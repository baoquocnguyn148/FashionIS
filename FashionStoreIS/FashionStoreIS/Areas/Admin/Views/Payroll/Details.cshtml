@model FashionStoreIS.Models.Payroll

@{
    ViewData["Title"] = "Phiếu lương - " + Model.Employee?.FullName;
}

<div style="max-width: 800px; margin: 0 auto;">
    <div class="admin-card">
        <div class="admin-card-header" style="background: rgba(255,255,255,0.02);">
            <div class="admin-card-title">PHIẾU LƯƠNG NHÂN VIÊN (THÁNG @Model.Month/@Model.Year)</div>
            <button class="btn-admin btn-secondary" onclick="window.print()">
                <i class="fa-solid fa-print"></i> In phiếu lương
            </button>
        </div>
        <div class="admin-content" style="padding: 40px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 40px; border-bottom: 1px solid var(--admin-border); padding-bottom: 30px;">
                <div>
                    <h2 style="font-size: 24px; font-weight: 800; color: #fff; margin-bottom: 4px;">@Model.Employee?.FullName</h2>
                    <p style="color: var(--admin-muted); font-size: 13px;">Chức vụ: @Model.Employee?.Position</p>
                    <p style="color: var(--admin-muted); font-size: 13px;">Phòng ban: @(Model.Employee?.Department?.Name ?? "N/A")</p>
                </div>
                <div style="text-align: right;">
                    <div class="logo-box" style="margin-left: auto; margin-bottom: 10px;">B</div>
                    <h3 style="font-size: 16px; font-weight: 700; color: #fff;">BN STORE ERP</h3>
                    <p style="color: var(--admin-muted); font-size: 12px;">Hệ thống Quản trị Thời trang</p>
                </div>
            </div>

            <div class="stat-grid" style="grid-template-columns: 1fr 1fr 1fr; margin-bottom: 40px;">
                <div class="stat-card" style="padding: 20px;">
                    <div class="stat-label">TỔNG SỐ GIỜ LÀM</div>
                    <div class="stat-value" style="font-size: 24px;">@Model.TotalHoursWorked.ToString("0.##") giờ</div>
                </div>
                <div class="stat-card" style="padding: 20px;">
                    <div class="stat-label">LƯƠNG CƠ BẢN/GIỜ</div>
                    <div class="stat-value" style="font-size: 24px;">@Model.BaseHourlyRate.ToString("N0") đ</div>
                </div>
                <div class="stat-card" style="background: var(--admin-accent); padding: 20px;">
                    <div class="stat-label" style="color: rgba(255,255,255,0.8);">THÀNH TIỀN CƠ BẢN</div>
                    <div class="stat-value" style="font-size: 24px; color: #fff;">@Model.TotalBaseSalary.ToString("N0") đ</div>
                </div>
            </div>

            <h4 style="font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--admin-muted); text-transform: uppercase; margin-bottom: 15px;">CHI TIẾT CÁC KHOẢN CỘNG/TRỪ</h4>
            <div class="admin-table-container" style="border: 1px solid var(--admin-border); border-radius: 4px; margin-bottom: 30px;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Nội dung</th>
                            <th>Mô tả</th>
                            <th style="text-align: right;">Số tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td style="font-weight: 600;">@(item.SalaryComponent?.Name ?? "Phụ cấp/Trừ khác")</td>
                                <td style="color: var(--admin-muted);">@item.Note</td>
                                <td style="text-align: right; font-weight: 600; color: @(item.SalaryComponent?.Type == SalaryComponentType.Deduction ? "var(--admin-red)" : "var(--admin-green)")">
                                    @(item.SalaryComponent?.Type == SalaryComponentType.Deduction ? "-" : "+")@item.Amount.ToString("N0") đ
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="background: rgba(255,255,255,0.03); padding: 30px; border-radius: 4px; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <div class="stat-label">TỔNG LƯƠNG THỰC LĨNH</div>
                    <div style="font-size: 36px; font-weight: 900; color: #fff; letter-spacing: -1px;">@Model.NetSalary.ToString("N0") VNĐ</div>
                    <p style="font-size: 11px; color: var(--admin-muted); margin-top: 5px;">Trạng thái: 
                        @if (Model.Status == PayrollStatus.Paid) {
                           <span style="color: var(--admin-green);">ĐÃ THANH TOÁN NGÀY @Model.ProcessedDate?.ToString("dd/MM/yyyy")</span>
                        } else {
                           <span style="color: var(--admin-accent);">CHỜ THANH TOÁN</span>
                        }
                    </p>
                </div>
                <div style="text-align: center;">
                    <p style="font-size: 12px; margin-bottom: 60px; color: var(--admin-muted);">Chữ ký kế toán</p>
                    <p style="font-weight: 600;">(Đã ký điện tử)</p>
                </div>
            </div>

            <div style="margin-top: 40px; display: flex; gap: 10px;">
                <a asp-action="Index" asp-route-month="@Model.Month" asp-route-year="@Model.Year" class="btn-admin btn-secondary">Quay lại</a>
                @if (Model.Status != PayrollStatus.Paid)
                {
                    <form asp-action="ProcessPayment" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn-admin btn-primary">Xác nhận thanh toán lương</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        body { background: white; color: black; }
        .admin-sidebar, .admin-topbar, .btn-admin, form { display: none !important; }
        .admin-main { margin: 0; padding: 0; width: 100%; }
        .admin-card { border: none; background: white; width: 100%; }
        .admin-card-header { display: none; }
        .stat-card { border: 1px solid #ccc; color: black !important; }
        .stat-value { color: black !important; }
        .admin-table th, .admin-table td { border-bottom: 1px solid #eee; color: black !important; }
        .logo-box { background: black !important; }
    }
</style>
