@model List<FashionStoreIS.Models.ReturnRequest>
@{
    ViewData["Title"] = "Quản lý Trả hàng";
}

<div class="search-bar" style="display:flex; justify-content:space-between; align-items:center;">
    <form method="get" style="display:flex; gap:10px; align-items:center;">
        <select name="status" class="form-control" style="width:200px;">
            <option value="">Tất cả trạng thái</option>
            <option value="Pending" selected="@(ViewBag.SelectedStatus == "Pending" ? "selected" : null)">Chờ xử lý (@ViewBag.PendingCount)</option>
            <option value="Approved" selected="@(ViewBag.SelectedStatus == "Approved" ? "selected" : null)">Đã duyệt</option>
            <option value="Rejected" selected="@(ViewBag.SelectedStatus == "Rejected" ? "selected" : null)">Từ chối</option>
            <option value="Completed" selected="@(ViewBag.SelectedStatus == "Completed" ? "selected" : null)">Hoàn tất</option>
        </select>
        <button type="submit" class="btn-admin btn-secondary">
            <i class="fas fa-filter"></i> Lọc
        </button>
    </form>
</div>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Lý do</th>
                <th>Hoàn tiền dự kiến</th>
                <th>Trạng thái</th>
                <th>Thời gian gửi</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td><span class="order-id">#@r.Order?.OrderCode</span></td>
                    <td><div class="text-truncate" style="max-width: 200px;" title="@r.Reason">@r.Reason</div></td>
                    <td><div class="price-text">@r.RefundAmount.ToString("N0") VND</div></td>
                    <td>
                        @{
                            var statusClass = r.Status.ToString().ToLower();
                            var statusName = r.Status switch
                            {
                                FashionStoreIS.Models.ReturnRequestStatus.Pending => "Chờ xử lý",
                                FashionStoreIS.Models.ReturnRequestStatus.Approved => "Đã duyệt",
                                FashionStoreIS.Models.ReturnRequestStatus.Rejected => "Từ chối",
                                FashionStoreIS.Models.ReturnRequestStatus.Completed => "Hoàn tất",
                                _ => r.Status.ToString()
                            };
                            var badgeClass = r.Status switch
                            {
                                FashionStoreIS.Models.ReturnRequestStatus.Pending => "status-pending",
                                FashionStoreIS.Models.ReturnRequestStatus.Approved => "status-processing",
                                FashionStoreIS.Models.ReturnRequestStatus.Completed => "status-delivered",
                                FashionStoreIS.Models.ReturnRequestStatus.Rejected => "status-cancelled",
                                _ => ""
                            };
                        }
                        <span class="status-badge @badgeClass">@statusName</span>
                    </td>
                    <td><div class="date-text">@r.CreatedAt.ToString("dd/MM/yyyy")<br/><small>@r.CreatedAt.ToString("HH:mm")</small></div></td>
                    <td>
                        <a href="/Admin/Return/Details/@r.Id" class="btn-action btn-view">
                            <i class="fas fa-edit"></i> Xử lý
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-rotate-left"></i>
            <p>Không tìm thấy yêu cầu trả hàng nào.</p>
        </div>
    }
</div>

<style>
.order-id {
    font-family: 'Courier New', Courier, monospace;
    font-weight: bold;
    color: #a78bfa;
    background: rgba(167, 139, 250, 0.1);
    padding: 4px 8px;
    border-radius: 6px;
}
.price-text { font-weight: 700; color: #10b981; font-size: 15px; }
.date-text { font-size: 13px; color: #9ca3af; line-height: 1.2; }

.status-badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
}
.status-pending { background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); color: #451a03; }
.status-processing { background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%); color: #eff6ff; }
.status-delivered { background: linear-gradient(135deg, #34d399 0%, #10b981 100%); color: #ecfdf5; }
.status-cancelled { background: linear-gradient(135deg, #f87171 0%, #ef4444 100%); color: #fef2f2; }

.btn-view {
    background: rgba(255, 255, 255, 0.05);
    color: #e5e7eb;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 6px 12px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 12px;
    transition: all 0.3s ease;
}
.btn-view:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }

.empty-state { text-align: center; padding: 60px; color: #6b7280; }
.empty-state i { font-size: 48px; margin-bottom: 20px; opacity: 0.3; }
</style>
