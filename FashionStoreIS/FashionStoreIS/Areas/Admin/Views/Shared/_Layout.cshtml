@using Microsoft.AspNetCore.Identity
@using FashionStoreIS.Models
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - BN STORE</title>
    @{
        var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    }
    @if (!string.IsNullOrEmpty(csrfToken))
    {
        <meta name="csrf-token" content="@csrfToken" />
    }
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --admin-bg: #030712;
            --admin-sidebar: #020617;
            --admin-card: #0f172a;
            --admin-border: #1e293b;
            --admin-accent: #8b5cf6; /* Modern Purple */
            --admin-text: #f1f5f9;
            --admin-muted: #94a3b8;
            --admin-green: #10b981;
            --admin-red: #ef4444;
        }
        body { font-family: 'Outfit', sans-serif; background: var(--admin-bg); color: var(--admin-text); display: flex; min-height: 100vh; }

        /* Sidebar */
        .admin-sidebar {
            width: 280px;
            background: var(--admin-sidebar);
            border-right: 1px solid var(--admin-border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 100;
            padding: 32px 20px;
            transition: width 0.3s ease;
            overflow-x: hidden; /* Prevent horizontal scroll */
            scrollbar-width: none; /* Firefox */
        }
        .admin-sidebar::-webkit-scrollbar { display: none; } /* Chrome, Safari, Edge */

        .sidebar-logo {
            padding: 0 10px 40px;
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
        }
        .logo-box {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 900;
            box-shadow: 0 8px 16px rgba(99, 102, 241, 0.2);
        }
        
        .sidebar-nav { 
            flex: 1; 
            display: flex; 
            flex-direction: column; 
            gap: 8px; 
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: none; /* Firefox */
        }
        .sidebar-nav::-webkit-scrollbar { display: none; } /* Chrome, Safari, Edge */
        
        .nav-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 14px 18px;
            font-size: 14px;
            font-weight: 500;
            color: var(--admin-muted);
            text-decoration: none;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 14px;
            position: relative;
        }
        .nav-item:hover { color: #fff; background: rgba(255,255,255,0.03); transform: translateX(5px); }
        .nav-item.active { 
            color: #fff; 
            background: linear-gradient(90deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0.05) 100%);
            border: 1px solid rgba(99, 102, 241, 0.2);
        }
        .nav-item.active::before {
            content: '';
            position: absolute;
            left: -20px;
            width: 4px;
            height: 24px;
            background: #6366f1;
            border-radius: 0 4px 4px 0;
            box-shadow: 4px 0 12px rgba(99, 102, 241, 0.5);
        }
        .nav-item i { width: 20px; font-size: 18px; opacity: 0.7; transition: all 0.3s; }
        .nav-item.active i { color: #6366f1; opacity: 1; transform: scale(1.1); }
        
        .sidebar-footer { 
            margin-top: auto;
            padding: 24px 10px 0;
            border-top: 1px solid var(--admin-border);
            font-size: 12px;
            color: var(--admin-muted);
        }

        /* Main */
        .admin-main { margin-left: 280px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
        .admin-topbar {
            height: 70px;
            border-bottom: 1px solid var(--admin-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            background: rgba(2, 6, 23, 0.8);
            backdrop-filter: blur(8px);
            position: sticky;
            top: 0;
            z-index: 99;
        }
        .topbar-title { font-size: 18px; font-weight: 700; color: #fff; }
        .topbar-right { display: flex; align-items: center; gap: 24px; }
        .user-profile { display: flex; align-items: center; gap: 10px; cursor: pointer; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: #8b5cf6; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #fff; font-size: 12px; }
        
        .admin-content { padding: 40px; flex: 1; }

        /* Cards */
        .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 30px; }
        .stat-card {
            background: var(--admin-card);
            border: 1px solid var(--admin-border);
            padding: 22px 24px;
            border-radius: 4px;
        }
        .stat-label { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--admin-muted); margin-bottom: 10px; }
        .stat-value { font-size: 32px; font-weight: 700; color: #fff; }
        .stat-sub { font-size: 11px; color: var(--admin-muted); margin-top: 4px; }

        /* Tables */
        .admin-card { background: var(--admin-card); border: 1px solid var(--admin-border); border-radius: 4px; overflow: hidden; margin-bottom: 24px; }
        .admin-card-header { padding: 18px 24px; border-bottom: 1px solid var(--admin-border); display: flex; align-items: center; justify-content: space-between; }
        .admin-card-title { font-size: 13px; font-weight: 600; color: #fff; }
        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table th { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--admin-muted); padding: 12px 24px; text-align: left; border-bottom: 1px solid var(--admin-border); }
        .admin-table td { padding: 14px 24px; font-size: 13px; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle; }
        .admin-table tr:last-child td { border-bottom: none; }
        .admin-table tr:hover td { background: rgba(255,255,255,0.02); }
        .product-thumb { width: 44px; height: 44px; object-fit: cover; background: #2a2a2a; border-radius: 3px; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 2px; font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; }
        .badge-green { background: rgba(34,197,94,0.15); color: var(--admin-green); }
        .badge-red { background: rgba(239,68,68,0.15); color: var(--admin-red); }

        /* Buttons */
        .btn-admin { display: inline-flex; align-items: center; gap: 6px; padding: 9px 18px; font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; border: none; border-radius: 2px; text-decoration: none; transition: opacity 0.2s; }
        .btn-admin:hover { opacity: 0.8; }
        .btn-primary { background: #fff; color: #000; }
        .btn-danger { background: rgba(239,68,68,0.15); color: var(--admin-red); }
        .btn-secondary { background: var(--admin-border); color: var(--admin-text); }
        .btn-sm { padding: 6px 12px; font-size: 11px; }

        /* Forms */
        .form-group { margin-bottom: 20px; }
        .form-label { display: block; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--admin-muted); margin-bottom: 8px; }
        .form-control { width: 100%; padding: 11px 14px; background: var(--admin-border); border: 1px solid rgba(255,255,255,0.08); color: #fff; font-size: 13px; font-family: 'Outfit', sans-serif; border-radius: 2px; outline: none; transition: border-color 0.2s; }
        .form-control:focus { border-color: rgba(255,255,255,0.3); }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
        .form-check { display: flex; align-items: center; gap: 10px; cursor: pointer; }
        .form-check input { width: 16px; height: 16px; }

        /* Alert */
        .alert { padding: 12px 16px; border-radius: 2px; font-size: 13px; margin-bottom: 20px; }
        .alert-success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: var(--admin-green); }
        .alert-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: var(--admin-red); }

        /* Image preview */
        .image-preview { width: 120px; height: 120px; object-fit: cover; border: 1px solid var(--admin-border); border-radius: 3px; margin-top: 10px; }

        /* Search */
        .search-bar { display: flex; gap: 10px; margin-bottom: 20px; }
        .search-bar .form-control { max-width: 280px; }
        textarea.form-control { min-height: 100px; resize: vertical; }
        select.form-control option { background: #1e1e1e; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <div class="logo-box">B</div>
            BN Store Admin
        </div>
        <nav class="sidebar-nav">
            <a href="/Admin/Dashboard" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fa-solid fa-gauge-high"></i>
                Dashboard
            </a>

            <a href="/Admin/Pos" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pos" ? "active" : "")">
                <i class="fa-solid fa-cash-register"></i>
                Bán hàng tại quầy
            </a>


            <a href="/Admin/Products" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
                <i class="fa-solid fa-boxes-stacked"></i>
                Sản phẩm
            </a>

            <a href="/Admin/Order" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                <i class="fa-solid fa-cart-shopping"></i>
                Đơn hàng
            </a>

            <a href="/Admin/Return" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Return" ? "active" : "")">
                <i class="fa-solid fa-rotate-left"></i>
                Trả hàng / Hoàn tiền
            </a>

            <a href="/Admin/AdminNotification" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminNotification" ? "active" : "")">
                <i class="fa-solid fa-bell"></i>
                Thông báo kh
            </a>

            <a href="/Admin/Inventory" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")">
                <i class="fa-solid fa-warehouse"></i>
                Tồn kho SKU
            </a>

            <a href="/Admin/Customers" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")">
                <i class="fa-solid fa-users"></i>
                Khách hàng
            </a>

            <div style="font-size:9px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#334155; padding:14px 18px 4px; margin-top:4px;">CRM</div>

            <a href="/Admin/Crm/Analytics" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Crm" && ViewContext.RouteData.Values["action"]?.ToString() == "Analytics" ? "active" : "")">
                <i class="fa-solid fa-chart-pie" style="color:#6366f1;"></i>
                CRM Analytics
            </a>

            <a href="/Admin/Crm/Segments" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Crm" && ViewContext.RouteData.Values["action"]?.ToString() == "Segments" ? "active" : "")">
                <i class="fa-solid fa-layer-group" style="color:#10b981;"></i>
                Phân khúc RFM
            </a>

            <a href="/Admin/Campaign" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Campaign" ? "active" : "")">
                <i class="fa-solid fa-bullhorn" style="color:#f59e0b;"></i>
                Campaign
            </a>

            <a href="/Admin/Vouchers" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vouchers" ? "active" : "")">
                <i class="fa-solid fa-ticket"></i>
                Khuyến mãi
            </a>

            <a href="/Admin/Categories" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")">
                <i class="fa-solid fa-layer-group"></i>
                Danh mục
            </a>

            <a href="/Admin/Banners" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Banners" ? "active" : "")">
                <i class="fa-solid fa-image"></i>
                Banner
            </a>

            <div style="font-size:9px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#334155; padding:14px 18px 4px; margin-top:4px;">HRM & PAYROLL</div>

            <a href="/Admin/Departments" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")">
                <i class="fa-solid fa-sitemap" style="color:#6366f1;"></i>
                Phòng ban
            </a>

            <a href="/Admin/Employees" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employees" ? "active" : "")">
                <i class="fa-solid fa-user-tie" style="color:#10b981;"></i>
                Nhân viên
            </a>

            <a href="/Admin/Shifts" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shifts" ? "active" : "")">
                <i class="fa-solid fa-clock" style="color:#8b5cf6;"></i>
                Quản lý ca
            </a>

            <a href="/Admin/Schedules" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Schedules" ? "active" : "")">
                <i class="fa-solid fa-calendar-week" style="color:#0ea5e9;"></i>
                Xếp lịch tuần
            </a>

            <a href="/Admin/Attendances" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Attendances" ? "active" : "")">
                <i class="fa-solid fa-fingerprint" style="color:#f59e0b;"></i>
                Chấm công
            </a>

            <a href="/Admin/LeaveRequest" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "LeaveRequest" ? "active" : "")">
                <i class="fa-solid fa-file-circle-check" style="color:#ec4899;"></i>
                Nghỉ phép
            </a>

            <a href="/Admin/Payroll" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payroll" ? "active" : "")">
                <i class="fa-solid fa-money-check-dollar" style="color:#f43f5e;"></i>
                Bảng lương
            </a>

            <a href="/Admin/KpiReview/Leaderboard" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "KpiReview" ? "active" : "")">
                <i class="fa-solid fa-trophy" style="color:#fbbf24;"></i>
                KPI & Xếp hạng
            </a>

            @if (User.IsInRole("SuperAdmin"))
            {
                <a href="/Admin/Staff" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" ? "active" : "")">
                    <i class="fa-solid fa-user-shield"></i>
                    Nhân viên
                </a>
            }
        </nav>
        <div class="sidebar-footer">
            <div>BN Store Admin Dashboard v1.0</div>
            <div>© 2026 All rights reserved</div>
            <a href="/" target="_blank" style="margin-top:8px; display:block; color: var(--admin-accent); text-decoration: none;">Về trang chính</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-topbar">
            <div class="topbar-title">@ViewData["Title"]</div>
            <div class="topbar-right">
                @{
                    var user = await UserManager.GetUserAsync(User);
                }
                <div class="user-profile">
                    <div class="user-avatar">@(user?.FullName?[0] ?? 'A')</div>
                    <span>@(user?.FullName ?? user?.UserName ?? "Administrator")</span>
                </div>
                <form id="logoutForm" method="post" action="/Identity/Account/Logout?returnUrl=@Url.Content("~/")">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="background: none; border: none; color: var(--admin-red); cursor: pointer; font-weight: 600; font-size: 13px; padding: 0;">Đăng xuất</button>
                </form>
            </div>
        </div>
        <div class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @RenderBody()
        </div>
    </main>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        (function () {
            const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
            if (token && window.jQuery) {
                $.ajaxSetup({ headers: { 'RequestVerificationToken': token } });
            }
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
