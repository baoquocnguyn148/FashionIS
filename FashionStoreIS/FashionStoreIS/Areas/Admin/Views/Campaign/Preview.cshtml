@model FashionStoreIS.Areas.Admin.ViewModels.CampaignViewModel
@using FashionStoreIS.Services
@{
    Layout = "_Layout";
    ViewData["Title"] = $"Preview Campaign: {Model.Name}";
}

@section Styles {
<style>
    .preview-header { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:24px 28px; margin-bottom:24px; display:grid; grid-template-columns:1fr auto; align-items:start; gap:20px; }
    .recipient-grid { display:grid; gap:10px; }
    .rec-row { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:10px; padding:12px 18px; display:grid; grid-template-columns:36px 1fr 100px 120px 90px; align-items:center; gap:12px; font-size:13px; }
    .rec-av { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#6366f1,#a855f7); display:flex; align-items:center; justify-content:center; font-weight:700; color:#fff; font-size:13px; }
    .notif-preview-card { background:rgba(99,102,241,.06); border:1px solid rgba(99,102,241,.2); border-radius:12px; padding:20px 24px; margin-bottom:24px; }
</style>
}

<a href="/Admin/Campaign" style="color:var(--admin-muted); font-size:12px; text-decoration:none; display:flex; align-items:center; gap:6px; margin-bottom:16px;">
    <i class="fa fa-arrow-left"></i> Quay lại Campaign
</a>

<!-- Campaign Summary -->
<div class="preview-header">
    <div>
        <div style="font-size:20px; font-weight:700; margin-bottom:8px;">@Model.Name</div>
        <div style="font-size:13px; color:var(--admin-muted); display:flex; gap:16px; flex-wrap:wrap;">
            <span>🎯 Nhóm: <strong style="color:#fff;">@(Model.TargetSegment == "All" ? "Tất cả khách hàng" : RfmSegmentationService.GetSegmentLabel(Model.TargetSegment))</strong></span>
            <span>👥 Số người nhận ước tính: <strong style="color:#6366f1;">@Model.PreviewRecipients.Count</strong></span>
            @if (!string.IsNullOrEmpty(Model.VoucherCode))
            {
                <span>🎁 Voucher: <strong style="color:#f59e0b;">@Model.VoucherCode</strong></span>
            }
        </div>
        @if (Model.IsSent)
        {
            <div style="margin-top:10px; color:#10b981; font-weight:600; font-size:13px;">✅ Đã gửi lúc @Model.SentAt?.ToString("dd/MM/yyyy HH:mm") • @Model.RecipientCount người nhận</div>
        }
    </div>
    @if (!Model.IsSent)
    {
        <form method="post" action="/Admin/Campaign/Send/@Model.Id" onsubmit="return confirm('Xác nhận gửi campaign tới @Model.PreviewRecipients.Count người?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-admin btn-primary" style="font-size:14px; padding:12px 24px;">
                <i class="fa fa-paper-plane"></i> Gửi ngay (@Model.PreviewRecipients.Count người)
            </button>
        </form>
    }
</div>

<!-- Notification Preview -->
<div class="notif-preview-card">
    <div style="font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#6366f1; margin-bottom:12px;">📱 Thông báo sẽ được gửi</div>
    <div style="font-size:15px; font-weight:700; color:#fff; margin-bottom:6px;">@Model.NotificationTitle</div>
    <div style="font-size:13px; color:var(--admin-muted); line-height:1.6;">@Model.NotificationMessage</div>
    @if (!string.IsNullOrEmpty(Model.VoucherCode))
    {
        <div style="margin-top:10px; padding:10px 14px; background:rgba(245,158,11,.1); border-radius:8px; color:#f59e0b; font-size:13px; font-weight:600;">
            🎁 Mã giảm giá: @Model.VoucherCode
        </div>
    }
</div>

<!-- Recipients List -->
<div class="admin-card">
    <div class="admin-card-header">
        <span class="admin-card-title">👥 Danh sách người nhận (@Model.PreviewRecipients.Count)</span>
    </div>
    <div style="padding:0 20px 16px;">
        @if (!Model.PreviewRecipients.Any())
        {
            <div style="padding:40px; text-align:center; color:var(--admin-muted);">
                Không có khách hàng nào trong nhóm "@Model.TargetSegment"
            </div>
        }
        else
        {
            <div class="rec-row" style="font-size:10px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--admin-muted); padding:10px 18px;">
                <div></div><div>Khách hàng</div><div>Đơn hàng</div><div>Tổng chi</div><div>Hạng</div>
            </div>
            @foreach (var c in Model.PreviewRecipients)
            {
                var tcolor = c.Tier.ToString() == "Vip" ? "#a855f7" : c.Tier.ToString() == "Gold" ? "#f59e0b" : c.Tier.ToString() == "Silver" ? "#9ca3af" : "#cd7f32";
                <div class="rec-row">
                    <div class="rec-av">@c.FullName[0]</div>
                    <div>
                        <div style="font-weight:600; color:#fff;">@c.FullName</div>
                        <div style="font-size:11px; color:var(--admin-muted);">@c.Email</div>
                    </div>
                    <div style="color:var(--admin-muted);">@c.OrderCount đơn</div>
                    <div style="font-weight:600;">@c.TotalSpent.ToString("N0")₫</div>
                    <div><span style="font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;background:@(tcolor)22;color:@tcolor;">@c.Tier</span></div>
                </div>
            }
        }
    </div>
</div>
