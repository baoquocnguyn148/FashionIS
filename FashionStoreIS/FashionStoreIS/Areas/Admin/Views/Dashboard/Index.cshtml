@model FashionStoreIS.Areas.Admin.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Statistics Cards -->
<div class="stat-grid">
    <div class="stat-card revenue">
        <div class="stat-icon"><i class="fa-solid fa-coins"></i></div>
        <div class="stat-content">
            <div class="stat-label">Tổng doanh thu</div>
            <div class="stat-value">@Model.TotalRevenue.ToString("N0") <small>VND</small></div>
            <div class="stat-trend positive"><i class="fa-solid fa-arrow-up"></i> +12%</div>
        </div>
    </div>
    <div class="stat-card orders">
        <div class="stat-icon"><i class="fa-solid fa-cart-shopping"></i></div>
        <div class="stat-content">
            <div class="stat-label">Đơn hàng mới</div>
            <div class="stat-value">@Model.TotalOrders</div>
            <div class="stat-sub">@Model.TotalCustomers Khách hàng</div>
        </div>
    </div>
    <div class="stat-card products">
        <div class="stat-icon"><i class="fa-solid fa-box-open"></i></div>
        <div class="stat-content">
            <div class="stat-label">Sản phẩm</div>
            <div class="stat-value">@Model.TotalProducts</div>
            <div class="stat-sub">Đang kinh doanh</div>
        </div>
    </div>
    <div class="stat-card average">
        <div class="stat-icon"><i class="fa-solid fa-chart-line"></i></div>
        <div class="stat-content">
            <div class="stat-label">Giá trị trung bình</div>
            <div class="stat-value">@((Model.TotalOrders > 0 ? Model.TotalRevenue / Model.TotalOrders : 0).ToString("N0")) <small>VND</small></div>
            <div class="stat-sub">Mỗi đơn hàng</div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="chart-layout">
    <!-- Revenue Trend Chart -->
    <div class="admin-card glass-card chart-container">
        <div class="admin-card-header">
            <div class="admin-card-title"><i class="fa-solid fa-chart-area"></i> Xu hướng doanh thu theo tháng</div>
        </div>
        <div class="chart-body">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Order Status Chart -->
    <div class="admin-card glass-card status-container">
        <div class="admin-card-header">
            <div class="admin-card-title"><i class="fa-solid fa-chart-pie"></i> Tỉ lệ trạng thái</div>
        </div>
        <div class="chart-body">
            <canvas id="statusChart"></canvas>
        </div>
    </div>
</div>

<!-- Top Products and Customers -->
<div class="data-grid">
    <!-- Top Products -->
    <div class="admin-card glass-card">
        <div class="admin-card-header">
            <div class="admin-card-title"><i class="fa-solid fa-fire"></i> Sản phẩm bán chạy</div>
        </div>
        <div class="card-table-wrapper">
            <table class="admin-table premium-table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th style="text-align: center;">SL</th>
                        <th style="text-align: right;">Doanh thu</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TopProducts.Any())
                    {
                        @foreach (var product in Model.TopProducts)
                        {
                            <tr>
                                <td>
                                    <div class="prod-entry">
                                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                                        {
                                            <img src="@product.ImageUrl" class="prod-img" />
                                        }
                                        else
                                        {
                                            <div class="prod-img-placeholder">NA</div>
                                        }
                                        <div class="prod-name">@product.ProductName</div>
                                    </div>
                                </td>
                                <td style="text-align: center;"><span class="count-badge">@product.TotalQuantity</span></td>
                                <td style="text-align: right;"><span class="price-val">@product.TotalRevenue.ToString("N0") VND</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3" class="empty-msg">Chưa có dữ liệu giao dịch</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Top Customers -->
    <div class="admin-card glass-card">
        <div class="admin-card-header">
            <div class="admin-card-title"><i class="fa-solid fa-crown" style="color:#fcd34d;"></i> Khách hàng thân thiết</div>
        </div>
        <div class="card-table-wrapper">
            <table class="admin-table premium-table">
                <thead>
                    <tr>
                        <th>Khách hàng</th>
                        <th style="text-align: center;">Đơn</th>
                        <th style="text-align: right;">Tổng chi</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TopCustomers.Any())
                    {
                        @foreach (var customer in Model.TopCustomers)
                        {
                            <tr>
                                <td>
                                    <div class="user-entry">
                                        <div class="user-initials">@customer.CustomerName[0]</div>
                                        <div class="user-info">
                                            <div class="user-name">@customer.CustomerName</div>
                                            <div class="user-phone">@customer.Phone</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="text-align: center;"><span class="count-badge">@customer.OrderCount</span></td>
                                <td style="text-align: right;"><span class="price-val total">@customer.TotalSpent.ToString("N0") VND</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3" class="empty-msg">Chưa có khách mua hàng</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
/* Dashboard Specific Styles */
.stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 24px; }
.stat-card {
    background: #0f172a;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 20px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}
.stat-card:hover { transform: translateY(-5px); border-color: rgba(99, 102, 241, 0.4); box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5); }
.stat-card::after { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 3px; opacity: 0.3; }
.stat-card.revenue::after { background: #10b981; }
.stat-card.orders::after { background: #3b82f6; }
.stat-card.products::after { background: #a855f7; }
.stat-card.average::after { background: #f59e0b; }

.stat-icon {
    width: 60px; height: 60px;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    background: rgba(255,255,255,0.03);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.05);
}
.revenue .stat-icon { color: #10b981; background: rgba(16, 185, 129, 0.1); }
.orders .stat-icon { color: #3b82f6; background: rgba(59, 130, 246, 0.1); }
.products .stat-icon { color: #a855f7; background: rgba(168, 85, 247, 0.1); }
.average .stat-icon { color: #f59e0b; background: rgba(245, 158, 11, 0.1); }

.stat-label { font-size: 13px; color: var(--admin-muted); font-weight: 500; margin-bottom: 4px; }
.stat-value { font-size: 26px; font-weight: 800; color: #fff; line-height: 1; }
.stat-value small { font-size: 14px; color: var(--admin-muted); font-weight: 500; }
.stat-trend { font-size: 12px; margin-top: 8px; font-weight: 600; }
.trend-positive { color: #10b981; }
.stat-sub { font-size: 11px; color: #64748b; margin-top: 4px; }

.chart-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px; }
.glass-card { background: rgba(15, 23, 42, 0.6) !important; backdrop-filter: blur(12px); border-color: rgba(255,255,255,0.05) !important; }
.chart-body { padding: 24px; min-height: 320px; }

.data-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.premium-table { font-size: 14px; }
.premium-table th { padding: 12px 20px; background: rgba(255,255,255,0.02); }
.premium-table td { padding: 16px 20px; }

.prod-entry { display: flex; align-items: center; gap: 12px; }
.prod-img { width: 44px; height: 44px; border-radius: 8px; object-fit: cover; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }
.prod-img-placeholder { width: 44px; height: 44px; background: #1e293b; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 10px; color: #64748b; }
.prod-name { font-weight: 600; color: #f1f5f9; }

.user-entry { display: flex; align-items: center; gap: 12px; }
.user-initials { width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, #6366f1, #a855f7); display: flex; align-items: center; justify-content: center; font-weight: 700; color: #fff; }
.user-info .user-name { font-weight: 600; color: #f1f5f9; }
.user-info .user-phone { font-size: 11px; color: #64748b; }

.count-badge { background: #1e293b; color: #cbd5e1; padding: 4px 10px; border-radius: 8px; font-size: 12px; font-weight: 700; }
.price-val { font-weight: 700; color: #10b981; }
.price-val.total { color: #fcd34d; }

.empty-msg { text-align: center; padding: 40px; color: #64748b; font-style: italic; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Set global defaults
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.font.family = "'Outfit', sans-serif";

        // Revenue Trend Chart
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        const revenueGradient = revenueCtx.createLinearGradient(0, 0, 0, 400);
        revenueGradient.addColorStop(0, 'rgba(99, 102, 241, 0.4)');
        revenueGradient.addColorStop(1, 'rgba(99, 102, 241, 0)');

        new Chart(revenueCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.MonthlyRevenueData.Select(m => m.Month).ToList())),
                datasets: [{
                    label: 'Doanh thu',
                    data: @Html.Raw(Json.Serialize(Model.MonthlyRevenueData.Select(m => m.Revenue).ToList())),
                    borderColor: '#6366f1',
                    borderWidth: 3,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#6366f1',
                    pointBorderWidth: 2,
                    pointRadius: 6,
                    pointHoverRadius: 8,
                    tension: 0.4,
                    fill: true,
                    backgroundColor: revenueGradient
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { padding: 10 } },
                    y: { 
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { padding: 10, callback: (v) => v.toLocaleString() + ' VND' }
                    }
                }
            }
        });

        // Order Status Chart
        const statusCtx = document.getElementById('statusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.OrderStatusData.Select(s => s.Status).ToList())),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.OrderStatusData.Select(s => s.Count).ToList())),
                    backgroundColor: [
                        '#fbbf24', // Pending - yellow
                        '#3b82f6', // Processing - blue
                        '#a855f7', // Shipped - purple
                        '#10b981', // Delivered - green
                        '#ef4444'  // Cancelled - red
                    ],
                    hoverOffset: 15,
                    borderWidth: 0,
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { padding: 25, usePointStyle: true, boxWidth: 8 }
                    }
                }
            }
        });
    </script>
}
