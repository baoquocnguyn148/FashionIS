@model FashionStoreIS.Areas.Admin.ViewModels.Crm.CrmAnalyticsViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "CRM Analytics";
    var segColors = new Dictionary<string,string>{
        {"Champions","#f59e0b"},{"Loyal","#6366f1"},{"PotentialLoyalists","#10b981"},
        {"New","#3b82f6"},{"AtRisk","#ef4444"},{"Lost","#64748b"},{"Others","#94a3b8"}
    };
}

@section Styles {
<style>
    .anl-kpi { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:28px; }
    .anl-card { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:20px 22px; }
    .anl-label { font-size:10px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--admin-muted); margin-bottom:8px; }
    .anl-value { font-size:28px; font-weight:800; color:#fff; }
    .anl-sub { font-size:11px; color:var(--admin-muted); margin-top:4px; }
    .chart-row { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px; }
    .chart-card { background:var(--admin-card); border:1px solid var(--admin-border); border-radius:12px; padding:22px; }
    .chart-title { font-size:13px; font-weight:700; color:#fff; margin-bottom:18px; }
    .vip-table { width:100%; border-collapse:collapse; }
    .vip-table th { font-size:10px; text-transform:uppercase; letter-spacing:.1em; color:var(--admin-muted); font-weight:700; padding:8px 0; text-align:left; border-bottom:1px solid var(--admin-border); }
    .vip-table td { padding:12px 0; font-size:13px; border-bottom:1px solid rgba(255,255,255,.04); vertical-align:middle; }
    .vip-rank { width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; }
    .seg-dist-row { display:flex; align-items:center; gap:12px; margin-bottom:10px; }
    .seg-dist-bar-wrap { flex:1; height:6px; background:rgba(255,255,255,.08); border-radius:3px; }
    .seg-dist-bar { height:6px; border-radius:3px; transition:width .6s ease; }
    .seg-dist-count { font-size:12px; font-weight:600; color:var(--admin-muted); width:40px; text-align:right; }
    .seg-dist-label { font-size:12px; color:var(--admin-muted); width:130px; }
</style>
}

<!-- KPIs -->
<div class="anl-kpi">
    <div class="anl-card">
        <div class="anl-label">Tổng khách hàng</div>
        <div class="anl-value">@Model.TotalCustomers</div>
        <div class="anl-sub">🆕 @Model.NewCustomers30Days mới trong 30 ngày</div>
    </div>
    <div class="anl-card">
        <div class="anl-label">Tỷ lệ quay lại</div>
        <div class="anl-value" style="color:#10b981;">@Model.RepeatRate.ToString("F0")%</div>
        <div class="anl-sub">@Model.RepeatCustomers / @Model.TotalCustomers khách mua ≥2 lần</div>
    </div>
    <div class="anl-card">
        <div class="anl-label">CLV trung bình</div>
        <div class="anl-value" style="font-size:20px;">@Model.AvgClv.ToString("N0")₫</div>
        <div class="anl-sub">Tổng doanh thu: @Model.TotalRevenue.ToString("N0")₫</div>
    </div>
    <div class="anl-card">
        <div class="anl-label">Churn Risk</div>
        <div class="anl-value" style="color:#ef4444;">@(Model.AtRiskCount + Model.LostCount)</div>
        <div class="anl-sub">⚠️ @Model.AtRiskCount nguy cơ • 💔 @Model.LostCount đã mất</div>
    </div>
</div>

<div class="anl-card" style="background:rgba(99,102,241,0.05); border:1px dashed #6366f1; text-align:center; margin-bottom:28px; display:flex; justify-content:space-between; align-items:center; padding: 12px 22px;">
    <div style="text-align:left;">
        <div class="anl-label" style="margin-bottom:4px;">Công cụ phát triển CRM</div>
        <div style="font-size:12px; color:var(--admin-muted);">Tùy chọn nạp dữ liệu mẫu để kiểm tra các phân khúc khách hàng.</div>
    </div>
    <div style="display:flex; gap:10px;">
        <a href="/Admin/Crm/AppendSampleSeed" class="btn-admin" style="background:rgba(16,185,129,0.1); border:1px solid #10b981; color:#10b981; padding: 8px 16px; font-size: 13px; border-radius:6px; text-decoration:none; font-weight:600;">➕ Nạp THÊM 20 hồ sơ</a>
        <a href="/Admin/Crm/TriggerSampleSeed" class="btn-admin btn-primary" style="padding: 8px 16px; font-size: 13px;">🚀 LÀM MỚI (Xóa & Nạp lại)</a>
    </div>
</div>

<!-- Campaign KPIs -->
<div style="display:grid; grid-template-columns:repeat(2,1fr); gap:16px; margin-bottom:28px;">
    <div class="anl-card" style="display:flex; align-items:center; gap:20px;">
        <div style="font-size:36px;">📣</div>
        <div>
            <div class="anl-label">Campaigns đã tạo</div>
            <div class="anl-value">@Model.TotalCampaigns</div>
            <div class="anl-sub">✅ @Model.SentCampaigns đã gửi</div>
        </div>
    </div>
    <div class="anl-card" style="display:flex; align-items:center; gap:20px;">
        <div style="font-size:36px;">👑</div>
        <div>
            <div class="anl-label">VIP customers</div>
            <div class="anl-value" style="color:#a855f7;">@Model.VipCount</div>
            <div class="anl-sub">Gold: @Model.GoldCount • Silver: @Model.SilverCount</div>
        </div>
    </div>
</div>

<!-- Charts row -->
<div class="chart-row">
    <!-- Monthly new customers -->
    <div class="chart-card">
        <div class="chart-title">📈 Khách hàng mới (6 tháng gần nhất)</div>
        <canvas id="chartNewCustomers" height="200"></canvas>
    </div>

    <!-- Tier distribution -->
    <div class="chart-card">
        <div class="chart-title">👑 Phân bổ hạng thành viên</div>
        <canvas id="chartTier" height="200"></canvas>
    </div>
</div>

<!-- Segment distribution + VIP table -->
<div style="display:grid; grid-template-columns:1fr 1.6fr; gap:20px; margin-bottom:24px;">
    <!-- Segment bars -->
    <div class="chart-card">
        <div class="chart-title">🎯 Phân bổ RFM Segment</div>
        @{
            var segDef = new[] {
                ("Champions","🏆 Champions","#f59e0b"),
                ("Loyal","💙 Trung thành","#6366f1"),
                ("PotentialLoyalists","⭐ Tiềm năng","#10b981"),
                ("New","🆕 Mới","#3b82f6"),
                ("AtRisk","⚠️ Nguy cơ","#ef4444"),
                ("Lost","💔 Đã mất","#64748b"),
                ("Others","📦 Khác","#94a3b8"),
            };
        }
        @foreach (var (key, label, color) in segDef)
        {
            var cnt = Model.SegmentCounts.TryGetValue(key, out var c) ? c : 0;
            var pct = Model.TotalCustomers > 0 ? (cnt * 100.0 / Model.TotalCustomers) : 0;
            <div class="seg-dist-row">
                <div class="seg-dist-label">@label</div>
                <div class="seg-dist-bar-wrap">
                    <div class="seg-dist-bar" style="width:@(pct.ToString("F0"))%; background:@color;"></div>
                </div>
                <div class="seg-dist-count">@cnt</div>
            </div>
        }
    </div>

    <!-- Top VIP -->
    <div class="chart-card">
        <div class="chart-title">🌟 Top 10 khách hàng VIP</div>
        <table class="vip-table">
            <thead><tr><th>#</th><th>Khách hàng</th><th>Đơn</th><th>Tổng chi</th><th>Hạng</th></tr></thead>
            <tbody>
                @for (int i = 0; i < Model.TopVipCustomers.Count; i++)
                {
                    var c = Model.TopVipCustomers[i];
                    var rc = i == 0 ? "#f59e0b" : i == 1 ? "#9ca3af" : i == 2 ? "#cd7f32" : "var(--admin-muted)";
                    var tc = c.Tier.ToString();
                    var tcolor = tc == "Vip" ? "#a855f7" : tc == "Gold" ? "#f59e0b" : tc == "Silver" ? "#9ca3af" : "#cd7f32";
                    <tr>
                        <td><div class="vip-rank" style="background:@(rc)22; color:@rc;">@(i+1)</div></td>
                        <td>
                            <a href="/Admin/Crm/CustomerProfile/@c.UserId" style="text-decoration:none; display:block;">
                                <div style="font-weight:600; color:#fff;">@c.FullName</div>
                                <div style="font-size:11px; color:var(--admin-muted);">@c.Email</div>
                            </a>
                        </td>
                        <td style="color:var(--admin-muted);">@c.OrderCount</td>
                        <td style="font-weight:700; color:#fff;">@c.TotalSpent.ToString("N0")₫</td>
                        <td><span style="font-size:11px; font-weight:700; padding:2px 8px; border-radius:20px; background:@(tcolor)22; color:@tcolor;">@c.Tier</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Chart 1: Monthly New Customers
new Chart(document.getElementById('chartNewCustomers'), {
    type: 'bar',
    data: {
        labels: [@Html.Raw(string.Join(",", Model.MonthlyNewCustomers.Select(m => $"'{m.Month}'")))],
        datasets: [{
            label: 'Khách mới',
            data: [@string.Join(",", Model.MonthlyNewCustomers.Select(m => m.Count))],
            backgroundColor: 'rgba(99,102,241,0.6)',
            borderColor: '#6366f1',
            borderWidth: 2,
            borderRadius: 6,
        }]
    },
    options: { responsive:true, plugins:{ legend:{display:false} }, scales:{ x:{ grid:{color:'rgba(255,255,255,.05)'}, ticks:{color:'#94a3b8'} }, y:{ grid:{color:'rgba(255,255,255,.05)'}, ticks:{color:'#94a3b8'} } } }
});

// Chart 2: Tier Donut
new Chart(document.getElementById('chartTier'), {
    type: 'doughnut',
    data: {
        labels: ['Bronze','Silver','Gold','VIP'],
        datasets: [{
            data: [@Model.BronzeCount, @Model.SilverCount, @Model.GoldCount, @Model.VipCount],
            backgroundColor: ['#cd7f3233','#9ca3af33','#f59e0b33','#a855f733'],
            borderColor:     ['#cd7f32',  '#9ca3af',  '#f59e0b',  '#a855f7'],
            borderWidth: 2,
        }]
    },
    options: { responsive:true, cutout:'65%', plugins:{ legend:{ position:'bottom', labels:{ color:'#94a3b8', font:{size:12} } } } }
});
</script>
}
