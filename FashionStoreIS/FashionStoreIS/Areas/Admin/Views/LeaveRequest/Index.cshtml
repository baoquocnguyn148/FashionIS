@model IEnumerable<FashionStoreIS.Models.LeaveRequest>

@{
    ViewData["Title"] = "Quản lý Nghỉ phép";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h2 style="font-size: 24px; font-weight: 700; color: #fff;">QUẢN LÝ NGHỈ PHÉP</h2>
    <a asp-action="Create" class="btn-admin btn-primary">
        <i class="fa-solid fa-plus"></i> NỘP ĐƠN MỚI
    </a>
</div>

<div class="admin-card" style="margin-bottom: 24px; padding: 20px;">
    <form method="get" style="display: flex; gap: 15px; align-items: flex-end;">
        <div style="width: 180px;">
            <label class="form-label">Trạng thái</label>
            <select name="status" class="form-control">
                <option value="">Tất cả</option>
                @foreach (var s in Enum.GetValues(typeof(FashionStoreIS.Models.LeaveStatus)))
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>
        <button type="submit" class="btn-admin btn-primary" style="height: 42px;">LỌC</button>
    </form>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <div class="admin-card-title">DANH SÁCH ĐƠN NGHỈ PHÉP</div>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Nhân viên</th>
                <th>Loại phép</th>
                <th>Từ ngày</th>
                <th>Đến ngày</th>
                <th>Lý do</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div style="font-weight: 600; color: #fff;">@item.Employee?.FullName</div>
                        <div style="font-size: 11px; color: var(--admin-muted);">@item.Employee?.Position</div>
                    </td>
                    <td><span class="type-badge @item.Type.ToString().ToLower()">@item.Type</span></td>
                    <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                    <td><div style="max-width: 200px; font-size: 11px;">@item.Reason</div></td>
                    <td>
                        <span class="badge @GetStatusClass(item.Status)">@item.Status</span>
                    </td>
                    <td>
                        @if (item.Status == FashionStoreIS.Models.LeaveStatus.Pending)
                        {
                            <div style="display: flex; gap: 8px;">
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-admin btn-sm" style="background: rgba(34,197,94,0.1); color: #22c55e;">DUYỆT</button>
                                </form>
                                <button type="button" onclick="openRejectModal(@item.Id)" class="btn-admin btn-sm btn-danger">TỪ CHỐI</button>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Từ chối -->
<div id="rejectModal" class="modal-overlay" style="display:none;">
    <div class="admin-card" style="width: 400px; margin: 100px auto;">
        <div class="admin-card-header"><div class="admin-card-title">TỪ CHỐI ĐƠN NGHỈ PHÉP</div></div>
        <div style="padding: 24px;">
            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="rejectId" />
                <div class="form-group">
                    <label class="form-label">Lý do từ chối</label>
                    <textarea name="adminNote" class="form-control" required></textarea>
                </div>
                <div style="display: flex; gap: 10px; margin-top: 20px;">
                    <button type="submit" class="btn-admin btn-primary" style="flex: 1;">XÁC NHẬN</button>
                    <button type="button" onclick="closeModal()" class="btn-admin btn-secondary" style="flex: 1;">HỦY</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .type-badge { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; }
    .annual { background: rgba(99,102,241,0.15); color: #6366f1; }
    .sick { background: rgba(244,63,94,0.15); color: #f43f5e; }
    .personal { background: rgba(245,158,11,0.15); color: #f59e0b; }
    
    .status-pending { background: rgba(148,163,184,0.15); color: #94a3b8; }
    .status-approved { background: rgba(34,197,94,0.15); color: #22c55e; }
    .status-rejected { background: rgba(239,68,68,0.15); color: #ef4444; }

    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; backdrop-filter: blur(4px); }
</style>

<script>
    function openRejectModal(id) {
        document.getElementById('rejectId').value = id;
        document.getElementById('rejectModal').style.display = 'block';
    }
    function closeModal() {
        document.getElementById('rejectModal').style.display = 'none';
    }
</script>

@functions {
    string GetStatusClass(FashionStoreIS.Models.LeaveStatus status) => status switch
    {
        FashionStoreIS.Models.LeaveStatus.Pending => "status-pending",
        FashionStoreIS.Models.LeaveStatus.Approved => "status-approved",
        FashionStoreIS.Models.LeaveStatus.Rejected => "status-rejected",
        _ => ""
    };
}
