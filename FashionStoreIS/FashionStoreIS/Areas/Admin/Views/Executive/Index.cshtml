@model FashionStoreIS.Areas.Admin.ViewModels.Executive.ExecutiveDashboardViewModel
@{
    ViewData["Title"] = "Executive Dashboard";
    Layout = "_AdminLayout";
}

<!-- ─── EXECUTIVE DASHBOARD HEADER ─────────────────────────────────────── -->
<div class="executive-header">
    <div class="executive-title">
        <h1><i class="fa-solid fa-chart-line"></i> Executive Dashboard</h1>
        <p class="executive-subtitle">Strategic Business Intelligence & Decision Support</p>
    </div>
    <div class="executive-actions">
        <button class="btn btn-primary" onclick="refreshDashboard()">
            <i class="fa-solid fa-sync"></i> Refresh
        </button>
        <button class="btn btn-secondary" onclick="exportReport()">
            <i class="fa-solid fa-download"></i> Export
        </button>
        <div class="date-filter">
            <select id="periodFilter" class="form-select" onchange="filterByPeriod()">
                <option value="today">Today</option>
                <option value="week" selected>This Week</option>
                <option value="month">This Month</option>
                <option value="quarter">This Quarter</option>
                <option value="year">This Year</option>
            </select>
        </div>
    </div>
</div>

<!-- ─── EXECUTIVE ALERTS ───────────────────────────────────────────────── -->
@if (Model.ExecutiveAlerts.Any())
{
    <div class="executive-alerts">
        @foreach (var alert in Model.ExecutiveAlerts.Take(3))
        {
            <div class="alert alert-@(alert.Type.ToLower()) alert-dismissible fade show executive-alert" role="alert">
                <div class="alert-content">
                    <div class="alert-header">
                        <strong>@alert.Title</strong>
                        <span class="alert-category">@alert.Category</span>
                        <span class="alert-time">@alert.CreatedAt.ToString("HH:mm")</span>
                    </div>
                    <div class="alert-body">
                        <p>@alert.Description</p>
                        @if (!string.IsNullOrEmpty(alert.ActionRequired))
                        {
                            <div class="alert-action">
                                <strong>Action Required:</strong> @alert.ActionRequired
                            </div>
                        }
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>
}

<!-- ─── STRATEGIC KPIS GRID ─────────────────────────────────────────────── -->
<div class="strategic-kpis-grid">
    <div class="kpi-card financial">
        <div class="kpi-header">
            <div class="kpi-icon">
                <i class="fa-solid fa-chart-line"></i>
            </div>
            <div class="kpi-title">Revenue Growth</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">@Model.FinancialKpis.RevenueGrowthRate.ToString("F1")%</div>
            <div class="kpi-trend @(Model.FinancialKpis.RevenueGrowthRate > 0 ? "positive" : "negative")">
                <i class="fa-solid fa-arrow-@(Model.FinancialKpis.RevenueGrowthRate > 0 ? "up" : "down")"></i>
                vs last period
            </div>
            <div class="kpi-chart">
                <canvas id="revenueTrendChart" height="60"></canvas>
            </div>
        </div>
    </div>

    <div class="kpi-card market">
        <div class="kpi-header">
            <div class="kpi-icon">
                <i class="fa-solid fa-globe"></i>
            </div>
            <div class="kpi-title">Market Share</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">@Model.MarketMetrics.MarketShare.ToString("F1")%</div>
            <div class="kpi-trend positive">
                <i class="fa-solid fa-arrow-up"></i>
                @Model.MarketMetrics.MarketGrowthRate.ToString("F1")% growth
            </div>
            <div class="kpi-details">
                <small>Total Market: @Model.MarketMetrics.TotalAddressableMarket.ToString("N0") VND</small>
            </div>
        </div>
    </div>

    <div class="kpi-card operational">
        <div class="kpi-header">
            <div class="kpi-icon">
                <i class="fa-solid fa-cogs"></i>
            </div>
            <div class="kpi-title">Operational Efficiency</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">@Model.OperationalMetrics.SupplyChainEfficiency.ToString("F1")%</div>
            <div class="kpi-trend positive">
                <i class="fa-solid fa-arrow-up"></i>
                Above target
            </div>
            <div class="kpi-details">
                <small>Inventory Turnover: @Model.OperationalMetrics.InventoryTurnover.ToString("F1")x</small>
            </div>
        </div>
    </div>

    <div class="kpi-card customer">
        <div class="kpi-header">
            <div class="kpi-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <div class="kpi-title">Customer Satisfaction</div>
        </div>
        <div class="kpi-content">
            <div class="kpi-value">@Model.MarketMetrics.CustomerSatisfaction.ToString("F1")/5.0</div>
            <div class="kpi-trend positive">
                <i class="fa-solid fa-arrow-up"></i>
                NPS: @Model.MarketMetrics.NetPromoterScore.ToString("F0")
            </div>
            <div class="kpi-details">
                <small>Brand Awareness: @Model.MarketMetrics.BrandAwareness.ToString("F1")%</small>
            </div>
        </div>
    </div>
</div>

<!-- ─── MAIN DASHBOARD CONTENT ───────────────────────────────────────────── -->
<div class="dashboard-main-content">
    <div class="dashboard-row">
        <!-- Revenue & Profit Analysis -->
        <div class="dashboard-col-8">
            <div class="executive-card">
                <div class="card-header">
                    <h3><i class="fa-solid fa-chart-area"></i> Revenue & Profit Analysis</h3>
                    <div class="card-actions">
                        <button class="btn btn-sm btn-outline-primary" onclick="drillDown('revenue')">
                            <i class="fa-solid fa-search-plus"></i> Drill Down
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="revenueProfitChart"></canvas>
                    </div>
                    <div class="chart-legend">
                        <div class="legend-item">
                            <span class="legend-color" style="background: #4CAF50;"></span>
                            Revenue
                        </div>
                        <div class="legend-item">
                            <span class="legend-color" style="background: #2196F3;"></span>
                            Gross Profit
                        </div>
                        <div class="legend-item">
                            <span class="legend-color" style="background: #FF9800;"></span>
                            Net Profit
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Predictive Insights -->
        <div class="dashboard-col-4">
            <div class="executive-card">
                <div class="card-header">
                    <h3><i class="fa-solid fa-brain"></i> AI Predictions</h3>
                </div>
                <div class="card-body">
                    <div class="prediction-list">
                        @foreach (var alert in Model.PredictiveInsights.PredictiveAlerts.Take(3))
                        {
                            <div class="prediction-item @(alert.Type.ToLower())">
                                <div class="prediction-icon">
                                    <i class="fa-solid fa-@(alert.Type == "Critical" ? "exclamation-triangle" : "info-circle")"></i>
                                </div>
                                <div class="prediction-content">
                                    <div class="prediction-title">@alert.Title</div>
                                    <div class="prediction-desc">@alert.Description</div>
                                    <div class="prediction-confidence">
                                        Confidence: @(alert.Confidence * 100)% | 
                                        <a href="#" onclick="takeAction('@alert.RecommendedAction')">Action</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="dashboard-row">
        <!-- Market Intelligence -->
        <div class="dashboard-col-6">
            <div class="executive-card">
                <div class="card-header">
                    <h3><i class="fa-solid fa-chart-pie"></i> Market Intelligence</h3>
                </div>
                <div class="card-body">
                    <div class="market-grid">
                        <div class="market-item">
                            <div class="market-label">Competitor Analysis</div>
                            <div class="market-chart">
                                <canvas id="competitorChart"></canvas>
                            </div>
                        </div>
                        <div class="market-item">
                            <div class="market-label">Geographic Distribution</div>
                            <div class="market-chart">
                                <canvas id="geographicChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="market-insights">
                        <h4>Key Insights</h4>
                        <ul>
                            <li>Market leader: Zara with 15.2% share</li>
                            <li>HCMC showing 15.8% growth rate</li>
                            <li>Sustainable fashion trending +25.8%</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Operational Metrics -->
        <div class="dashboard-col-6">
            <div class="executive-card">
                <div class="card-header">
                    <h3><i class="fa-solid fa-tachometer-alt"></i> Operational Excellence</h3>
                </div>
                <div class="card-body">
                    <div class="operational-metrics">
                        @foreach (var dept in Model.OperationalMetrics.DepartmentMetrics.Take(4))
                        {
                            <div class="dept-metric">
                                <div class="dept-header">
                                    <span class="dept-name">@dept.Department</span>
                                    <span class="dept-score">@dept.PerformanceScore.ToString("F1")</span>
                                </div>
                                <div class="dept-progress">
                                    <div class="progress">
                                        <div class="progress-bar" style="width: @dept.PerformanceScore%"></div>
                                    </div>
                                </div>
                                <div class="dept-details">
                                    <small>Efficiency: @dept.Efficiency.ToString("F1")% | 
                                           Budget: @dept.BudgetUtilization.ToString("F1")%</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="dashboard-row">
        <!-- Strategic Initiatives -->
        <div class="dashboard-col-12">
            <div class="executive-card">
                <div class="card-header">
                    <h3><i class="fa-solid fa-rocket"></i> Strategic Initiatives Tracking</h3>
                    <div class="card-actions">
                        <button class="btn btn-sm btn-primary" onclick="addInitiative()">
                            <i class="fa-solid fa-plus"></i> Add Initiative
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="initiatives-grid">
                        <div class="initiative-item">
                            <div class="initiative-header">
                                <h4>Digital Transformation</h4>
                                <span class="initiative-status in-progress">In Progress</span>
                            </div>
                            <div class="initiative-progress">
                                <div class="progress">
                                    <div class="progress-bar bg-info" style="width: 65%"></div>
                                </div>
                                <span class="progress-text">65% Complete</span>
                            </div>
                            <div class="initiative-details">
                                <small>Target: Q2 2026 | Budget: 500M VND</small>
                            </div>
                        </div>
                        <div class="initiative-item">
                            <div class="initiative-header">
                                <h4>Market Expansion - HCMC</h4>
                                <span class="initiative-status planning">Planning</span>
                            </div>
                            <div class="initiative-progress">
                                <div class="progress">
                                    <div class="progress-bar bg-warning" style="width: 25%"></div>
                                </div>
                                <span class="progress-text">25% Complete</span>
                            </div>
                            <div class="initiative-details">
                                <small>Target: Q3 2026 | Budget: 1B VND</small>
                            </div>
                        </div>
                        <div class="initiative-item">
                            <div class="initiative-header">
                                <h4>Sustainability Program</h4>
                                <span class="initiative-status completed">Completed</span>
                            </div>
                            <div class="initiative-progress">
                                <div class="progress">
                                    <div class="progress-bar bg-success" style="width: 100%"></div>
                                </div>
                                <span class="progress-text">100% Complete</span>
                            </div>
                            <div class="initiative-details">
                                <small>Completed: Q1 2026 | Actual: 450M VND</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ─── REAL-TIME DATA PANEL ───────────────────────────────────────────── -->
<div class="real-time-panel">
    <div class="panel-header">
        <h4><i class="fa-solid fa-satellite-dish"></i> Real-time Market Data</h4>
        <span class="last-updated" id="lastUpdated">Updated: @DateTime.Now.ToString("HH:mm:ss")</span>
    </div>
    <div class="panel-content">
        <div class="real-time-item">
            <span class="label">Market Index:</span>
            <span class="value" id="marketIndex">1,250.5</span>
            <span class="change positive">+0.8%</span>
        </div>
        <div class="real-time-item">
            <span class="label">Consumer Sentiment:</span>
            <span class="value" id="consumerSentiment">72.3</span>
            <span class="change positive">+2.1</span>
        </div>
        <div class="real-time-item">
            <span class="label">USD/VND:</span>
            <span class="value" id="exchangeRate">23,500</span>
            <span class="change negative">+200</span>
        </div>
    </div>
</div>

<!-- ─── JAVASCRIPT FOR INTERACTIVE FEATURES ───────────────────────────────── -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Initialize dashboard
        document.addEventListener('DOMContentLoaded', function() {
            initializeCharts();
            startRealTimeUpdates();
            setupInteractions();
        });

        // Chart configurations
        function initializeCharts() {
            // Revenue Trend Chart
            const revenueTrendCtx = document.getElementById('revenueTrendChart').getContext('2d');
            new Chart(revenueTrendCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        data: [120, 135, 125, 145, 160, 155],
                        borderColor: '#4CAF50',
                        backgroundColor: 'rgba(76, 175, 80, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { display: false },
                        y: { display: false }
                    }
                }
            });

            // Revenue & Profit Chart
            const revenueProfitCtx = document.getElementById('revenueProfitChart').getContext('2d');
            new Chart(revenueProfitCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [
                        {
                            label: 'Revenue',
                            data: [1200, 1350, 1250, 1450, 1600, 1550],
                            borderColor: '#4CAF50',
                            backgroundColor: 'rgba(76, 175, 80, 0.1)',
                            tension: 0.4
                        },
                        {
                            label: 'Gross Profit',
                            data: [480, 540, 500, 580, 640, 620],
                            borderColor: '#2196F3',
                            backgroundColor: 'rgba(33, 150, 243, 0.1)',
                            tension: 0.4
                        },
                        {
                            label: 'Net Profit',
                            data: [240, 270, 250, 290, 320, 310],
                            borderColor: '#FF9800',
                            backgroundColor: 'rgba(255, 152, 0, 0.1)',
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    }
                }
            });

            // Competitor Chart
            const competitorCtx = document.getElementById('competitorChart').getContext('2d');
            new Chart(competitorCtx, {
                type: 'doughnut',
                data: {
                    labels: ['BN Store', 'Zara', 'H&M', 'Uniqlo', 'Others'],
                    datasets: [{
                        data: [18.2, 15.2, 12.8, 8.7, 45.1],
                        backgroundColor: [
                            '#4CAF50',
                            '#2196F3',
                            '#FF9800',
                            '#9C27B0',
                            '#607D8B'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

            // Geographic Chart
            const geographicCtx = document.getElementById('geographicChart').getContext('2d');
            new Chart(geographicCtx, {
                type: 'bar',
                data: {
                    labels: ['Hanoi', 'HCMC', 'Da Nang', 'Others'],
                    datasets: [{
                        label: 'Revenue',
                        data: [40, 35, 15, 10],
                        backgroundColor: '#4CAF50'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        // Real-time updates
        function startRealTimeUpdates() {
            setInterval(updateRealTimeData, 30000); // Update every 30 seconds
        }

        function updateRealTimeData() {
            // Simulate real-time data updates
            fetch('/Executive/GetRealTimeKpis')
                .then(response => response.json())
                .then(data => {
                    updateKpiValues(data);
                    document.getElementById('lastUpdated').textContent = 'Updated: ' + new Date().toLocaleTimeString();
                })
                .catch(error => console.error('Error updating real-time data:', error));
        }

        function updateKpiValues(data) {
            // Update KPI values with animation
            updateValueWithAnimation('marketIndex', data.marketIndex);
            updateValueWithAnimation('consumerSentiment', data.consumerSentiment);
            updateValueWithAnimation('exchangeRate', data.exchangeRate);
        }

        function updateValueWithAnimation(elementId, newValue) {
            const element = document.getElementById(elementId);
            const currentValue = parseFloat(element.textContent.replace(/,/g, ''));
            const difference = newValue - currentValue;
            const steps = 20;
            const stepValue = difference / steps;
            let currentStep = 0;

            const animation = setInterval(() => {
                currentStep++;
                if (currentStep >= steps) {
                    element.textContent = newValue.toLocaleString();
                    clearInterval(animation);
                } else {
                    element.textContent = (currentValue + stepValue * currentStep).toLocaleString();
                }
            }, 50);
        }

        // Interactive functions
        function refreshDashboard() {
            location.reload();
        }

        function exportReport() {
            window.open('/Executive/GenerateReport?reportType=dashboard&period=current', '_blank');
        }

        function filterByPeriod() {
            const period = document.getElementById('periodFilter').value;
            fetch(`/Executive/Index?period=${period}`)
                .then(response => response.text())
                .then(html => {
                    document.documentElement.innerHTML = html;
                    initializeCharts();
                });
        }

        function drillDown(type) {
            // Navigate to detailed analysis page
            window.location.href = `/Executive/${type === 'revenue' ? 'FinancialAnalysis' : 'MarketIntelligence'}`;
        }

        function takeAction(action) {
            alert('Recommended Action: ' + action);
        }

        function addInitiative() {
            window.location.href = '/Executive/StrategicPlanning';
        }

        // Setup interactions
        function setupInteractions() {
            // Add hover effects to KPI cards
            document.querySelectorAll('.kpi-card').forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.classList.add('hover');
                });
                card.addEventListener('mouseleave', function() {
                    this.classList.remove('hover');
                });
            });

            // Setup alert dismiss functionality
            document.querySelectorAll('.executive-alert .btn-close').forEach(button => {
                button.addEventListener('click', function() {
                    const alert = this.closest('.executive-alert');
                    alert.style.opacity = '0';
                    setTimeout(() => alert.remove(), 300);
                });
            });
        }
    </script>
}

<!-- ─── EXECUTIVE DASHBOARD STYLES ───────────────────────────────────────── -->
<style>
    .executive-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        color: white;
    }

    .executive-title h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 600;
    }

    .executive-subtitle {
        margin: 0.5rem 0 0 0;
        opacity: 0.9;
        font-size: 0.9rem;
    }

    .executive-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .executive-alerts {
        margin-bottom: 2rem;
    }

    .executive-alert {
        border-left: 4px solid;
        margin-bottom: 1rem;
    }

    .executive-alert.critical {
        border-left-color: #dc3545;
    }

    .executive-alert.warning {
        border-left-color: #ffc107;
    }

    .executive-alert.opportunity {
        border-left-color: #28a745;
    }

    .alert-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .alert-category {
        background: rgba(0,0,0,0.1);
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.8rem;
    }

    .strategic-kpis-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .kpi-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

    .kpi-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .kpi-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .kpi-card.financial .kpi-icon { background: #4CAF50; }
    .kpi-card.market .kpi-icon { background: #2196F3; }
    .kpi-card.operational .kpi-icon { background: #FF9800; }
    .kpi-card.customer .kpi-icon { background: #9C27B0; }

    .kpi-title {
        font-size: 0.9rem;
        color: #666;
        font-weight: 500;
    }

    .kpi-value {
        font-size: 2rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 0.5rem;
    }

    .kpi-trend {
        font-size: 0.85rem;
        font-weight: 500;
        margin-bottom: 1rem;
    }

    .kpi-trend.positive {
        color: #4CAF50;
    }

    .kpi-trend.negative {
        color: #f44336;
    }

    .dashboard-main-content {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .dashboard-row {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 2rem;
    }

    .dashboard-col-4 { grid-column: span 4; }
    .dashboard-col-6 { grid-column: span 6; }
    .dashboard-col-8 { grid-column: span 8; }
    .dashboard-col-12 { grid-column: span 12; }

    .executive-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .card-header {
        padding: 1.5rem;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-header h3 {
        margin: 0;
        font-size: 1.1rem;
        color: #333;
    }

    .card-body {
        padding: 1.5rem;
    }

    .chart-container {
        position: relative;
        height: 300px;
        margin-bottom: 1rem;
    }

    .prediction-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .prediction-item {
