@model FashionStoreIS.Models.KpiReview

@{
    ViewData["Title"] = "Đánh giá KPI";
}

<div style="margin-bottom: 24px;">
    <a asp-action="Index" class="btn-admin btn-secondary">
        <i class="fa-solid fa-arrow-left"></i> QUAY LẠI
    </a>
</div>

<div class="admin-card" style="max-width: 800px; margin: 0 auto;">
    <div class="admin-card-header">
        <div class="admin-card-title">BIỂU MẪU ĐÁNH GIÁ NĂNG LỰC NHÂN VIÊN (KPI)</div>
    </div>
    <div style="padding: 30px;">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>
            
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="EmployeeId" class="form-label">Chọn nhân viên</label>
                    <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId"></select>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label asp-for="Month" class="form-label">Tháng</label>
                        <select asp-for="Month" class="form-control">
                            @for(int i=1; i<=12; i++) {
                                <option value="@i" selected="@(i == DateTime.Now.Month)">T@i</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="Year" class="form-label">Năm</label>
                        <select asp-for="Year" class="form-control">
                            <option value="@DateTime.Now.Year">@DateTime.Now.Year</option>
                        </select>
                    </div>
                </div>
            </div>

            <div style="margin: 20px 0; padding: 20px; background: rgba(139, 92, 246, 0.05); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 8px;">
                <div style="font-size: 11px; font-weight: 700; color: var(--admin-accent); margin-bottom: 20px; text-transform: uppercase;">Tiêu chí đánh giá (Thang điểm 0 - 100)</div>
                
                <div class="form-grid-3">
                    <div class="form-group">
                        <label asp-for="SalesScore" class="form-label">Doanh số (50%)</label>
                        <input asp-for="SalesScore" class="form-control" type="number" min="0" max="100" />
                        <span asp-validation-for="SalesScore" style="color: var(--admin-red); font-size: 11px;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="AttitudeScore" class="form-label">Thái độ (25%)</label>
                        <input asp-for="AttitudeScore" class="form-control" type="number" min="0" max="100" />
                        <span asp-validation-for="AttitudeScore" style="color: var(--admin-red); font-size: 11px;"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="TeamworkScore" class="form-label">Teamwork (25%)</label>
                        <input asp-for="TeamworkScore" class="form-control" type="number" min="0" max="100" />
                        <span asp-validation-for="TeamworkScore" style="color: var(--admin-red); font-size: 11px;"></span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">Nhận xét chi tiết</label>
                <textarea asp-for="Notes" class="form-control" placeholder="Nhận xét ưu điểm, khuyết điểm và nhắc nhở..."></textarea>
            </div>

            <div style="margin-top: 30px;">
                <button type="submit" class="btn-admin btn-primary" style="width: 100%; height: 50px; font-size: 14px;">HOÀN TẤT ĐÁNH GIÁ & TÍNH ĐIỂM</button>
            </div>
        </form>
    </div>
</div>
