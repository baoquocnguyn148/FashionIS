@model Category
@{
    bool isEdit = Model?.Id > 0;
    ViewData["Title"] = isEdit ? "Sửa Danh mục" : "Thêm Danh mục";
}

<div style="max-width: 1000px; margin: 0 auto;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px;">
        <a href="/Admin/Categories" class="btn-admin btn-secondary" style="border-radius: 12px; padding: 10px 20px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><polyline points="15 18 9 12 15 6"/></svg>
            Quay lại danh sách
        </a>
        <h2 style="font-size: 24px; font-weight: 800; color: #fff;">@(isEdit ? "Chỉnh sửa danh mục" : "Tạo danh mục mới")</h2>
    </div>

    <form method="post" action="/Admin/Categories/Create">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@Model!.Id" /> }
        
        <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 32px;">
            <!-- Left Column: Basic Info -->
            <div class="admin-card" style="padding: 32px; border-radius: 20px; border: 1px solid var(--admin-border); background: var(--admin-card);">
                <div class="form-group">
                    <label class="form-label">Tên danh mục <span style="color: var(--admin-red);">*</span></label>
                    <input name="Name" id="CategoryName" class="form-control" value="@Model?.Name" required placeholder="VD: Áo Thun Polo" style="padding: 14px; border-radius: 12px;" />
                </div>

                <div class="form-group">
                    <label class="form-label">Slug (Đường dẫn tĩnh)</label>
                    <input name="Slug" id="CategorySlug" class="form-control" value="@Model?.Slug" placeholder="ao-thun-polo" style="padding: 14px; border-radius: 12px; font-family: monospace;" />
                    <small style="color: var(--admin-muted); font-size: 11px; margin-top: 4px; display: block;">Tự động sinh nếu để trống. Dùng cho URL SEO.</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Mô tả danh mục</label>
                    <textarea name="Description" class="form-control" rows="4" placeholder="Mô tả ngắn gọn về danh mục này..." style="padding: 14px; border-radius: 12px; resize: none;">@Model?.Description</textarea>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Danh mục cha</label>
                        <select name="ParentCategoryId" class="form-control" style="padding: 14px; border-radius: 12px;">
                            <option value="">-- Danh mục gốc --</option>
                            @foreach (var p in (List<Category>)ViewBag.Parents)
                            {
                                if (p.Id != Model?.Id)
                                {
                                    @Html.Raw($"<option value='{p.Id}'{(Model?.ParentCategoryId == p.Id ? " selected" : "")}>{p.Name}</option>")
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input name="DisplayOrder" type="number" class="form-control" value="@(Model?.DisplayOrder ?? 0)" style="padding: 14px; border-radius: 12px;" />
                    </div>
                </div>
            </div>

            <!-- Right Column: Media & Actions -->
            <div style="display: flex; flex-direction: column; gap: 32px;">
                <div class="admin-card" style="padding: 32px; border-radius: 20px; border: 1px solid var(--admin-border); background: var(--admin-card);">
                    <div class="form-group">
                        <label class="form-label">Ảnh đại diện (URL)</label>
                        <input name="ImageUrl" id="CategoryImageUrl" class="form-control" value="@Model?.ImageUrl" placeholder="https://..." style="padding: 14px; border-radius: 12px;" oninput="updatePreview(this.value)" />
                    </div>
                    
                    <div id="ImagePreviewContainer" style="width: 100%; aspect-ratio: 16/9; background: var(--admin-border); border-radius: 16px; margin-top: 16px; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 2px dashed rgba(255,255,255,0.05);">
                        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <div style="text-align: center; color: var(--admin-muted);">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 8px;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                <div style="font-size: 12px;">Xem trước ảnh</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="admin-card" style="padding: 32px; border-radius: 20px; border: 1px solid var(--admin-border); background: var(--admin-card);">
                    <div class="form-group">
                        <label class="form-check" style="cursor: pointer; padding: 12px; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid var(--admin-border);">
                            <input type="checkbox" name="IsActive" value="true" @(Model?.IsActive != false ? "checked" : "") style="width: 20px; height: 20px; accent-color: var(--admin-accent);" />
                            <span style="font-size: 14px; font-weight: 600; color: #fff; margin-left: 12px;">Kích hoạt danh mục</span>
                        </label>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 24px;">
                        <button type="submit" class="btn-admin btn-primary" style="padding: 16px; border-radius: 12px; background: var(--admin-accent); color: #fff; font-weight: 800; font-size: 14px; box-shadow: 0 4px 20px rgba(139, 92, 246, 0.4);">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/></svg>
                            @(isEdit ? "LƯU THAY ĐỔI" : "XÁC NHẬN TẠO")
                        </button>
                        <a href="/Admin/Categories" class="btn-admin btn-secondary" style="padding: 16px; border-radius: 12px; text-align: center; justify-content: center; font-weight: 600;">HỦY BỎ</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    function updatePreview(url) {
        const container = document.getElementById('ImagePreviewContainer');
        if (url) {
            container.innerHTML = `<img src="${url}" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.innerHTML='Lỗi tải ảnh'"/>`;
        } else {
            container.innerHTML = `<div style="text-align: center; color: var(--admin-muted);"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 8px;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><div style="font-size: 12px;">Xem trước ảnh</div></div>`;
        }
    }

    // Auto-slug generation
    const nameInput = document.getElementById('CategoryName');
    const slugInput = document.getElementById('CategorySlug');

    nameInput.addEventListener('input', function() {
        if (!slugInput.value || slugInput.getAttribute('data-sync') === 'true' || @((!isEdit).ToString().ToLower())) {
            const slug = nameInput.value
                .trim()
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/đ/g, 'd')
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
            slugInput.value = slug;
            slugInput.setAttribute('data-sync', 'true');
        }
    });

    slugInput.addEventListener('input', function() {
        slugInput.setAttribute('data-sync', 'false');
    });
</script>
