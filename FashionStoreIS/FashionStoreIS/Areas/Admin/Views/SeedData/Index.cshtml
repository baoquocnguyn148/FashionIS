@{
    ViewData["Title"] = "Tạo dữ liệu mẫu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-card">
    <div class="admin-card-header">
        <div class="admin-card-title">Tạo dữ liệu mẫu cho Dashboard</div>
    </div>
    <div style="padding: 24px;">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">@TempData["Error"]</div>
        }

        <div style="margin-bottom: 20px;">
            <h3 style="margin-bottom: 12px; font-size: 16px;">Mục đích:</h3>
            <p style="color: #888; line-height: 1.6;">
                Tạo dữ liệu mẫu để hiển thị Dashboard với các biểu đồ và thống kê.
                Dữ liệu bao gồm 20 đơn hàng ngẫu nhiên với các trạng thái khác nhau,
                phân bổ trong 90 ngày gần nhất.
            </p>
        </div>

        <div style="background: var(--admin-sidebar); padding: 16px; border-radius: 4px; margin-bottom: 20px;">
            <h4 style="font-size: 14px; margin-bottom: 12px;">Dữ liệu sẽ được tạo:</h4>
            <ul style="color: #ccc; margin: 0; padding-left: 20px;">
                <li>20 đơn hàng với trạng thái ngẫu nhiên</li>
                <li>Khách hàng giả định với tên và SĐT</li>
                <li>Sản phẩm ngẫu nhiên từ database hiện có</li>
                <li>Ngày tạo trong 90 ngày gần nhất</li>
                <li>Số lượng sản phẩm 1-3 items mỗi đơn hàng</li>
            </ul>
        </div>

        <form method="post" action="/Admin/SeedData/SeedSampleData" style="display: inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-admin btn-primary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2v20M2 12h20"/>
                </svg>
                Tạo dữ liệu mẫu
            </button>
        </form>

        <div style="margin-top: 20px;">
            <a href="/Admin/Dashboard" class="btn-admin btn-secondary">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Về Dashboard
            </a>
        </div>
    </div>
</div>

<style>
.alert {
    padding: 12px 16px;
    border-radius: 2px;
    font-size: 13px;
    margin-bottom: 20px;
}

.alert-success {
    background: rgba(34,197,94,0.1);
    border: 1px solid rgba(34,197,94,0.3);
    color: var(--admin-green);
}

.alert-error {
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.3);
    color: var(--admin-red);
}
</style>
