@model IEnumerable<FashionStoreIS.Models.Department>

@{
    ViewData["Title"] = "Quản lý Phòng ban";
}

<div class="admin-card">
    <div class="admin-card-header">
        <div class="admin-card-title">DANH SÁCH PHÒNG BAN</div>
        <a asp-action="Create" class="btn-admin btn-primary">
            <i class="fa-solid fa-plus"></i> Thêm mới
        </a>
    </div>
    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Tên phòng ban</th>
                    <th>Mô tả</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight: 600;">@item.Name</td>
                        <td style="color: var(--admin-muted);">@item.Description</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge badge-green">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge badge-red">Ngừng</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-admin btn-secondary btn-sm" title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-admin btn-danger btn-sm" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 40px; color: var(--admin-muted);">
                            Chưa có dữ liệu phòng ban nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
