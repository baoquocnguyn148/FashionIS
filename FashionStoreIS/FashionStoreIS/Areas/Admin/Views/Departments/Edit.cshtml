@model FashionStoreIS.Models.Department

@{
    ViewData["Title"] = "Chỉnh sửa Phòng ban";
}

<div class="admin-card" style="max-width: 600px;">
    <div class="admin-card-header">
        <div class="admin-card-title">CẬP NHẬT PHÒNG BAN: @Model.Name</div>
    </div>
    <div class="admin-content" style="padding: 24px;">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            
            <div class="form-group">
                <label asp-for="Name" class="form-label">Tên phòng ban</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" style="color: var(--admin-red); font-size: 11px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" style="color: var(--admin-red); font-size: 11px;"></span>
            </div>

            <div class="form-group">
                <label class="form-check">
                    <input asp-for="IsActive" type="checkbox" />
                    <span class="form-label" style="margin: 0;">Đang hoạt động</span>
                </label>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 30px;">
                <button type="submit" class="btn-admin btn-primary">
                    <i class="fa-solid fa-save"></i> Cập nhật
                </button>
                <a asp-action="Index" class="btn-admin btn-secondary">
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
