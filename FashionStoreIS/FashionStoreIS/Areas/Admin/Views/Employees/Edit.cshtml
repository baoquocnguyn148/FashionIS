@model FashionStoreIS.Models.Employee

@{
    ViewData["Title"] = "Chỉnh sửa Nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-content-inner">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="stat-label">Hệ thống Quản trị Nhân sự</div>
            <h1 class="topbar-title" style="font-size: 28px;">Chỉnh sửa Nhân viên</h1>
        </div>
        <a asp-action="Index" class="btn-admin btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="admin-card" style="border-top: 4px solid #f59e0b;">
                <div class="admin-card-header">
                    <div class="admin-card-title">CẬP NHẬT HỒ SƠ: @Model.FullName.ToUpper()</div>
                    <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">Staff ID: #@Model.Id</span>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-error mb-4"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />

                        <!-- Section: Personal Info -->
                        <div class="mb-5">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <div style="width: 32px; height: 32px; background: rgba(99, 102, 241, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #6366f1;">
                                    <i class="fa-solid fa-user"></i>
                                </div>
                                <h3 style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; margin: 0;">Thông tin cá nhân</h3>
                            </div>

                            <div class="form-grid">
                                <div class="form-group">
                                    <label asp-for="FullName" class="form-label">Họ và Tên <span class="text-danger">*</span></label>
                                    <input asp-for="FullName" class="form-control" required />
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="UserId" class="form-label">Tài khoản Hệ thống</label>
                                    <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId">
                                        <option value="">-- Không liên kết --</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Email" class="form-label">Email Liên hệ <span class="text-danger">*</span></label>
                                    <input asp-for="Email" class="form-control" required />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Phone" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                    <input asp-for="Phone" class="form-control" required />
                                    <span asp-validation-for="Phone" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Section: Job Details -->
                        <div class="mb-5">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <div style="width: 32px; height: 32px; background: rgba(16, 185, 129, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #10b981;">
                                    <i class="fa-solid fa-briefcase"></i>
                                </div>
                                <h3 style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; margin: 0;">Vị trí & Công việc</h3>
                            </div>

                            <div class="form-grid-3">
                                <div class="form-group">
                                    <label asp-for="Position" class="form-label">Chức vụ <span class="text-danger">*</span></label>
                                    <input asp-for="Position" class="form-control" required />
                                    <span asp-validation-for="Position" class="text-danger small"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="DepartmentId" class="form-label">Phòng ban <span class="text-danger">*</span></label>
                                    <select asp-for="DepartmentId" class="form-control" asp-items="ViewBag.DepartmentId" required></select>
                                </div>
                                <div class="form-group">
                                    <label asp-for="StoreId" class="form-label">Chi nhánh <span class="text-danger">*</span></label>
                                    <select asp-for="StoreId" class="form-control" asp-items="ViewBag.StoreId" required></select>
                                </div>
                            </div>

                            <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                                <div class="form-group">
                                    <label asp-for="HireDate" class="form-label">Ngày vào làm <span class="text-danger">*</span></label>
                                    <input asp-for="HireDate" type="date" class="form-control" required />
                                    <span asp-validation-for="HireDate" class="text-danger small"></span>
                                </div>
                                <div class="form-group d-flex align-items-center" style="padding-top: 25px;">
                                    <div class="form-check">
                                        <input type="checkbox" asp-for="IsActive" id="IsActiveCheck" />
                                        <label for="IsActiveCheck" style="font-size: 13px; font-weight: 500; color: #fff;">Đang làm việc</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Section: Finance -->
                        <div class="mb-4">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <div style="width: 32px; height: 32px; background: rgba(245, 158, 11, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #f59e0b;">
                                    <i class="fa-solid fa-money-bill-wave"></i>
                                </div>
                                <h3 style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; margin: 0;">Lương & Tài khoản Ngân hàng</h3>
                            </div>

                            <div class="form-grid">
                                <div class="form-group">
                                    <label asp-for="BaseSalaryPerHour" class="form-label">Lương mỗi giờ (VND) <span class="text-danger">*</span></label>
                                    <input asp-for="BaseSalaryPerHour" type="number" class="form-control" required />
                                    <span asp-validation-for="BaseSalaryPerHour" class="text-danger small"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="BankName" class="form-label">Ngân hàng</label>
                                    <input asp-for="BankName" class="form-control" />
                                </div>
                                <div class="form-group">
                                    <label asp-for="BankAccountNumber" class="form-label">Số tài khoản</label>
                                    <input asp-for="BankAccountNumber" class="form-control" />
                                </div>
                                <div class="form-group">
                                    <label asp-for="BankAccountName" class="form-label">Tên chủ tài khoản</label>
                                    <input asp-for="BankAccountName" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-4 pt-4 border-top border-secondary">
                            <button type="button" class="btn-admin btn-secondary" onclick="window.history.back()" style="background: transparent; border: 1px solid var(--admin-border);">
                                Hủy bỏ
                            </button>
                            <button type="submit" class="btn-admin btn-primary" style="padding: 12px 32px; font-size: 14px; background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%); color: #fff; box-shadow: 0 8px 16px rgba(245, 158, 11, 0.2);">
                                <i class="fa-solid fa-save"></i> CẬP NHẬT THÔNG TIN
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-content-inner { max-width: 1200px; margin: 0 auto; }
    .form-group { margin-bottom: 24px; }
    .form-label { margin-bottom: 10px; opacity: 0.8; }
    .form-control { 
        background: rgba(30, 41, 59, 0.5); 
        border: 1px solid rgba(255, 255, 255, 0.05); 
        padding: 12px 16px; 
        border-radius: 8px;
    }
    .form-control:focus { 
        background: rgba(30, 41, 59, 0.8);
        border-color: #f59e0b;
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
    }
    .form-check input { 
        cursor: pointer; 
        background-color: var(--admin-border);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .form-check input:checked { background-color: #f59e0b; border-color: #f59e0b; }
    .alert-error { border-radius: 8px; border: 1px solid rgba(239, 68, 68, 0.2); background: rgba(239, 68, 68, 0.05); color: #fca5a5; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
