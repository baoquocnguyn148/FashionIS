@model FashionStoreIS.Models.Employee

@{
    ViewData["Title"] = "Chi tiết Nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-content-inner">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="stat-label">Hồ sơ Cán bộ Nhân viên</div>
            <h1 class="topbar-title" style="font-size: 28px;">Chi tiết: @Model.FullName</h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-admin btn-primary" style="background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%); color: #fff;">
                <i class="fa-solid fa-edit"></i> Chỉnh sửa hồ sơ
            </a>
            <a asp-action="Index" class="btn-admin btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Danh sách
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="admin-card text-center p-5">
                <div class="user-avatar mx-auto mb-4" style="width: 100px; height: 100px; font-size: 36px; background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);">
                    @(Model.FullName?[0] ?? 'E')
                </div>
                <h2 style="font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 8px;">@Model.FullName</h2>
                <div class="badge badge-green mb-4">@Model.Position</div>
                
                <div class="mt-4 pt-4 border-top border-secondary text-start" style="opacity: 0.8;">
                    <div class="mb-3">
                        <div class="stat-label" style="margin-bottom: 2px;">Trạng thái</div>
                        <div class="d-flex align-items-center gap-2">
                            <div style="width: 8px; height: 8px; border-radius: 50%; background: @(Model.IsActive ? "#10b981" : "#ef4444");"></div>
                            <span style="font-size: 13px; font-weight: 600;">@(Model.IsActive ? "Đang công tác" : "Nghỉ việc / Tạm dừng")</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="stat-label" style="margin-bottom: 2px;">Ngày gia nhập</div>
                        <div style="font-size: 13px; font-weight: 600; color: #fff;">@Model.HireDate.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
            </div>

            <div class="admin-card p-4">
                <div class="admin-card-title mb-4">THÔNG TIN LIÊN HỆ</div>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-phone text-muted" style="width: 20px;"></i>
                        <span style="font-size: 14px;">@Model.Phone</span>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-envelope text-muted" style="width: 20px;"></i>
                        <span style="font-size: 14px;">@Model.Email</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.UserId))
                    {
                        <div class="d-flex align-items-center gap-3">
                            <i class="fa-solid fa-user-lock text-muted" style="width: 20px;"></i>
                            <span style="font-size: 12px; color: #6366f1;">Linked Account: @Model.UserId</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Main Details -->
        <div class="col-lg-8">
            <div class="admin-card">
                <div class="admin-card-header">
                    <div class="admin-card-title">CHI TIẾT CÔNG TÁC & TÀI CHÍNH</div>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-5">
                        <div class="col-md-6 mb-4">
                            <div class="stat-label">Phòng ban</div>
                            <div style="font-size: 16px; font-weight: 600; color: #fff;">@(Model.Department?.Name ?? "Chưa phân bổ")</div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="stat-label">Chi nhánh làm việc</div>
                            <div style="font-size: 16px; font-weight: 600; color: #fff;">@(Model.Store?.Name ?? "Hệ thống chung")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="stat-label">Lương cơ bản mỗi giờ</div>
                            <div style="font-size: 24px; font-weight: 800; color: #10b981;">@Model.BaseSalaryPerHour.ToString("N0") <span style="font-size: 14px; font-weight: 500; opacity: 0.6;">VND/h</span></div>
                        </div>
                    </div>

                    <div class="pt-4 border-top border-secondary">
                        <div class="admin-card-title mb-4" style="font-size: 11px;">THÔNG TIN NGÂN HÀNG</div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="stat-label">Tên Ngân hàng</div>
                                <div style="font-size: 14px; font-weight: 600;">@(Model.BankName ?? "Chưa cập nhật")</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="stat-label">Số tài khoản</div>
                                <div style="font-size: 14px; font-weight: 600; letter-spacing: 0.05em;">@(Model.BankAccountNumber ?? "Chưa cập nhật")</div>
                            </div>
                            <div class="col-md-12">
                                <div class="stat-label">Tên chủ tài khoản</div>
                                <div style="font-size: 14px; font-weight: 700; text-transform: uppercase;">@(Model.BankAccountName ?? "Chưa cập nhật")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity Placeholder -->
            <div class="admin-card">
                <div class="admin-card-header">
                    <div class="admin-card-title">HIỆU SUẤT TRONG THÁNG</div>
                    <span class="stat-sub">Dữ liệu tính đến hôm nay</span>
                </div>
                <div class="card-body p-5 text-center" style="opacity: 0.5;">
                    <i class="fa-solid fa-chart-line fa-3x mb-3"></i>
                    <p>Chưa có dữ liệu chấm công và doanh số cho tháng này.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-content-inner { max-width: 1240px; margin: 0 auto; }
</style>
