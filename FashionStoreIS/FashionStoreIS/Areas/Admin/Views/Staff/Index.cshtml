@model List<ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Quản lý Nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
    <div>
        <h2 style="font-size: 24px; font-weight: 800; color: #fff; margin-bottom: 4px;">Đội ngũ Nhân sự</h2>
        <p style="font-size: 14px; color: var(--admin-muted);">Quản lý tài khoản quản trị và nhân viên vận hành.</p>
    </div>
    <button class="btn-admin btn-primary">Thêm nhân viên mới</button>
</div>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Họ tên</th>
                <th>Email / Username</th>
                <th>Vai trò</th>
                <th style="text-align: right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                var roles = await UserManager.GetRolesAsync(u);
                <tr>
                    <td>
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(139, 92, 246, 0.1); color: var(--admin-accent); display: flex; align-items: center; justify-content: center; font-weight: 700;">
                                @(u.FullName?[0] ?? 'S')
                            </div>
                            <span style="font-weight: 600; color: #fff;">@u.FullName</span>
                        </div>
                    </td>
                    <td>@u.Email</td>
                    <td>
                        @foreach (var role in roles)
                        {
                            <span class="badge @(role == "SuperAdmin" ? "badge-red" : "badge-green")" style="margin-right: 4px;">
                                @role
                            </span>
                        }
                    </td>
                    <td style="text-align: right;">
                        <button class="btn-admin btn-secondary btn-sm">Sửa</button>
                        @if (u.Email != User.Identity?.Name)
                        {
                            <button class="btn-admin btn-danger btn-sm">Khóa</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
