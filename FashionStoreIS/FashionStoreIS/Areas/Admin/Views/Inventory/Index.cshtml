@using FashionStoreIS.Services
@{
    ViewData["Title"] = "Inventory Intelligence";
    var search = ViewBag.Search as string ?? "";
    var intel = ViewBag.Intelligence as InventoryIntelligenceViewModel;
}

@section Styles {
<style>
    .intel-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .intel-card { background: var(--admin-card); border: 1px solid var(--admin-border); border-radius: 12px; padding: 20px; }
    .intel-label { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--admin-muted); margin-bottom: 8px; }
    .intel-value { font-size: 24px; font-weight: 800; color: #fff; }
    .intel-sub { font-size: 11px; color: var(--admin-muted); margin-top: 4px; }

    .insight-card { border-radius: 10px; padding: 16px 20px; margin-bottom: 20px; display: flex; align-items: center; gap: 16px; border-left: 4px solid #fff; }
    .insight-Danger { background: rgba(239,68,68,0.1); border-color: #ef4444; }
    .insight-Warning { background: rgba(245,158,11,0.1); border-color: #f59e0b; }
    .insight-Info { background: rgba(59,130,246,0.1); border-color: #3b82f6; }
    
    .stock-health-bar { height: 4px; width: 100%; background: rgba(255,255,255,0.05); border-radius: 2px; margin-top: 8px; overflow: hidden; }
    .health-Healthy { background: #10b981; }
    .health-Warning { background: #f59e0b; }
    .health-Critical { background: #ef4444; }
</style>
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
    <h2 style="font-size:22px; font-weight:800; color:#fff;">📊 Inventory Intelligence & DSS</h2>
    <div style="text-align:right;">
        <div style="font-size:11px; color:var(--admin-muted); text-transform:uppercase; letter-spacing:1px;">Ngày báo cáo</div>
        <div style="font-size:13px; font-weight:600;">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
</div>

@if (intel != null)
{
    <!-- KPI Dashboard -->
    <div class="intel-grid">
        <div class="intel-card">
            <div class="intel-label">Giá trị vốn (Cost)</div>
            <div class="intel-value">@intel.TotalAssetValue.ToString("N0")₫</div>
            <div class="intel-sub">Tổng vốn lưu động trong kho</div>
        </div>
        <div class="intel-card">
            <div class="intel-label">Doanh thu dự kiến</div>
            <div class="intel-value" style="color:#10b981;">@intel.PotentialRevenue.ToString("N0")₫</div>
            <div class="intel-sub">Biên lợi nhuận: ~@intel.MarginPercentage.ToString("F1")%</div>
        </div>
        <div class="intel-card">
            <div class="intel-label">Sức khỏe kho hàng</div>
            <div class="intel-value">@intel.HealthyStockCount <span style="font-size:14px; font-weight:400; color:var(--admin-muted);">/ @intel.TotalSkus</span></div>
            <div class="intel-sub">⚠️ @intel.LowStockCount sắp hết • ❌ @intel.OutOfStockCount hết hàng</div>
        </div>
        <div class="intel-card">
            <div class="intel-label">Tỷ lệ hết hàng</div>
            @{
                var oosPct = intel.TotalSkus > 0 ? (intel.OutOfStockCount * 100.0 / intel.TotalSkus) : 0;
            }
            <div class="intel-value" style="color:@(oosPct > 10 ? "#ef4444" : "#fff");">@oosPct.ToString("F1")%</div>
            <div class="intel-sub">Mục tiêu: &lt; 5% để tối ưu doanh thu</div>
        </div>
    </div>

    <!-- Smart Insights -->
    @foreach (var insight in intel.Insights)
    {
        <div class="insight-card insight-@insight.Type">
            <div style="font-size:24px;">
                @(insight.Type == "Danger" ? "🚨" : insight.Type == "Warning" ? "⚡" : "ℹ️")
            </div>
            <div style="flex:1;">
                <div style="font-size:14px; font-weight:700; color:#fff;">@insight.Title</div>
                <div style="font-size:12px; color:var(--admin-muted);">@insight.Message</div>
            </div>
            @if (!string.IsNullOrEmpty(insight.ActionUrl))
            {
                <a href="@insight.ActionUrl" class="btn-admin btn-sm @(insight.Type == "Danger" ? "btn-danger" : "btn-primary")">
                    @insight.ActionText
                </a>
            }
        </div>
    }
}

<div style="display:flex; gap:12px; margin-bottom:20px; align-items:center; flex-wrap:wrap;">
    <form method="get" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <input name="search" value="@search" class="form-control" placeholder="Tìm kiếm SKU hoặc tên sản phẩm..." style="max-width:320px;" />
        <button type="submit" class="btn-admin btn-primary"><i class="fa fa-search"></i> Lọc dữ liệu</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a href="/Admin/Inventory" class="btn-admin btn-secondary">Xóa lọc</a>
        }
    </form>
</div>

@if (ViewBag.InventoryItems is null || ((List<FashionStoreIS.Areas.Admin.Controllers.InventoryGroupItem>)ViewBag.InventoryItems).Count == 0)
{
    <div style="text-align:center; padding:60px 20px; color:#64748b;">
        <div style="font-size:40px; margin-bottom:12px;">📦</div>
        <div style="font-size:16px;">Không tìm thấy sản phẩm nào.</div>
    </div>
}
else
{
    foreach (var item in (List<FashionStoreIS.Areas.Admin.Controllers.InventoryGroupItem>)ViewBag.InventoryItems)
    {
        var isLow = item.TotalStock <= 10;
        <div class="admin-card" style="margin-bottom:16px;">
            <div class="admin-card-header">
                <div style="display:flex; align-items:center; gap:14px;">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="product-thumb" />
                    }
                    else
                    {
                        <div class="product-thumb" style="background:#222; display:flex; align-items:center; justify-content:center; color:#555; font-size:18px;">📦</div>
                    }
                    <div>
                        <div class="admin-card-title">@item.ProductName</div>
                        <div style="font-size:11px; color:#64748b; margin-top:2px;">@item.CategoryName · @item.Skus.Count biến thể</div>
                    </div>
                </div>
                <div style="display:flex; align-items:center; gap:12px;">
                    <span class="badge @(isLow ? "badge-red" : "badge-green")">
                        @(isLow ? "⚠️ " : "")Tổng: @item.TotalStock
                    </span>
                    <a href="/Admin/Products/Edit/@item.ProductId" class="btn-admin btn-secondary btn-sm">✏️ Sửa SP</a>
                </div>
            </div>
            <div>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>SKU Code</th>
                            <th>Màu sắc</th>
                            <th>Kích thước</th>
                            <th>Giá vốn</th>
                            <th>Giá bán</th>
                            <th style="text-align:center;">Tồn kho</th>
                            <th style="text-align:center;">Trạng thái</th>
                            <th style="text-align:center;">Cập nhật</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sku in item.Skus)
                        {
                            var stockColor = sku.Stock <= 0 ? "#ef4444" : (sku.Stock <= 5 ? "#f59e0b" : "#10b981");
                            var displayPrice = (sku.PriceOverride.HasValue && sku.PriceOverride.Value > 0)
                                ? sku.PriceOverride.Value : sku.SellingPrice;
                            <tr>
                                <td><code style="font-size:11px; color:#94a3b8; background:#1e293b; padding:2px 6px; border-radius:3px;">@sku.SkuCode</code></td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:8px;">
                                        <div style="width:14px; height:14px; border-radius:50%; border:1px solid #444; background:@ColorToHex(sku.Color ?? "");"></div>
                                        @sku.Color
                                    </div>
                                </td>
                                <td><span class="badge" style="background:rgba(51,65,85,0.5); color:#94a3b8; font-size:11px;">@sku.Size</span></td>
                                <td style="color:#94a3b8;">@sku.CostPrice.ToString("N0") ₫</td>
                                <td>@displayPrice.ToString("N0") ₫</td>
                                <td style="text-align:center;">
                                    @{
                                        var healthClass = sku.Stock <= 0 ? "Critical" : (sku.Stock <= 10 ? "Warning" : "Healthy");
                                        var healthLabel = sku.Stock <= 0 ? "Hết hàng" : (sku.Stock <= 10 ? "Sắp hết" : "Ổn định");
                                    }
                                    <span style="font-size:22px; font-weight:800; color:@stockColor; display:block;">@sku.Stock</span>
                                    <div class="stock-health-bar"><div class="health-@healthClass" style="width:@(Math.Min(sku.Stock * 2, 100))%;"></div></div>
                                    <span style="font-size:9px; font-weight:700; text-transform:uppercase; color:var(--admin-muted); margin-top:2px; display:block;">@healthLabel</span>
                                </td>
                                <td style="text-align:center;">
                                    <span class="badge @(sku.IsActive ? "badge-green" : "badge-red")">
                                        @(sku.IsActive ? "Đang bán" : "Ngừng bán")
                                    </span>
                                </td>
                                <td style="text-align:center;">
                                    <form method="post" action="/Admin/Inventory/UpdateStock" style="display:flex; gap:6px; align-items:center; justify-content:center;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="skuId" value="@sku.Id" />
                                        <input type="number" name="stock" value="@sku.Stock" class="form-control" style="width:70px;" min="0" />
                                        <button type="submit" class="btn-admin btn-primary btn-sm">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@{
    string ColorToHex(string color) => color.ToLower() switch {
        "black" or "đen" => "#111",
        "white" or "trắng" => "#f0f0f0",
        "red" or "đỏ" => "#ef4444",
        "blue" or "xanh dương" => "#3b82f6",
        "navy" or "xanh navy" => "#1e3a5f",
        "green" or "xanh lá" => "#10b981",
        "yellow" or "vàng" => "#fbbf24",
        "brown" or "nâu" => "#92400e",
        "gray" or "grey" or "xám" => "#9ca3af",
        "indigo" or "chàm" => "#4f46e5",
        "pink" or "hồng" => "#ec4899",
        _ => "#64748b"
    };
}
