@model List<FashionStoreIS.Models.Banner>
@{
    ViewData["Title"] = "Quản lý Banners";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
    <p style="font-size:13px; color:#666;">Quản lý banner hiển thị trên trang chủ. Ảnh sẽ hiển thị trong phần Hero / danh mục.</p>
    <a href="/Admin/Banners/Create" class="btn-admin btn-primary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Thêm banner
    </a>
</div>

<div class="admin-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Ảnh</th>
                <th>Tiêu đề</th>
                <th>Phụ đề</th>
                <th>Thứ tự</th>
                <th>Vị trí</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(b.ImageUrl))
                        {
                            <img src="@b.ImageUrl" class="product-thumb" />
                        }
                        else
                        {
                            <div class="product-thumb" style="display:flex;align-items:center;justify-content:center;font-size:10px;color:#444;background:#2a2a2a;">N/A</div>
                        }
                    </td>
                    <td><strong style="color:#fff;">@b.Title</strong></td>
                    <td style="color:#888;">@b.SubTitle</td>
                    <td style="color:#888;">@b.DisplayOrder</td>
                    <td>
                        @if(b.Position == "Hero") { <span style="color:#aaa;">Hero</span> }
                        else if(b.Position == "Category1") { <span style="color:#aaa;">Danh mục 1</span> }
                        else if(b.Position == "Category2") { <span style="color:#aaa;">Danh mục 2</span> }
                        else if(b.Position == "Category3") { <span style="color:#aaa;">Danh mục 3</span> }
                        else { <span style="color:#aaa;">@b.Position</span> }
                    </td>
                    <td>
                        <span class="badge @(b.IsActive ? "badge-green" : "badge-red")">
                            @(b.IsActive ? "Hiển thị" : "Ẩn")
                        </span>
                    </td>
                    <td>
                        <div style="display:flex; gap:8px;">
                            <a href="/Admin/Banners/Edit/@b.Id" class="btn-admin btn-secondary btn-sm">Sửa</a>
                            <form method="post" action="/Admin/Banners/Delete/@b.Id" style="display:inline;" onsubmit="return confirm('Xóa banner này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-admin btn-danger btn-sm">Xóa</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" style="text-align:center; color:#555; padding:40px;">Chưa có banner nào. <a href="/Admin/Banners/Create" style="color:#fff;">Thêm ngay</a></td></tr>
            }
        </tbody>
    </table>
</div>
