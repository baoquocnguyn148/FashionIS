@model IEnumerable<FashionStoreIS.Models.Shift>

@{
    ViewData["Title"] = "Quản lý Ca làm việc";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h2 style="font-size: 24px; font-weight: 700; color: #fff;">QUẢN LÝ CA LÀM VIỆC</h2>
    <a asp-action="Create" class="btn-admin btn-primary">
        <i class="fa-solid fa-plus"></i> THÊM CA MỚI
    </a>
</div>

<div class="admin-card" style="margin-bottom: 24px; padding: 20px;">
    <form method="get" style="display: flex; gap: 15px; align-items: flex-end;">
        <div style="width: 280px;">
            <label class="form-label">Lọc theo Chi nhánh</label>
            <select name="storeId" class="form-control" asp-items="@(ViewData["Stores"] as SelectList)">
                <option value="">Tất cả chi nhánh</option>
            </select>
        </div>
        <button type="submit" class="btn-admin btn-primary" style="height: 42px;">LỌC</button>
    </form>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <div class="admin-card-title">DANH SÁCH CÁC CA</div>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Tên ca</th>
                <th>Giờ bắt đầu</th>
                <th>Giờ kết thúc</th>
                <th>Chi nhánh</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-weight: 600; color: #fff;">@item.Name</td>
                    <td>@item.StartTime.ToString(@"hh\:mm")</td>
                    <td>@item.EndTime.ToString(@"hh\:mm")</td>
                    <td>@(item.Store?.Name ?? "Tất cả")</td>
                    <td>
                        <span class="badge @(item.IsActive ? "badge-green" : "badge-red")">
                            @(item.IsActive ? "Hoạt động" : "Ngưng")
                        </span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-admin btn-secondary btn-sm">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa ca này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-admin btn-danger btn-sm">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
