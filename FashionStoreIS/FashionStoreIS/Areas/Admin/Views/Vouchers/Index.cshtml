@model List<Voucher>
@{
    ViewData["Title"] = "Quản lý Voucher";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
    <div>
        <h2 style="font-size: 24px; font-weight: 800; color: #fff; margin-bottom: 4px;">Danh sách Voucher</h2>
        <p style="font-size: 14px; color: var(--admin-muted);">Quản lý mã giảm giá và chương trình khuyến mãi.</p>
    </div>
    <a href="/Admin/Vouchers/Create" class="btn-admin btn-primary" style="padding: 12px 24px; border-radius: 12px; background: var(--admin-accent); color: #fff;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Tạo Voucher mới
    </a>
</div>

<div class="admin-card" style="border: none; background: transparent; box-shadow: none;">
    <table class="admin-table" style="background: var(--admin-card); border-radius: 16px; overflow: hidden; border: 1px solid var(--admin-border);">
        <thead>
            <tr style="background: rgba(255,255,255,0.02);">
                <th style="padding: 20px 24px;">Mã Code</th>
                <th style="padding: 20px 24px;">Giảm giá</th>
                <th style="padding: 20px 24px;">Đơn tối thiểu</th>
                <th style="padding: 20px 24px;">Hạn dùng</th>
                <th style="padding: 20px 24px;">Trạng thái</th>
                <th style="padding: 20px 24px; text-align: right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td style="padding: 20px 24px;">
                        <span style="font-family: monospace; font-weight: 800; color: var(--admin-accent); background: rgba(139, 92, 246, 0.1); padding: 4px 8px; border-radius: 4px; border: 1px solid rgba(139, 92, 246, 0.2);">@v.Code</span>
                    </td>
                    <td style="padding: 20px 24px; color: #fff; font-weight: 700;">@v.DiscountAmount.ToString("N0") VND</td>
                    <td style="padding: 20px 24px; color: var(--admin-muted);">@v.MinOrderAmount.ToString("N0") VND</td>
                    <td style="padding: 20px 24px; color: var(--admin-muted);">@v.ExpiryDate.ToString("dd/MM/yyyy")</td>
                    <td style="padding: 20px 24px;">
                        <span class="badge @(v.IsActive && v.ExpiryDate >= DateTime.Now ? "badge-green" : "badge-red")">
                            @(v.IsActive && v.ExpiryDate >= DateTime.Now ? "Đang chạy" : "Hết hạn/Ẩn")
                        </span>
                    </td>
                    <td style="padding: 20px 24px; text-align: right;">
                        <div style="display: flex; gap: 8px; justify-content: flex-end;">
                            <a href="/Admin/Vouchers/Edit/@v.Id" class="btn-admin btn-secondary btn-sm" title="Sửa">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            </a>
                            <form method="post" action="/Admin/Vouchers/Delete/@v.Id" style="display:inline;" onsubmit="return confirm('Xóa voucher này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-admin btn-danger btn-sm" title="Xóa">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"></path></svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align: center; padding: 60px 0; color: var(--admin-muted);">Chưa có voucher nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .admin-table td { border-bottom: 1px solid rgba(255,255,255,0.03); }
    .btn-admin.btn-sm { width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; }
    .badge { padding: 4px 12px; border-radius: 20px; font-weight: 600; font-size: 11px; }
</style>
