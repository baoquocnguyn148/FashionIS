@page
@model FashionStoreIS.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "BN STORE - Login Page";
}

<div class="page-container">
    <!-- Breadcrumbs -->
    <div class="breadcrumb-container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Login Page</li>
            </ol>
        </nav>
    </div>

    <div class="login-page-wrapper">
        <div class="login-container">
            <h2 class="login-title">Đăng nhập</h2>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-group mb-3">
                    <label class="form-label-expert">Email *</label>
                    <input asp-for="Input.Email" class="form-control-expert" placeholder="Email của bạn" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label-expert">Mật khẩu *</label>
                    <input asp-for="Input.Password" class="form-control-expert" placeholder="••••••••" type="password" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="login-meta mb-3">
                    <a id="forgot-password" asp-page="./ForgotPassword" class="meta-link">Quên thông tin tài khoản</a>
                </div>

                <button id="login-submit" type="submit" class="btn-login-expert">Đăng nhập</button>

                <div class="login-footer-links mt-4">
                    <p>Bạn chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="footer-link-bold">Đăng ký ngay</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
