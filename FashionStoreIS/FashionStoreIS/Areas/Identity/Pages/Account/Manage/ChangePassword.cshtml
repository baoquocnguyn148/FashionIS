@page
@model FashionStoreIS.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<h2 class="section-title-expert">Đổi mật khẩu</h2>

<form id="change-password-form" method="post" class="password-box-expert">
    <div asp-validation-summary="All" class="text-danger mb-3" role="alert" style="font-size: 13px; text-transform: none;"></div>
    
    <div class="mb-3">
        <input asp-for="Input.OldPassword" class="form-control-expert" placeholder="Nhập mật khẩu hiện tại" />
        <span asp-validation-for="Input.OldPassword" class="text-danger d-block mt-1" style="font-size: 13px; text-transform: none;"></span>
    </div>

    <div class="password-input-wrapper mb-4">
        <input asp-for="Input.NewPassword" class="form-control-expert" placeholder="........" />
        <span class="password-toggle-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </span>
        <span asp-validation-for="Input.NewPassword" class="text-danger d-block mt-1" style="font-size: 13px; text-transform: none;"></span>
    </div>

    <button type="submit" class="btn-login-expert">Đổi mật khẩu</button>

    <div class="password-hint-expert">
        Mật khẩu của bạn chềEđược chứa chữ cái (viết hoa/thường), sềEvà dài tối thiểu 6 ký tự.<br />
        Không chứa khoảng trắng và các ký tự đặc biệt.
    </div>
</form>

<div class="mt-5" style="max-width: 500px;">
    <h3 class="section-title-expert" style="font-size: 16px; margin-bottom: 20px;">Quên mật khẩu</h3>
    <div class="mb-3">
        <input class="form-control-expert" value="0914061758" readonly />
    </div>
    <button class="btn-login-expert" type="button">Gửi yêu cầu</button>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
