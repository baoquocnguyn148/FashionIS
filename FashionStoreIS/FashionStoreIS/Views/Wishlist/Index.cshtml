@model List<FashionStoreIS.Models.WishlistItem>
@{
    ViewData["Title"] = "Danh sách yêu thích";
}

<div class="wl-container">
    <!-- Header -->
    <div class="wl-header">
        <h1 class="wl-title">DANH SÁCH YÊU THÍCH</h1>
        <span class="wl-count">@Model.Count sản phẩm</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="wl-alert wl-alert-success">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <!-- Empty State -->
        <div class="wl-empty">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ddd" stroke-width="1.2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <p class="wl-empty-title">Danh sách yêu thích trống</p>
            <p class="wl-empty-sub">Hãy thêm những sản phẩm bạn thích vào đây nhé!</p>
            <a href="/Product/List" class="wl-btn-shop">KHÁM PHÁ SẢN PHẨM</a>
        </div>
    }
    else
    {
        <!-- Clear All Button -->
        <div class="wl-toolbar">
            <form asp-action="Clear" asp-controller="Wishlist" method="post" onsubmit="return confirm('Xóa toàn bộ danh sách yêu thích?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="wl-btn-clear-all">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                    Xóa tất cả
                </button>
            </form>
        </div>

        <!-- Wishlist Grid -->
        <div class="wl-grid">
            @foreach (var item in Model)
            {
                var p = item.Product;
                <div class="wl-card" id="wl-card-@p.Id">
                    <!-- Remove Button -->
                    <form asp-action="Remove" asp-controller="Wishlist" method="post" class="wl-remove-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@p.Id" />
                        <button type="submit" class="wl-remove-btn" title="Xóa khỏi yêu thích">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </form>

                    <!-- Product Image -->
                    <a href="/Product/Detail/@p.Id" class="wl-card-image-link">
                        <div class="wl-card-image">
                            @if (p.Stock <= 0)
                            {
                                <div class="wl-sold-out">SOLD OUT</div>
                            }
                            <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "https://placehold.co/600x750/f0f0f0/999?text=NO+IMAGE" : p.ImageUrl)"
                                 alt="@p.Name" loading="lazy" />
                        </div>
                    </a>

                    <!-- Product Info -->
                    <div class="wl-card-info">
                        <a href="/Product/Detail/@p.Id" class="wl-card-name">@p.Name.ToUpper()</a>
                        @if (p.Category != null)
                        {
                            <div class="wl-card-cat">@p.Category.Name</div>
                        }
                        <div class="wl-card-price">@p.Price.ToString("N0")₫</div>

                        <!-- Add to Cart Button -->
                        @if (p.Stock > 0)
                        {
                            <button class="wl-btn-cart"
                                    onclick="addToCartFromWishlist(@p.Id, '@p.Name.Replace("'","\\'")')">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                                Thêm vào giỏ hàng
                            </button>
                        }
                        else
                        {
                            <button class="wl-btn-cart wl-btn-disabled" disabled>Hết hàng</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
/* ─── Wishlist Container ─── */
.wl-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px 80px;
}

.wl-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 32px;
    border-bottom: 2px solid #111;
    padding-bottom: 16px;
}
.wl-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin: 0;
}
.wl-count {
    font-size: 13px;
    color: #888;
}

/* ─── Alert ─── */
.wl-alert {
    padding: 12px 20px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-size: 14px;
}
.wl-alert-success {
    background: #f0fdf4;
    border: 1px solid #86efac;
    color: #166534;
}

/* ─── Toolbar ─── */
.wl-toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 24px;
}
.wl-btn-clear-all {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1px solid #ddd;
    color: #666;
    font-size: 12px;
    padding: 8px 16px;
    cursor: pointer;
    border-radius: 4px;
    letter-spacing: 0.04em;
    transition: all 0.2s;
}
.wl-btn-clear-all:hover { border-color: #ef4444; color: #ef4444; }

/* ─── Grid ─── */
.wl-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
}
@@media (max-width: 1024px) { .wl-grid { grid-template-columns: repeat(3, 1fr); } }
@@media (max-width: 768px)  { .wl-grid { grid-template-columns: repeat(2, 1fr); } }
@@media (max-width: 480px)  { .wl-grid { grid-template-columns: 1fr; } }

/* ─── Card ─── */
.wl-card {
    position: relative;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    overflow: hidden;
    transition: box-shadow 0.25s;
    background: #fff;
}
.wl-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }

/* Remove Button */
.wl-remove-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 10;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
}
.wl-remove-btn:hover { background: #ef4444; border-color: #ef4444; color: #fff; }
.wl-remove-btn:hover svg { stroke: #fff; }
.wl-remove-form { margin: 0; }

/* Image */
.wl-card-image-link { display: block; }
.wl-card-image {
    position: relative;
    aspect-ratio: 3/4;
    background: #f5f5f5;
    overflow: hidden;
}
.wl-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}
.wl-card:hover .wl-card-image img { transform: scale(1.04); }
.wl-sold-out {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(0,0,0,0.7);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 4px 8px;
    z-index: 2;
    border-radius: 2px;
}

/* Info */
.wl-card-info {
    padding: 14px 16px 18px;
    border-top: 1px solid #e5e5e5;
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.wl-card-name {
    font-size: 12px;
    font-weight: 600;
    color: #111;
    text-decoration: none;
    letter-spacing: 0.03em;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.wl-card-name:hover { text-decoration: underline; }
.wl-card-cat { font-size: 11px; color: #aaa; }
.wl-card-price { font-size: 14px; font-weight: 500; color: #111; }

/* Add to Cart Button */
.wl-btn-cart {
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 10px;
    background: #111;
    color: #fff;
    border: none;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    cursor: pointer;
    border-radius: 3px;
    transition: opacity 0.2s;
}
.wl-btn-cart:hover { opacity: 0.8; }
.wl-btn-disabled {
    background: #ddd !important;
    color: #999 !important;
    cursor: not-allowed !important;
}
.wl-btn-disabled:hover { opacity: 1 !important; }

/* ─── Empty State ─── */
.wl-empty {
    text-align: center;
    padding: 100px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
}
.wl-empty-title {
    font-size: 18px;
    font-weight: 600;
    color: #333;
    margin: 0;
}
.wl-empty-sub {
    font-size: 14px;
    color: #888;
    margin: 0;
}
.wl-btn-shop {
    display: inline-block;
    margin-top: 8px;
    padding: 14px 40px;
    background: #111;
    color: #fff;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    border-radius: 3px;
    transition: opacity 0.2s;
}
.wl-btn-shop:hover { opacity: 0.8; color: #fff; }
</style>

@section Scripts {
<script>
function addToCartFromWishlist(productId, productName) {
    // Thêm vào cart cookie (giống CartController)
    var cartCookie = getCookie('BNStore_Cart');
    var cart = cartCookie ? JSON.parse(decodeURIComponent(cartCookie)) : [];

    // Tìm sản phẩm trong giỏ (không dùng SKU trên trang wishlist này)
    var existing = cart.find(function(i) { 
        // CartController uses PascalCase for the model in cookie
        return (i.ProductId === productId || i.productId === productId) && !i.ProductSkuId && !i.productSkuId; 
    });

    if (existing) {
        if (existing.Quantity !== undefined) existing.Quantity++;
        else if (existing.quantity !== undefined) existing.quantity++;
        else existing.Quantity = 1;
    } else {
        cart.push({ 
            ProductId: productId, 
            ProductSkuId: null, 
            Color: "", 
            Size: "", 
            Quantity: 1 
        });
    }

    // Lưu cookie (7 ngày giống CartController)
    var expires = new Date();
    expires.setDate(expires.getDate() + 7);
    document.cookie = 'BNStore_Cart=' + encodeURIComponent(JSON.stringify(cart)) + 
                     '; expires=' + expires.toUTCString() + '; path=/';

    // Cập nhật số lượng trên header (nếu có hàm updateCartCount toàn cục)
    if (typeof updateCartCount === 'function') {
        updateCartCount();
    } else {
        // Fallback update badge
        var total = cart.reduce(function(sum, item) { 
            return sum + (item.Quantity || item.quantity || 0); 
        }, 0);
        var badge = document.getElementById('cartCountBadge');
        if (badge) {
            badge.textContent = total;
            badge.style.display = total > 0 ? 'flex' : 'none';
        }
    }

    // Thông báo thành công
    showToast('✓ ' + productName + ' đã thêm vào giỏ hàng!');
}

function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? decodeURIComponent(match[2]) : null;
}

function showToast(msg) {
    var t = document.createElement('div');
    t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#111;color:#fff;padding:14px 22px;border-radius:6px;font-size:13px;z-index:99999;box-shadow:0 4px 20px rgba(0,0,0,0.2);transition:opacity 0.3s';
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(function(){ t.style.opacity='0'; setTimeout(function(){ t.remove(); }, 300); }, 2500);
}
</script>
}
