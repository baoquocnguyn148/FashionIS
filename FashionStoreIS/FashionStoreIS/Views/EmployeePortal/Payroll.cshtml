@model List<FashionStoreIS.Models.Payroll>
@{
    Layout = "_EmployeeLayout";
    ViewData["Title"] = "Phiếu lương cá nhân";
}

<div class="row mb-3">
    <div class="col-12">
        <h4 class="fw-bold"><i class="fas fa-wallet text-primary me-2"></i>Tiền lương</h4>
        <p class="text-muted small">Lịch sử thu nhập của bạn</p>
    </div>
</div>

<!-- Current Month Earnings Card -->
@if (Model.Any())
{
    var latest = Model.First();
    <div class="p-card border-0 mb-4 bg-success text-white p-3 overflow-hidden position-relative shadow">
        <div style="position:absolute; top:-10px; right:-10px; font-size:80px; opacity:0.1;">
            <i class="fas fa-coins"></i>
        </div>
        
        <div class="position-relative">
            <span class="badge bg-white text-success mb-2">LƯƠNG @latest.Month/@latest.Year</span>
            <div class="h1 fw-bold mb-1">@latest.NetSalary.ToString("N0") <small style="font-size:0.5em">VNĐ</small></div>
            <div class="small opacity-75">Trạng thái: @latest.Status.ToString()</div>
            <hr class="my-2 opacity-25" />
            <a asp-action="PayrollDetail" asp-route-id="@latest.Id" class="btn btn-sm btn-light rounded-pill px-3 fw-bold text-success">
                Xem chi tiết <i class="fas fa-chevron-right ms-1"></i>
            </a>
        </div>
    </div>
}

<!-- History List -->
<div class="p-card border-0 bg-white p-0 overflow-hidden shadow-sm">
    <div class="p-3 bg-light border-bottom fw-bold">LỊCH SỬ PHIẾU LƯƠNG</div>
    <div class="p-0">
        @if (Model.Any())
        {
            @foreach (var payroll in Model)
            {
                <a asp-action="PayrollDetail" asp-route-id="@payroll.Id" class="d-flex align-items-center p-3 border-bottom text-decoration-none text-dark hover-bg-light">
                    <div class="stat-circle bg-light text-primary me-3 mb-0">
                        <i class="fas fa-file-invoice-dollar"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-bold">Tháng @payroll.Month / @payroll.Year</div>
                        <div class="small text-muted">Thực nhận: <span class="text-success fw-bold">@payroll.NetSalary.ToString("N0") đ</span></div>
                    </div>
                    <div class="text-muted">
                        <i class="fas fa-chevron-right"></i>
                    </div>
                </a>
            }
        }
        else
        {
            <div class="p-4 text-center text-muted small">Chưa có dữ liệu lương</div>
        }
    </div>
</div>

<style>
    .hover-bg-light:hover {
        background-color: #f8fafc;
    }
</style>
