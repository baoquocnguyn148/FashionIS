@model dynamic
@{
    ViewData["Title"] = "Tài khoản của tôi";
    var user = ViewBag.User as FashionStoreIS.Models.ApplicationUser;
    string activeTab = ViewBag.ActiveTab ?? "orders";
    string selectedStatus = ViewBag.SelectedStatus;

    // Membership logic
    string rank = "Dream Starter";
    if (user != null)
    {
        if (user.MembershipPoints >= 5000) { rank = "Diamond Master"; }
        else if (user.MembershipPoints >= 2000) { rank = "Gold Member"; }
        else if (user.MembershipPoints >= 500) { rank = "Silver Elite"; }
    }
}

<div class="profile-container container bg-white my-4 shadow-sm" style="max-width: 1200px;">
    <div class="row g-0 h-100">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3 sidebar-pane py-4 border-end">
            <div class="text-center px-4 mb-4">
                <div class="position-relative d-inline-block mb-3">
                    <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center overflow-hidden mx-auto" style="width: 80px; height: 80px; border: 2px solid #0f3c83;">
                        @if (!string.IsNullOrEmpty(user?.AvatarUrl))
                        {
                            <img src="@user.AvatarUrl" class="w-100 h-100 object-fit-cover" alt="Avatar">
                        }
                        else
                        {
                            <img src="https://ui-avatars.com/api/?name=@(user?.FullName ?? user?.UserName)&background=random" class="w-100 h-100 object-fit-cover" alt="Avatar">
                        }
                    </div>
                </div>
                
                <h6 class="mb-1 text-dark fw-bold" style="font-size:15px;">Xin chào bạn!</h6>
                <div class="fw-bold mb-1 profile-name">@(user?.FullName ?? user?.UserName)</div>
                <p class="text-muted small mb-2" style="font-size: 13px;">@user?.Email</p>
                <div class="badge rank-badge px-3 py-1 rounded-pill small mt-1">
                    Cấp độ @rank
                </div>
            </div>
            
            <hr class="opacity-10 mx-3 mb-3">

            <div class="list-group list-group-flush sidebar-menu">
                <a href="@Url.Action("Index", "Account", new { tab = "orders" })" 
                   class="list-group-item list-group-item-action @(activeTab == "orders" ? "active" : "")">
                    <i class="fa-solid fa-box me-3 menu-icon"></i> Đơn hàng của tôi
                </a>
                <a href="@Url.Action("Index", "Account", new { tab = "profile" })" 
                   class="list-group-item list-group-item-action @(activeTab == "profile" ? "active" : "")">
                    <i class="fa-regular fa-id-card me-3 menu-icon"></i> Hồ sơ của tôi
                </a>
                <a href="@Url.Action("Index", "Account", new { tab = "security" })" 
                   class="list-group-item list-group-item-action @(activeTab == "security" ? "active" : "")">
                    <i class="fa-solid fa-shield-halved me-3 menu-icon"></i> Bảo mật tài khoản
                </a>
                <a href="@Url.Action("Index", "Account", new { tab = "address" })" 
                   class="list-group-item list-group-item-action @(activeTab == "address" ? "active" : "")">
                    <i class="fa-solid fa-location-dot me-3 menu-icon"></i> Địa chỉ giao hàng
                </a>
                <a href="@Url.Action("Index", "Account", new { tab = "returns" })" 
                   class="list-group-item list-group-item-action @(activeTab == "returns" ? "active" : "")">
                    <i class="fa-solid fa-rotate-left me-3 menu-icon"></i> Trả hàng/Hoàn tiền
                </a>
                <a href="@Url.Action("Index", "Account", new { tab = "promotions" })" 
                   class="list-group-item list-group-item-action d-flex align-items-center @(activeTab == "promotions" ? "active" : "")">
                    <i class="fa-solid fa-ticket me-3 menu-icon"></i> Khuyến mãi
                    <span class="badge new-badge ms-auto">New</span>
                </a>
                <a href="@Url.Action("Index", "Account", new { tab = "notifications" })" 
                   class="list-group-item list-group-item-action @(activeTab == "notifications" ? "active" : "")">
                    <i class="fa-solid fa-bell me-3 menu-icon"></i> Thông báo
                </a>
                
                <hr class="opacity-10 mx-3 mt-4 mb-2">
                <!-- Add Logout just to be complete, although screenshot cut it out, it's usually at bottom -->
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" class="px-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link text-decoration-none text-muted p-0 w-100 text-start" style="font-size: 14px; padding: 14px 24px !important; margin-left: -5px;">
                        <i class="fa-solid fa-arrow-right-from-bracket me-3 menu-icon"></i> Đăng xuất
                    </button>
                </form>
            </div>
            
            <!-- Cleaned up legacy layout container -->
        </div>

        <!-- Main Content Area -->
        <div class="col-lg-9 content-pane p-4 p-md-5 bg-white">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm rounded-0 mb-4 animate__animated animate__fadeIn">
                    <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger border-0 shadow-sm rounded-0 mb-4 animate__animated animate__fadeIn">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
                </div>
            }

            @if (activeTab == "orders")
            {
                <div class="mb-5">
                    <h3 class="fw-bold text-dark mb-2" style="color: #0c1e36;">Lịch sử đơn hàng</h3>
                    <p class="text-muted small mb-4" style="font-size: 14px;">Quản lý và theo dõi tất cả đơn hàng của bạn</p>
                    
                    <!-- Text Tab Navigation -->
                    <div class="d-flex flex-wrap status-tabs align-items-center border-bottom pb-3 gap-0">
                        <a href="@Url.Action("Index", new { tab = "orders" })" 
                           class="status-tab @(string.IsNullOrEmpty(selectedStatus) ? "active" : "")">Tất cả</a>
                        
                        <a href="@Url.Action("Index", new { tab = "orders", status = "Pending" })" 
                           class="status-tab @(selectedStatus == "Pending" ? "active" : "")">Chờ xác nhận</a>
                        
                        <a href="@Url.Action("Index", new { tab = "orders", status = "Confirmed" })" 
                           class="status-tab @(selectedStatus == "Confirmed" ? "active" : "")">Đã xác nhận</a>
                        
                        <a href="@Url.Action("Index", new { tab = "orders", status = "Shipped" })" 
                           class="status-tab @(selectedStatus == "Shipped" ? "active" : "")">Đang giao hàng</a>
                        
                        <a href="@Url.Action("Index", new { tab = "orders", status = "Completed" })" 
                           class="status-tab @(selectedStatus == "Completed" ? "active" : "")">Đã nhận hàng</a>
                        
                        <a href="@Url.Action("Index", new { tab = "orders", status = "Cancelled" })" 
                           class="status-tab @(selectedStatus == "Cancelled" ? "active" : "")">Đã hủy</a>
                    </div>
                </div>

                @if (Model == null || Model.Count == 0)
                {
                    <div class="empty-state border rounded-4 text-center py-5 px-3 mx-auto mt-4 w-100 shadow-sm" style="border-color: #eaeaea !important;">
                        <div class="empty-icon-circle mx-auto mb-4 d-flex align-items-center justify-content-center mt-3">
                            <i class="fa-solid fa-bag-shopping profile-theme-icon" style="font-size: 24px;"></i>
                        </div>
                        <h5 class="fw-bold mb-3" style="color: #0c1e36;">Chưa có đơn hàng nào</h5>
                        <p class="text-muted small mb-5 lh-lg mx-auto" style="max-width: 380px;">Nơi này sẽ giúp xem lại những đơn hàng mà bạn đã đặt,<br/>hãy quay lại đây sau khi đặt đơn hàng đầu tiên<br/>của mình nhé!</p>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-theme-primary px-4 py-2 mb-3 fw-medium" style="font-size: 14px;">Tiếp tục mua sắm &rarr;</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="bg-light">
                                <tr class="small text-uppercase text-muted">
                                    <th class="border-0 px-3 py-3">Mã đơn</th>
                                    <th class="border-0 py-3">Ngày đặt</th>
                                    <th class="border-0 py-3">Tổng cộng</th>
                                    <th class="border-0 py-3">Trạng thái</th>
                                    <th class="border-0 py-3 text-end"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    <tr>
                                        <td class="px-3">
                                            <span class="fw-bold text-dark">#@order.Id</span>
                                        </td>
                                        <td class="text-muted small">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="fw-bold text-dark">@order.TotalAmount.ToString("N0")₫</td>
                                        <td>
                                            @{
                                                var statusClass = order.Status switch
                                                {
                                                    FashionStoreIS.Models.OrderStatus.Pending => "bg-warning-subtle text-warning-emphasis",
                                                    FashionStoreIS.Models.OrderStatus.Processing => "bg-info-subtle text-info-emphasis",
                                                    FashionStoreIS.Models.OrderStatus.Shipped => "bg-primary-subtle text-primary-emphasis",
                                                    FashionStoreIS.Models.OrderStatus.Completed => "bg-success-subtle text-success-emphasis",
                                                    FashionStoreIS.Models.OrderStatus.Cancelled => "bg-danger-subtle text-danger-emphasis",
                                                    _ => "bg-secondary-subtle text-secondary-emphasis"
                                                };
                                                var statusText = order.Status switch
                                                {
                                                    FashionStoreIS.Models.OrderStatus.Pending => "Chờ xác nhận",
                                                    FashionStoreIS.Models.OrderStatus.Confirmed => "Đã xác nhận",
                                                    FashionStoreIS.Models.OrderStatus.Processing => "Đang xử lý",
                                                    FashionStoreIS.Models.OrderStatus.Shipped => "Đang giao hàng",
                                                    FashionStoreIS.Models.OrderStatus.Completed => "Đã nhận hàng",
                                                    FashionStoreIS.Models.OrderStatus.Cancelled => "Đã hủy",
                                                    _ => order.Status.ToString()
                                                };
                                            }
                                            <span class="badge @statusClass rounded-pill px-3">@statusText</span>
                                        </td>
                                        <td class="text-end text-nowrap">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a href="@Url.Action("OrderDetails", "Account", new { id = order.Id })" 
                                                   class="btn btn-sm btn-outline-dark px-3">Chi tiết</a>
                                                
                                                @if (order.Status == FashionStoreIS.Models.OrderStatus.Pending)
                                                {
                                                    <form asp-action="CancelOrder" asp-controller="Account" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@order.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3">Hủy đơn</button>
                                                    </form>
                                                }
                                                @if (order.Status == FashionStoreIS.Models.OrderStatus.Completed)
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-warning px-3"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#returnModal"
                                                            onclick="setReturnOrder(@order.Id)">
                                                        <i class="fa-solid fa-rotate-left me-1"></i>Trả hàng
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Return Request Modal -->
                    <div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow rounded-4">
                                <div class="modal-header border-0 pb-0">
                                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-rotate-left me-2 text-warning"></i>Yêu cầu trả hàng</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <form asp-action="RequestReturn" asp-controller="Account" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="modal-body p-4">
                                        <input type="hidden" name="orderId" id="returnOrderId" value="" />
                                        <p class="text-muted small mb-3">Vui lòng nhập lý do bạn muốn trả hàng. Yêu cầu sẽ được xem xét trong vòng 1-3 ngày làm việc.</p>
                                        <div class="mb-3">
                                            <label class="form-label small fw-bold text-muted">Lý do trả hàng <span class="text-danger">*</span></label>
                                            <textarea name="reason" class="form-control bg-light border-0" rows="4" required 
                                                      placeholder="Ví dụ: Sản phẩm bị lỗi, không đúng mô tả, nhận nhầm hàng..."></textarea>
                                        </div>
                                        <div class="alert alert-warning border-0 rounded-3 small py-2 px-3">
                                            <i class="fa-solid fa-circle-info me-1"></i>
                                            Chỉ có thể yêu cầu trả hàng trong vòng <strong>7 ngày</strong> sau khi nhận hàng.
                                        </div>
                                    </div>
                                    <div class="modal-footer border-0 pt-0">
                                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                                        <button type="submit" class="btn btn-warning px-4 rounded-pill fw-bold">Gửi yêu cầu</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                }  @* Close else block *@
            }
            else if (activeTab == "profile")
            {
                <div class="mb-4">
                    <h3 class="fw-bold text-dark mb-2" style="color: #0c1e36;">Hồ sơ của tôi</h3>
                    <p class="text-muted small" style="font-size: 14px;">Quản lý thông tin cá nhân và ảnh đại diện</p>
                </div>
                
                <div class="row g-5">
                    <div class="col-md-7">
                        <form asp-action="UpdateProfile" asp-controller="Account" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted text-uppercase">Họ và tên</label>
                                <input type="text" name="fullName" class="form-control bg-light border-0 py-2" value="@user?.FullName" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted text-uppercase">Email</label>
                                <input type="email" class="form-control bg-light border-0 py-2 text-muted" value="@user?.Email" disabled readonly>
                                <div class="form-text small">Email không thể thay đổi sau khi đăng ký.</div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted text-uppercase">Số điện thoại</label>
                                <input type="tel" name="phoneNumber" class="form-control bg-light border-0 py-2" value="@user?.PhoneNumber">
                            </div>
                            <div class="row mb-4">
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted text-uppercase">Ngày sinh</label>
                                    <input type="date" name="dob" class="form-control bg-light border-0 py-2" value="@(user?.DateOfBirth?.ToString("yyyy-MM-dd"))">
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted text-uppercase">Giới tính</label>
                                    <select name="gender" class="form-select bg-light border-0 py-2">
                                        <option value="" selected="@(string.IsNullOrEmpty(user?.Gender))">Chưa cập nhật</option>
                                        <option value="Nam" selected="@(user?.Gender == "Nam")">Nam</option>
                                        <option value="Nữ" selected="@(user?.Gender == "Nữ")">Nữ</option>
                                        <option value="Khác" selected="@(user?.Gender == "Khác")">Khác</option>
                                    </select>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-dark px-4 py-2 fw-medium rounded-pill me-2" style="background-color: #0f3c83;">Lưu thay đổi</button>
                        </form>
                    </div>
                    
                    <div class="col-md-5">
                        <div class="card border-0 bg-light rounded-4 text-center p-4">
                            <form asp-action="UploadAvatar" asp-controller="Account" method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                <label for="avatarUpload" class="cursor-pointer mb-3 position-relative d-inline-block">
                                    <div class="rounded-circle overflow-hidden border border-3 border-white shadow-sm" style="width: 120px; height: 120px; background: #fff;">
                                        @if (!string.IsNullOrEmpty(user?.AvatarUrl))
                                        {
                                            <img src="@user.AvatarUrl" class="w-100 h-100 object-fit-cover" alt="Avatar">
                                        }
                                        else
                                        {
                                            <img src="https://ui-avatars.com/api/?name=@(user?.FullName ?? user?.UserName)&background=random&size=120" class="w-100 h-100 object-fit-cover" alt="Avatar">
                                        }
                                    </div>
                                    <div class="position-absolute bottom-0 end-0 bg-dark text-white rounded-circle d-flex align-items-center justify-content-center border border-2 border-white" style="width: 32px; height: 32px; right: -5px; bottom: -5px;">
                                        <i class="fa-solid fa-camera small"></i>
                                    </div>
                                </label>
                                <input type="file" name="avatar" id="avatarUpload" class="d-none" accept="image/jpeg, image/png, image/webp" onchange="this.form.submit()">
                                <p class="text-muted small px-3 mb-0">Dung lượng file tới đa 2MB.<br>Định dạng: .JPEG, .PNG, .WEBP</p>
                            </form>
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == "security")
            {
                <div class="mb-5">
                    <h3 class="fw-bold text-dark mb-2" style="color: #0c1e36;">Bảo mật tài khoản</h3>
                    <p class="text-muted small" style="font-size: 14px;">Quản lý mật khẩu và cài đặt an toàn</p>
                </div>
                
                <div class="card border-0 border rounded-4 pt-1 shadow-sm mx-auto" style="border-color: #eaeaea !important; max-width: 500px;">
                    <div class="card-body p-4 p-md-5">
                        <form asp-action="ChangePassword" asp-controller="Account" method="post">
                            @Html.AntiForgeryToken()
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu hiện tại</label>
                                <div class="input-group">
                                    <input type="password" name="currentPassword" class="form-control bg-light border-0 py-2" required>
                                </div>
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu mới</label>
                                <div class="input-group">
                                    <input type="password" name="newPassword" class="form-control bg-light border-0 py-2" required minlength="8">
                                </div>
                                <div class="form-text small mt-2">Mật khẩu phải dài ít nhất 8 ký tự, bao gồm số và chữ cái.</div>
                            </div>
                            
                            <div class="mb-5">
                                <label class="form-label small fw-bold text-muted text-uppercase">Xác nhận mật khẩu mới</label>
                                <div class="input-group">
                                    <input type="password" name="confirmPassword" class="form-control bg-light border-0 py-2" required minlength="8">
                                </div>
                            </div>
                            
                            <button type="submit" class="btn btn-dark w-100 py-3 fw-bold rounded-pill text-uppercase" style="background-color: #0f3c83; letter-spacing: 0.5px;">Đổi mật khẩu</button>
                        </form>
                    </div>
                </div>
            }
            else if (activeTab == "address")
            {
                var addresses = (Model as IEnumerable<FashionStoreIS.Models.UserAddress>)?.ToList() ?? new List<FashionStoreIS.Models.UserAddress>();
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="fw-bold text-dark mb-1" style="color: #0c1e36;">Địa chỉ của tôi</h3>
                        <p class="text-muted small mb-0">Quản lý địa chỉ nhận hàng của bạn</p>
                    </div>
                    <button class="btn btn-dark btn-sm px-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                        <i class="fa-solid fa-plus me-1"></i> Thêm địa chỉ mới
                    </button>
                </div>

                <div class="row g-3">
                    @if (!addresses.Any())
                    {
                        <div class="col-12 text-center py-5 border rounded-4 bg-light">
                            <i class="fa-solid fa-map-location-dot mb-3 opacity-25" style="font-size: 48px;"></i>
                            <p class="text-muted">Bạn chưa có địa chỉ nào được lưu.</p>
                        </div>
                    }
                    @foreach (var addr in addresses)
                    {
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm rounded-4 h-100 @(addr.IsDefault ? "border-primary-subtle bg-primary-subtle bg-opacity-10" : "border")" style="border: 1px solid #eee !important;">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="fw-bold mb-0">@addr.FullName</h6>
                                        @if (addr.IsDefault)
                                        {
                                            <span class="badge bg-primary rounded-pill small" style="font-size: 10px; background-color: #0f3c83 !important;">Mặc định</span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-1"><i class="fa-solid fa-phone me-2 opacity-50"></i>@addr.PhoneNumber</p>
                                    <p class="text-dark small mb-3"><i class="fa-solid fa-location-dot me-2 opacity-50"></i>@addr.AddressLine</p>
                                    <div class="d-flex gap-2 mt-auto pt-2">
                                        @if (!addr.IsDefault)
                                        {
                                            <form asp-action="SetDefaultAddress" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@addr.Id" />
                                                <button type="submit" class="btn btn-link text-primary p-0 small text-decoration-none" style="font-size: 12px; color: #0f3c83 !important;">Thiết lập mặc định</button>
                                            </form>
                                            <span class="text-muted opacity-25">|</span>
                                        }
                                        <form asp-action="DeleteAddress" method="post" class="m-0" onsubmit="return confirm('Xóa địa chỉ này?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@addr.Id" />
                                            <button type="submit" class="btn btn-link text-danger p-0 small text-decoration-none" style="font-size: 12px;">Xóa</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Add Address Modal -->
                <div class="modal fade" id="addAddressModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 shadow rounded-4">
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title fw-bold">Thêm địa chỉ mới</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <form asp-action="AddAddress" method="post">
                                @Html.AntiForgeryToken()
                                <div class="modal-body p-4">
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Họ và tên người nhận</label>
                                        <input type="text" name="fullName" class="form-control bg-light border-0" required placeholder="Nhập tên người nhận">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Số điện thoại</label>
                                        <input type="tel" name="phoneNumber" class="form-control bg-light border-0" required placeholder="Nhập số điện thoại">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Địa chỉ chi tiết</label>
                                        <textarea name="addressLine" class="form-control bg-light border-0" rows="3" required placeholder="Số nhà, tên đường, phường/xã..."></textarea>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="isDefault" value="true" id="isDefaultCheck">
                                        <label class="form-check-label small" for="isDefaultCheck">Đặt làm địa chỉ mặc định</label>
                                    </div>
                                </div>
                                <div class="modal-footer border-0 pt-0">
                                    <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-toggle="modal">Hủy</button>
                                    <button type="submit" class="btn btn-dark px-4 rounded-pill" style="background-color: #0f3c83;">Hoàn thành</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == "returns")
            {
                var returns = (Model as IEnumerable<FashionStoreIS.Models.ReturnRequest>)?.ToList() ?? new List<FashionStoreIS.Models.ReturnRequest>();
                <div class="mb-5">
                    <h3 class="fw-bold text-dark mb-2" style="color: #0c1e36;">Trả hàng/Hoàn tiền</h3>
                    <p class="text-muted small" style="font-size: 14px;">Theo dõi các yêu cầu đổi trả sản phẩm</p>
                </div>

                @if (!returns.Any())
                {
                    <div class="empty-state border rounded-4 text-center py-5 px-3 mx-auto mt-4 w-100 shadow-sm" style="border-color: #eaeaea !important;">
                         <div class="empty-icon-circle mx-auto mb-4 d-flex align-items-center justify-content-center mt-3">
                            <i class="fa-solid fa-rotate-left profile-theme-icon" style="font-size: 24px;"></i>
                        </div>
                        <h5 class="fw-bold mb-3" style="color: #0c1e36;">Chưa có yêu cầu trả hàng</h5>
                        <p class="text-muted small mb-5 lh-lg mx-auto" style="max-width: 350px;">Lịch sử yêu cầu trả hàng hoặc hoàn tiền của bạn sẽ hiển thị tại đây.</p>
                        <a href="@Url.Action("Index", new { tab = "orders", status = "Completed" })" class="btn btn-theme-primary px-4 py-2 mb-3 fw-medium" style="font-size: 14px;">Tới danh sách đơn hàng &rarr;</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="bg-light">
                                <tr class="small text-uppercase text-muted">
                                    <th class="border-0 px-3 py-3">Đơn hàng</th>
                                    <th class="border-0 py-3">Lý do của bạn</th>
                                    <th class="border-0 py-3">Trạng thái</th>
                                    <th class="border-0 py-3">Phản hồi từ Shop</th>
                                    <th class="border-0 py-3">Ngày gửi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in returns)
                                {
                                    <tr>
                                        <td class="px-3 fw-bold">#@r.Order?.OrderCode</td>
                                        <td class="small text-truncate" style="max-width: 150px;">@r.Reason</td>
                                        <td>
                                            @{
                                                var rStatusClass = r.Status switch {
                                                    FashionStoreIS.Models.ReturnRequestStatus.Pending => "bg-warning text-dark",
                                                    FashionStoreIS.Models.ReturnRequestStatus.Approved => "bg-info text-white",
                                                    FashionStoreIS.Models.ReturnRequestStatus.Completed => "bg-success text-white",
                                                    FashionStoreIS.Models.ReturnRequestStatus.Rejected => "bg-danger text-white",
                                                    _ => "bg-secondary text-white"
                                                };
                                                var rStatusText = r.Status switch {
                                                    FashionStoreIS.Models.ReturnRequestStatus.Pending => "Chờ xử lý",
                                                    FashionStoreIS.Models.ReturnRequestStatus.Approved => "Đã duyệt",
                                                    FashionStoreIS.Models.ReturnRequestStatus.Completed => "Hoàn tất",
                                                    FashionStoreIS.Models.ReturnRequestStatus.Rejected => "Từ chối",
                                                    _ => r.Status.ToString()
                                                };
                                            }
                                            <span class="badge @rStatusClass rounded-pill px-3">@rStatusText</span>
                                        </td>
                                        <td class="small">
                                            @if (!string.IsNullOrEmpty(r.AdminNote))
                                            {
                                                <div class="text-primary fw-medium" style="max-width: 250px;">
                                                    <i class="fa-solid fa-comment-dots me-1"></i> @r.AdminNote
                                                </div>
                                            }
                                            else if (r.Status == FashionStoreIS.Models.ReturnRequestStatus.Pending)
                                            {
                                                <span class="text-muted italic">Đang chờ kiểm duyệt...</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-muted small">@r.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
            else if (activeTab == "promotions")
            {
                var vouchers = (Model as IEnumerable<FashionStoreIS.Models.Voucher>)?.ToList() ?? new List<FashionStoreIS.Models.Voucher>();
                <div class="mb-4">
                    <h3 class="fw-bold text-dark mb-2" style="color: #0c1e36;">Kho Voucher</h3>
                    <p class="text-muted small" style="font-size: 14px;">Khám phá các ưu đãi độc quyền dành riêng cho bạn</p>
                </div>

                <div class="row g-3">
                    @if (!vouchers.Any())
                    {
                        <div class="col-12 text-center py-5 border rounded-4 bg-light">
                            <i class="fa-solid fa-ticket mb-3 opacity-25" style="font-size: 48px;"></i>
                            <p class="text-muted">Hiện tại không có mã giảm giá khả dụng.</p>
                        </div>
                    }
                    @foreach (var v in vouchers)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="voucher-card position-relative d-flex bg-white border overflow-hidden rounded-3 shadow-sm" style="min-height: 110px;">
                                <div class="voucher-left d-flex flex-column align-items-center justify-content-center text-white px-2 text-center" style="width: 100px; background: linear-gradient(135deg, #0f3c83, #1e5bb8); border-right: 2px dashed #eee;">
                                    <i class="fa-solid fa-gift mb-2" style="font-size: 20px;"></i>
                                    <span class="small fw-bold">GIẢM GIÁ</span>
                                </div>
                                <div class="voucher-right p-3 flex-grow-1">
                                    <h6 class="fw-bold text-dark mb-1">@v.DiscountAmount.ToString("N0")₫</h6>
                                    <p class="text-muted small mb-2" style="font-size: 11px;">Mã: <span class="text-primary fw-bold">@v.Code</span></p>
                                    <div class="d-flex justify-content-between align-items-end mt-2">
                                        <span class="text-danger small fw-medium" style="font-size: 10px;">HSD: @v.ExpiryDate.ToString("dd/MM")</span>
                                        <button class="btn btn-sm btn-outline-primary py-0 px-2 rounded-pill" style="font-size: 10px;" onclick="copyCode('@v.Code')">Dùng ngay</button>
                                    </div>
                                </div>
                                <div class="voucher-cutout-top"></div>
                                <div class="voucher-cutout-bottom"></div>
                            </div>
                        </div>
                    }
                </div>
                <script>
                    function copyCode(code) {
                        navigator.clipboard.writeText(code);
                        alert("Đã copy mã: " + code + ". Sử dụng mã này khi thanh toán!");
                    }
                </script>
            }
            else if (activeTab == "notifications")
            {
                var notifications = (Model as IEnumerable<FashionStoreIS.Models.Notification>)?.ToList() ?? new List<FashionStoreIS.Models.Notification>();
                <div class="mb-4">
                    <h3 class="fw-bold text-dark mb-2" style="color: #0c1e36;">Thông báo</h3>
                    <p class="text-muted small" style="font-size: 14px;">Cập nhật những tin tức mới nhất từ BN Store</p>
                </div>

                <div class="list-group list-group-flush border rounded-4 overflow-hidden shadow-sm">
                    @if (!notifications.Any())
                    {
                        <div class="list-group-item text-center py-5 bg-light">
                            <i class="fa-solid fa-bell-slash mb-3 opacity-25" style="font-size: 48px;"></i>
                            <p class="text-muted small mb-0">Bạn chưa có thông báo nào.</p>
                        </div>
                    }
                    @foreach (var n in notifications)
                    {
                        <div class="list-group-item list-group-item-action p-4 @(n.IsRead ? "bg-white" : "bg-light")" style="border-left: 4px solid @(n.IsRead ? "transparent" : "#0f3c83")">
                            <div class="d-flex justify-content-between">
                                <h6 class="fw-bold mb-1 @(n.IsRead ? "text-dark" : "text-primary")">@n.Title</h6>
                                <small class="text-muted">@n.CreatedAt.ToString("dd/MM HH:mm")</small>
                            </div>
                            <p class="text-muted small mb-3">@n.Message</p>
                            <div class="d-flex gap-3">
                                @if (!n.IsRead)
                                {
                                    <form asp-action="MarkRead" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@n.Id" />
                                        <button type="submit" class="btn btn-link text-primary p-0 small text-decoration-none" style="font-size: 11px;">Đánh dấu đã đọc</button>
                                    </form>
                                }
                                <form asp-action="DeleteNotification" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@n.Id" />
                                    <button type="submit" class="btn btn-link text-danger p-0 small text-decoration-none" style="font-size: 11px;">Xóa</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    body { 
        background-color: #f8f9fa; /* slightly lighter gray to match image bg */
        font-family: 'Inter', sans-serif; 
    }
    
    .profile-container {
        min-height: 80vh;
        border-radius: 8px; /* Slightly more rounded */
    }
    
    .sidebar-pane {
        background-color: #fafbfc;
        border-top-left-radius: 8px;
        border-bottom-left-radius: 8px;
    }
    
    .content-pane {
        border-top-right-radius: 8px;
        border-bottom-right-radius: 8px;
    }

    .profile-name {
        color: #3b60b1;
        font-size: 15px;
        letter-spacing: 0.2px;
    }

    .rank-badge {
        background-color: #0f3c83;
        color: white;
        font-weight: 500;
        letter-spacing: 0.2px;
        font-size: 11px;
    }

    .sidebar-menu .list-group-item {
        background-color: transparent;
        border: none;
        padding: 13px 24px;
        color: #333;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .sidebar-menu .list-group-item:hover {
        background-color: #f1f3f8;
        color: #0f3c83;
    }

    .sidebar-menu .list-group-item.active {
        color: #0c1e36;
        background-color: transparent !important;
        font-weight: 700;
        /* No right border, the image doesn't show an active indicator on the right */
    }

    .sidebar-menu .menu-icon {
        color: #0f3c83; /* Matching the dark blue color from the image */
        font-size: 16px;
    }
    
    .sidebar-menu .list-group-item.active .menu-icon {
        color: #0f3c83;
    }

    .new-badge {
        background-color: #0f3c83;
        font-size: 10px;
        padding: 4px 8px;
    }

    /* Tab Navigation */
    .status-tabs .status-tab {
        color: #6c757d;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        padding: 12px 0;
        flex: 1;
        text-align: center;
        transition: all 0.2s ease;
        border-bottom: 2px solid transparent; /* default transparent border */
        margin-bottom: -1px; /* Overlap border-bottom */
    }

    .status-tabs .status-tab:hover {
        color: #0c1e36;
    }

    .status-tabs .status-tab.active {
        color: #0c1e36;
        border: 1px solid #c2cde7; /* The blue rectangular border */
        /* Make it look like a floating tab with a border */
        border-radius: 2px;
        font-weight: 600;
        background-color: transparent;
        border-bottom: 1px solid #c2cde7;
        padding: 9px 0; /* Add slight padding reduction to compensate border sizes */
    }

    /* Empty State */
    .empty-state {
        border-color: #eaebec !important; /* Very soft border */
        background-color: #fff;
    }

    .empty-icon-circle {
        width: 65px;
        height: 65px;
        background-color: #e5eef9; /* Light blue */
        border-radius: 50%;
    }

    .profile-theme-icon {
        color: #0f3c83;
    }

    .btn-theme-primary {
        background-color: #0f3c83;
        color: #fff;
        border-radius: 4px;
        transition: background-color 0.2s ease;
    }

    .btn-theme-primary:hover {
        background-color: #0a295c;
        color: #fff;
    }

    /* Animation */
    .animate__fadeIn { animation-duration: 0.5s; }

    /* Voucher Card Styling */
    .voucher-card {
        border-color: #eee !important;
        transition: transform 0.2s ease, shadow 0.2s ease;
    }
    .voucher-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }
    .voucher-cutout-top, .voucher-cutout-bottom {
        position: absolute;
        left: 90px;
        width: 20px;
        height: 20px;
        background-color: #fff; /* Matches card bg */
        border-radius: 50%;
        border: 1px solid #eee;
        z-index: 10;
    }
    .voucher-cutout-top { top: -10px; }
    .voucher-cutout-bottom { bottom: -10px; }

    /* Notification Styling */
    .list-group-item-action:hover {
        background-color: #f8f9fa !important;
    }

    /* Form control styling */
    .form-control:focus, .form-select:focus {
        box-shadow: none;
        background-color: #fff !important;
        border: 1px solid #0f3c83 !important;
    }
</style>

<script>
    function setReturnOrder(orderId) {
        document.getElementById('returnOrderId').value = orderId;
    }
</script>
