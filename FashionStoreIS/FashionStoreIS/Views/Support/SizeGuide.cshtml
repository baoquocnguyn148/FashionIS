@{
    ViewData["Title"] = "Bảng size - BN STORE";
}

<div class="page-container section-spacer">
    <div class="support-layout">
        <!-- Info Sidebar -->
        <div class="support-sidebar">
            <h1 class="support-title">BẢNG SIZE</h1>
            <p class="support-desc">Tìm kích cỡ hoàn hảo cho bạn. Hướng dẫn này cung cấp số đo trung bình cho các dòng sản phẩm của BN STORE.</p>
            
            <div class="contact-info-list">
                <div class="info-item">
                    <h5>LƯU Ý</h5>
                    <p>Mỗi sản phẩm có thể chênh lệch từ 1-2cm do quá trình đo đạc và cắt may.</p>
                </div>
            </div>
        </div>

        <!-- Size Charts -->
        <div class="support-content">
            <!-- Tops Chart -->
            <div class="size-section">
                <h3>BẢNG SIZE ÁO (T-SHIRT / HOODIE)</h3>
                <div class="table-responsive">
                    <table class="size-table">
                        <thead>
                            <tr>
                                <th>Size</th>
                                <th>Dài áo (cm)</th>
                                <th>Rộng áo (cm)</th>
                                <th>Chiều cao (cm)</th>
                                <th>Cân nặng (kg)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td>S</td><td>68</td><td>52</td><td>155-165</td><td>45-55</td></tr>
                            <tr><td>M</td><td>70</td><td>54</td><td>165-172</td><td>55-65</td></tr>
                            <tr><td>L</td><td>72</td><td>56</td><td>172-178</td><td>65-75</td></tr>
                            <tr><td>XL</td><td>74</td><td>58</td><td>178-185</td><td>75-90</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pants Chart -->
            <div class="size-section">
                <h3>BẢNG SIZE QUẦN (JEANS / SWEATPANTS)</h3>
                <div class="table-responsive">
                    <table class="size-table">
                        <thead>
                            <tr>
                                <th>Size</th>
                                <th>Chiều dài (cm)</th>
                                <th>Eo (cm)</th>
                                <th>Của quần (cm)</th>
                                <th>Cân nặng (kg)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td>S</td><td>96</td><td>72</td><td>24</td><td>45-55</td></tr>
                            <tr><td>M</td><td>98</td><td>76</td><td>25</td><td>55-65</td></tr>
                            <tr><td>L</td><td>100</td><td>80</td><td>26</td><td>65-75</td></tr>
                            <tr><td>XL</td><td>102</td><td>84</td><td>27</td><td>75-85</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <p class="size-footer">Nếu bạn cần tư vấn thêm, hãy <a href="/Support/Contact">Liên hệ với chúng tôi</a>.</p>
        </div>
    </div>
</div>

<style>
    .size-section { margin-bottom: 60px; }
    .size-section h3 { font-size: 14px; font-weight: 800; color: #111; margin-bottom: 20px; letter-spacing: 0.1em; }
    
    .size-table { width: 100%; border-collapse: collapse; border: 1px solid #eee; background: #fff; }
    .size-table th, .size-table td { 
        padding: 16px; text-align: center; border: 1px solid #eee; font-size: 14px; color: #444;
    }
    .size-table th { background: #f9f9f9; font-weight: 700; color: #111; }
    .size-table tr:hover td { background: #fafafa; }
    
    .size-footer { font-size: 14px; color: #888; text-align: center; border-top: 1px solid #eee; padding-top: 30px; margin-top: 40px; }
    .size-footer a { color: #111; font-weight: 700; text-decoration: underline; }
</style>
