@{
    ViewData["Title"] = "Liên hệ - BN STORE";
}

<div class="page-container section-spacer">
    <div class="support-layout">
        <!-- Info Sidebar -->
        <div class="support-sidebar">
            <h1 class="support-title">LIÊN HỆ</h1>
            <p class="support-desc">Gửi tin nhắn cho chúng tôi nếu bạn cần hỗ trợ hoặc có bất kỳ thắc mắc nào.</p>
            
            <div class="contact-info-list">
                <div class="info-item">
                    <h5>HOTLINE</h5>
                    <p>1900 0000 (9:00 - 22:00)</p>
                </div>
                <div class="info-item">
                    <h5>EMAIL</h5>
                    <p>support@bnstore.vn</p>
                </div>
                <div class="info-item">
                    <h5>HỆ THỐNG CỬA HÀNG</h5>
                    <p><strong>Quận 1:</strong> 123 Lê Lợi, Phường Bến Thành</p>
                    <p><strong>Quận 3:</strong> 456 Nguyễn Đình Chiểu, Phường 4</p>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="support-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            
            <form asp-action="Contact" method="post" class="contact-form">
                @Html.AntiForgeryToken()
                <div class="form-group mb-4">
                    <label>HỌ TÊN *</label>
                    <input type="text" name="name" class="form-control-minimal" placeholder="Nhập họ tên của bạn" required />
                </div>
                <div class="form-group mb-4">
                    <label>EMAIL *</label>
                    <input type="email" name="email" class="form-control-minimal" placeholder="email@example.com" required />
                </div>
                <div class="form-group mb-4">
                    <label>TIN NHẮN *</label>
                    <textarea name="message" class="form-control-minimal" rows="5" placeholder="Chúng tôi có thể giúp gì cho bạn?" required></textarea>
                </div>
                <button type="submit" class="btn-black-large">GỬI TIN NHẮN</button>
            </form>
        </div>
    </div>
</div>

<style>
    .support-layout { display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px; }
    .support-title { font-size: 32px; font-weight: 800; letter-spacing: 0.1em; margin-bottom: 20px; color: #111; }
    .support-desc { font-size: 15px; color: #666; line-height: 1.6; margin-bottom: 40px; }
    
    .info-item { margin-bottom: 30px; }
    .info-item h5 { font-size: 13px; font-weight: 700; color: #111; letter-spacing: 0.05em; margin-bottom: 10px; }
    .info-item p { font-size: 15px; color: #444; margin-bottom: 5px; }

    .contact-form { background: #fff; border: 1px solid #eee; padding: 40px; border-radius: 4px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
    .form-group label { display: block; font-size: 11px; font-weight: 700; color: #888; letter-spacing: 0.08em; margin-bottom: 10px; }
    
    .form-control-minimal {
        width: 100%; border: none; border-bottom: 1.5px solid #eee; padding: 12px 0; font-size: 14px;
        transition: all 0.3s; background: transparent; outline: none; border-radius: 0;
    }
    .form-control-minimal:focus { border-bottom-color: #111; }
    
    .btn-black-large {
        width: 100%; background: #111; color: white; border: none; padding: 18px; 
        font-size: 13px; font-weight: 700; letter-spacing: 0.15em; cursor: pointer;
        transition: background 0.3s; margin-top: 10px; border-radius: 4px;
    }
    .btn-black-large:hover { background: #333; }

    @@media (max-width: 991px) {
        .support-layout { grid-template-columns: 1fr; gap: 40px; }
    }
</style>
