@{
    ViewData["Title"] = "Chính sách đổi trả - BN STORE";
}

<div class="page-container section-spacer">
    <div class="support-layout">
        <!-- Info Sidebar -->
        <div class="support-sidebar">
            <h1 class="support-title">CHÍNH SÁCH ĐỔI TRẢ</h1>
            <p class="support-desc">Chúng tôi luôn đặt quyền lợi của khách hàng lên hàng đầu. BN STORE cam kết quy trình đổi trả minh bạch và thuận tiện.</p>
            
            <div class="contact-info-list">
                <div class="info-item">
                    <h5>THỜI GIAN ĐỔI TRẢ</h5>
                    <p>Trong vòng 7 ngày kể từ ngày nhận hàng thành công.</p>
                </div>
            </div>
        </div>

        <!-- Policy Content -->
        <div class="support-content content-rich">
            <section class="guide-step">
                <h3>ĐIỀU KIỆN ĐỔI TRẢ</h3>
                <ul class="policy-list">
                    <li>Sản phẩm còn nguyên nhãn mác, chưa qua sử dụng hoặc giặt là.</li>
                    <li>Sản phẩm không có mùi lạ, không bị hư hỏng do tác động bên ngoài.</li>
                    <li>Sản phẩm nằm trong chương trình cho phép đổi trả (Không áp dụng cho hàng Sale > 50%).</li>
                </ul>
            </section>

            <section class="guide-step">
                <h3>QUY TRÌNH ĐỔI TRẢ</h3>
                <p><strong>Cách 1: Đổi trực tiếp tại cửa hàng</strong><br/>Bạn có thể mang sản phẩm kèm hóa đơn đến địa chỉ quận 1 hoặc quận 3 để được hỗ trợ đổi size/mẫu trực tiếp.</p>
                <p><strong>Cách 2: Đổi qua dịch vụ vận chuyển</strong><br/>Gửi hàng về địa chỉ kho của BN STORE. Sau khi kiểm tra, chúng tôi sẽ gửi lại sản phẩm đổi cho bạn.</p>
            </section>

            <section class="guide-step">
                <h3>CHI PHÍ VẬN CHUYỂN</h3>
                <ul class="policy-list">
                    <li>Nếu lỗi do nhà sản xuất (rách, sai mẫu): BN STORE chịu 100% phí ship.</li>
                    <li>Nếu đổi theo nhu cầu khách hàng (size, màu): Khách hàng vui lòng thanh toán phí ship 2 chiều.</li>
                </ul>
            </section>

            <section class="guide-step">
                <h3>XỬ LÝ HOÀN TIỀN</h3>
                <p>BN STORE hỗ trợ hoàn tiền trong trường hợp sản phẩm hết size hoặc mẫu thay thế không còn. Thời gian xử lý từ 3-5 ngày làm việc qua tài khoản ngân hàng.</p>
            </section>
        </div>
    </div>
</div>

<style>
    .policy-list { padding-left: 20px; list-style-type: disc; margin-bottom: 20px; }
    .policy-list li { font-size: 15px; margin-bottom: 8px; color: #555; }
</style>
