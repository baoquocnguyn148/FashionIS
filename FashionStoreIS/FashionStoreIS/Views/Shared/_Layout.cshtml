<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="BN STORE - DREAMERS ONLY" />
    <title>@ViewData["Title"] - BN STORE</title>
    @{
        var antiforgery = Context.RequestServices.GetService(typeof(Microsoft.AspNetCore.Antiforgery.IAntiforgery)) as Microsoft.AspNetCore.Antiforgery.IAntiforgery;
        var csrfToken = antiforgery?.GetAndStoreTokens(Context).RequestToken;
    }
    @if (!string.IsNullOrEmpty(csrfToken))
    {
        <meta name="csrf-token" content="@csrfToken" />
    }

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/stylevibe-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ui-polish.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Announcement Bar ─────────────────────── -->
    <div class="announcement-bar">
        <div class="marquee">
            <span>◆ TOÀN BỘ CỬA HÀNG ◆</span>
            <span>BN STORE — FOR DREAMERS ONLY</span>
            <span>◆ GIẢM GIÁ ĐẾN 50% TOÀN BỘ CỬA HÀNG ◆</span>
            <span>BN STORE — FOR DREAMERS ONLY</span>
            <span>◆ GIẢM GIÁ ĐẾN 50% ◆</span>
        </div>
    </div>

    <!-- ── Site Header ───────────────────────────── -->
    <header class="site-header">
        <div class="header-inner">
            <!-- Left -->
            <div class="header-left">
                <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menu">
                    <span></span><span></span><span></span>
                </button>
            </div>

            <!-- Center: Logo -->
            <div class="header-logo text-center">
                <a asp-controller="Home" asp-action="Index">
                    <span class="logo-stars">★★★</span>&nbsp;BN STORE
                </a>
            </div>

            <!-- Right: Icons -->
            <div class="header-right">
                <div class="d-none d-md-flex align-items-center gap-2 search-wrapper">
                    <input id="headerSearchInput" class="form-control form-control-sm search-input" type="search" placeholder="Tìm sản phẩm..." />
                    <button id="headerSearchBtn" type="button" class="header-icon-btn search-toggle-btn" aria-label="Tìm kiếm">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                    </button>
                </div>
                
                <style>
                    .search-wrapper {
                        position: relative;
                        display: flex;
                        align-items: center;
                    }
                    .search-input {
                        width: 0;
                        padding: 0;
                        border: none;
                        overflow: hidden;
                        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                        opacity: 0;
                        background: rgba(0,0,0,0.03);
                        border-radius: 20px;
                    }
                    .search-input.active {
                        width: 240px;
                        padding: 6px 15px;
                        border: 1px solid #ddd;
                        opacity: 1;
                        margin-right: 10px;
                    }
                    .search-toggle-btn {
                        z-index: 2;
                    }
                </style>

                @* ─── Wishlist Icon (chỉ hiển thị khi đã đăng nhập) ─── *@
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Wishlist" class="header-icon-btn d-none d-md-flex" aria-label="Danh sách yêu thích" id="wishlistNavBtn" title="Yêu thích" style="position:relative;">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                        <span class="wl-nav-badge" id="wlNavBadge" style="display:none">0</span>
                    </a>
                    <style>
                    .wl-nav-badge {
                        position: absolute;
                        top: 2px;
                        right: 2px;
                        background: #e74c3c;
                        color: white;
                        font-size: 11px;
                        font-weight: 600;
                        min-width: 18px;
                        height: 18px;
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        padding: 0 5px;
                    }
                    </style>
                }

                <button type="button" class="header-cart-btn" id="openCart" aria-label="Giỏ hàng" onclick="showCart()">

                    <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 01-8 0"/>
                    </svg>
                    <span class="cart-badge" id="cartBadge" style="display:none">0</span>
                </button>
                
                <style>
                    .header-cart-btn {
                        background: transparent;
                        border: none;
                        cursor: pointer;
                        padding: 10px;
                        border-radius: 50%;
                        transition: all 0.3s ease;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        position: relative;
                        color: #333;
                    }
                    .header-cart-btn:hover {
                        background: rgba(0,0,0,0.08);
                        transform: scale(1.05);
                    }
                    .header-cart-btn:active {
                        transform: scale(0.95);
                    }
                    .cart-badge {
                        position: absolute;
                        top: 2px;
                        right: 2px;
                        background: #e74c3c;
                        color: white;
                        font-size: 11px;
                        font-weight: 600;
                        min-width: 18px;
                        height: 18px;
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        padding: 0 5px;
                    }
                </style>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Index" class="header-icon-btn d-none d-md-flex" aria-label="Tài khoản">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="header-icon-btn d-none d-md-flex" aria-label="Đăng nhập">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </a>
                }
            </div>
        </div>
    </header>

    <!-- ── Mobile Menu ───────────────────────────── -->
    <div class="drawer-overlay" id="drawerOverlay"></div>
    <div class="nav-drawer" id="navDrawer">
        <div class="drawer-header">
            <span class="drawer-title">MENU</span>
            <button class="close-drawer-btn" id="closeDrawerBtn">✕</button>
        </div>
        
        <!-- Mobile Search Bar -->
        <div class="p-3 border-bottom d-md-none">
            <div class="input-group">
                <input type="search" id="mobileSearchInput" class="form-control form-control-sm border-end-0" placeholder="Tìm sản phẩm..." style="border-radius: 20px 0 0 20px; font-size: 14px;" />
                <button class="btn border border-start-0" type="button" id="mobileSearchBtn" style="border-radius: 0 20px 20px 0; background: white;">
                    <i class="fas fa-search text-muted"></i>
                </button>
            </div>
        </div>
        
        <ul class="drawer-menu">
            <li><a href="/" class="menu-link">TRANG CHỦ</a></li>
            <li class="has-submenu">
                <div class="menu-link d-flex justify-content-between align-items-center" onclick="toggleMobileSubmenu(this)" style="cursor: pointer;">
                    <span>SẢN PHẨM</span>
                    <i class="fas fa-chevron-down submenu-icon" style="transition: transform 0.3s; font-size: 14px;"></i>
                </div>
                <ul class="drawer-submenu" style="display: none; padding-left: 0; list-style: none; margin: 0; background-color: #fcfcfc;">
                    <li><a href="/Product/List" class="menu-link" style="font-size: 13px; padding: 12px 30px; border-bottom: 1px solid #f0f0f0;">TẤT CẢ SẢN PHẨM</a></li>
                    <li><a href="/Product/List?cat=tops" class="menu-link" style="font-size: 13px; padding: 12px 30px; border-bottom: 1px solid #f0f0f0;">ÁO</a></li>
                    <li><a href="/Product/List?cat=pants" class="menu-link" style="font-size: 13px; padding: 12px 30px; border-bottom: 1px solid #f0f0f0;">QUẦN</a></li>
                    <li><a href="/Product/List?cat=outerwear" class="menu-link" style="font-size: 13px; padding: 12px 30px; border-bottom: 1px solid #f0f0f0;">ÁO KHOÁC</a></li>
                    <li><a href="/Product/List?cat=footwear" class="menu-link" style="font-size: 13px; padding: 12px 30px; border-bottom: 1px solid #f0f0f0;">GIÀY & DÉP</a></li>
                    <li><a href="/Product/List?cat=dresses" class="menu-link" style="font-size: 13px; padding: 12px 30px; border-bottom: 1px solid #f0f0f0;">VÁY & ĐẦM</a></li>
                    <li><a href="/Product/List?cat=accessories" class="menu-link" style="font-size: 13px; padding: 12px 30px;">PHỤ KIỆN</a></li>
                </ul>
            </li>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li><a href="/Account" class="menu-link">TÀI KHOẢN</a></li>
                <li><a href="/Wishlist" class="menu-link">YÊU THÍCH <span id="mobileWlBadge" class=""></span></a></li>
                @if (User.IsInRole("SuperAdmin"))
                {
                    <li><a href="/Admin/Dashboard" class="menu-link" style="color:var(--sv-gray-text)">QUẢN TRỊ VIÊN</a></li>
                }
                @if (User.IsInRole("Staff"))
                {
                    <li><a href="/EmployeePortal" class="menu-link" style="color:#2ecc71; font-weight:700;">★ CỔNG NHÂN VIÊN</a></li>
                }
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" id="logoutFormDrawer">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="menu-link" style="background:none; border:none; width:100%; text-align:left; cursor:pointer;">ĐĂNG XUẤT</button>
                    </form>
                </li>
            }
        </ul>
        <script>
            function toggleMobileSubmenu(element) {
                var submenu = element.nextElementSibling;
                var icon = element.querySelector('.submenu-icon');
                if (submenu.style.display === "none" || submenu.style.display === "") {
                    // jQuery slideDown equivalent for smooth transition if needed, but display block is fine for now
                    submenu.style.display = "block";
                    icon.style.transform = "rotate(180deg)";
                } else {
                    submenu.style.display = "none";
                    icon.style.transform = "rotate(0deg)";
                }
            }
        </script>
    </div>

    <!-- ── Cart Drawer ───────────────────────────── -->
    <div id="cartDrawer" class="cart-panel">
        <div class="cart-panel-header">
            <h3 class="cart-title">Giỏ hàng của bạn</h3>
            <button id="closeCart" class="cart-close-btn" aria-label="Đóng giỏ hàng">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div id="cartContent" class="cart-panel-content"></div>
    </div>

    <!-- CART STYLES - NO BLUR -->
    <style>
        /* Cart Panel - NO backdrop overlay */
        .cart-panel {
            position: fixed;
            top: 0;
            right: -420px;
            width: 420px;
            max-width: 90vw;
            height: 100vh;
            background: #ffffff;
            z-index: 9999;
            transition: right 0.3s ease;
            display: flex;
            flex-direction: column;
            box-shadow: -5px 0 30px rgba(0,0,0,0.1);
        }
        
        .cart-panel.open {
            right: 0;
        }
        
        .cart-panel-header {
            padding: 20px 24px;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #fff;
        }
        
        .cart-title {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a1a;
            margin: 0;
        }
        
        .cart-close-btn {
            background: #f5f5f5;
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666;
        }
        
        .cart-close-btn:hover {
            background: #e8e8e8;
            color: #333;
        }
        
        .cart-panel-content {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            background: #fafafa;
        }
        
        /* Cart Items */
        .cart-item {
            background: #fff;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            gap: 14px;
        }
        
        .cart-item-image {
            width: 80px;
            height: 100px;
            border-radius: 8px;
            overflow: hidden;
            flex-shrink: 0;
        }
        
        .cart-item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .cart-item-details {
            flex: 1;
        }
        
        .cart-item-name {
            font-size: 15px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 4px;
        }
        
        .cart-item-price {
            font-size: 15px;
            font-weight: 700;
            color: #e74c3c;
            margin-bottom: 8px;
        }
        
        .cart-item-meta {
            font-size: 13px;
            color: #666;
            margin-bottom: 12px;
        }
        
        .quantity-control {
            display: flex;
            align-items: center;
            border: 1px solid #ddd;
            border-radius: 6px;
            overflow: hidden;
            width: fit-content;
        }
        
        .qty-btn {
            background: #fff;
            border: none;
            width: 32px;
            height: 32px;
            cursor: pointer;
            font-size: 16px;
            color: #333;
        }
        
        .qty-btn:hover {
            background: #f5f5f5;
        }
        
        .qty-value {
            min-width: 36px;
            text-align: center;
            font-size: 14px;
            font-weight: 600;
        }
        
        .remove-btn {
            background: none;
            border: none;
            color: #999;
            font-size: 13px;
            cursor: pointer;
            padding: 4px 8px;
            margin-top: 8px;
        }
        
        .remove-btn:hover {
            color: #e74c3c;
        }
        
        /* Empty Cart */
        .cart-empty {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }
        
        .cart-empty-icon {
            width: 80px;
            height: 80px;
            background: #f0f0f0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        
        .cart-empty-icon svg {
            width: 40px;
            height: 40px;
            stroke: #aaa;
        }
        
        .cart-empty-text {
            font-size: 16px;
            margin-bottom: 20px;
        }
        
        .continue-shopping {
            display: inline-block;
            padding: 12px 24px;
            background: #333;
            color: #fff;
            text-decoration: none;
            border-radius: 6px;
        }
        
        .continue-shopping:hover {
            background: #555;
            color: #fff;
        }
        
        /* Cart Footer */
        .cart-footer {
            padding: 20px 24px;
            border-top: 1px solid #eee;
            background: #fff;
        }
        
        .cart-total {
            display: flex;
            justify-content: space-between;
            margin-bottom: 16px;
            font-size: 16px;
        }
        
        .cart-total-value {
            font-size: 20px;
            font-weight: 700;
            color: #e74c3c;
        }
        
        .checkout-btn {
            width: 100%;
            padding: 16px;
            background: #333;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
        }
        
        .checkout-btn:hover {
            background: #555;
        }
    </style>

    <!-- ── Main Content ──────────────────────────── -->
    <main role="main">
        @RenderBody()
    </main>

    <style>
        .chatbot-widget {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 10000;
        }
        .chatbot-toggle-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: #1a1a1a;
            color: #fff;
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.3s ease;
        }
        .chatbot-toggle-btn:hover {
            transform: scale(1.05);
        }
        .chatbot-panel {
            position: absolute;
            bottom: 80px;
            right: 0;
            width: 350px;
            height: 500px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.15);
            display: none;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid #eee;
        }
        .chatbot-panel.open {
            display: flex;
            animation: slideUp 0.3s ease forwards;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .chatbot-header {
            background: #1a1a1a;
            color: #fff;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .chatbot-close-btn {
            background: none;
            border: none;
            color: #fff;
            font-size: 24px;
            cursor: pointer;
            line-height: 1;
        }
        .chatbot-messages {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            background: #fafafa;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .chat-msg {
            max-width: 85%;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 14px;
            line-height: 1.5;
            word-wrap: break-word;
        }
        .bot-msg {
            background: #ffffff;
            color: #333;
            align-self: flex-start;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            border: 1px solid #f0f0f0;
        }
        .user-msg {
            background: #1a1a1a;
            color: #fff;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }
        .chat-img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
            margin: 8px 0;
            display: block;
            border: 1px solid #eee;
        }
        .chat-link {
            display: inline-block;
            margin-top: 8px;
            padding: 6px 12px;
            background: #1a1a1a;
            color: #fff !important;
            text-decoration: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-align: center;
            transition: opacity 0.2s;
        }
        .chat-link:hover {
            opacity: 0.8;
            color: #fff;
        }
        .chat-product-title {
            font-weight: 700;
            display: block;
            margin-bottom: 4px;
            color: #1a1a1a;
        }
        .typing-indicator {
            display: flex;
            gap: 4px;
            padding: 12px 14px;
            background: #eef2f5;
            border-radius: 12px;
            border-bottom-left-radius: 4px;
            align-self: flex-start;
            width: fit-content;
        }
        .typing-indicator span {
            width: 6px;
            height: 6px;
            background: #999;
            border-radius: 50%;
            animation: typing 1.4s infinite ease-in-out both;
        }
        .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
        .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }
        @@keyframes typing {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }
        .chatbot-input-area {
            display: flex;
            padding: 15px;
            background: #fff;
            border-top: 1px solid #eee;
            gap: 10px;
        }
        .chatbot-input-area input {
            flex: 1;
            border: 1px solid #ddd;
            border-radius: 20px;
            padding: 8px 15px;
            font-size: 14px;
            outline: none;
            transition: border-color 0.3s;
        }
        .chatbot-input-area input:focus {
            border-color: #333;
        }
        .chatbot-input-area button {
            background: #333;
            color: #fff;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.3s;
            flex-shrink: 0;
        }
        .chatbot-input-area button:hover {
            background: #555;
        }
        @@media (max-width: 480px) {
            .chatbot-panel {
                width: calc(100vw - 48px);
                height: 400px;
            }
        }
    </style>

    <!-- ── Chatbot Widget ───────────────────────────── -->
    <div id="chatbot-widget" class="chatbot-widget">
        <button id="chatbot-toggle-btn" class="chatbot-toggle-btn" aria-label="Open Chat">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
        </button>
        <div id="chatbot-panel" class="chatbot-panel">
            <div class="chatbot-header">
                <div>
                    <h4 style="margin: 0; font-size: 16px; font-weight: 600;">Trợ lý mua sắm AI</h4>
