    <!-- CART SCRIPT - NO blur -->
    <script>
        $(document).ready(function() {
            // Search toggle
            $('#headerSearchBtn').on('click', function(e) {
                const $input = $('#headerSearchInput');
                if ($input.val().trim() !== "" && $input.hasClass('active')) {
                    // If there's text and it's active, perform search
                    window.location.href = '/Product/List?q=' + encodeURIComponent($input.val().trim());
                } else {
                    // Otherwise just toggle
                    $input.toggleClass('active');
                    if ($input.hasClass('active')) {
                        $input.focus();
                    }
                }
            });

            // Close search when clicking outside
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.search-wrapper').length) {
                    $('#headerSearchInput').removeClass('active');
                }
            });

            // Enter key to search
            $('#headerSearchInput').on('keypress', function(e) {
                if (e.which === 13) {
                    const val = $(this).val().trim();
                    if (val !== "") {
                        window.location.href = '/Product/List?q=' + encodeURIComponent(val);
                    }
                }
            });

            // Mobile Search
            function executeMobileSearch() {
                const val = $('#mobileSearchInput').val().trim();
                if (val !== "") {
                    window.location.href = '/Product/List?q=' + encodeURIComponent(val);
                }
            }
            $('#mobileSearchBtn').on('click', executeMobileSearch);
            $('#mobileSearchInput').on('keypress', function(e) {
                if (e.which === 13) executeMobileSearch();
            });

            const $drawer = $('#cartDrawer');
            const $content = $('#cartContent');
            
            // Define global functions for other pages to call
            window.updateCartCount = function() {
                $.get('/Cart/GetCartCount', function(data) {
                    const count = data.count || 0;
                    $('#cartBadge').text(count).toggle(count > 0);
                });
            };
            
            window.loadCartContent = function() {
                $.get('/Cart/GetCartDrawer', function(data) {
                    $content.html(data);
                    window.updateCartCount();
                }).fail(function() {
                    $content.html('<div class="cart-empty"><div class="cart-empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></div><div class="cart-empty-text">Giỏ hàng trống</div><a href="/Product/List" class="continue-shopping">Tiếp tục mua sắm</a></div>');
                });
            };

            window.showCart = function() {
                $drawer.addClass('open');
                $('body').css('overflow', 'hidden');
                window.loadCartContent();
            };

            // Event listeners
            $('#openCart').on('click', window.showCart);
            
            // Update quantity (+/-)
            $(document).on('click', '.qty-btn', function() {
                const $btn = $(this);
                const productId = $btn.data('product-id');
                const color = $btn.data('color') || '';
                const size = $btn.data('size') || '';
                const delta = parseInt($btn.data('delta'));
                
                // Get anti-forgery token
                const token = $('meta[name="csrf-token"]').attr('content');
                
                $.post('/Cart/UpdateQuantity', {
                    productId: productId,
                    color: color,
                    size: size,
                    delta: delta,
                    __RequestVerificationToken: token
                }, function(data) {
                    $content.html(data);
                    updateCartCount();
                }).fail(function() {
                    alert('Có lỗi xảy ra, vui lòng thử lại!');
                });
            });
            
            // Remove item
            $(document).on('click', '.remove-btn', function() {
                const $btn = $(this);
                const productId = $btn.data('product-id');
                const color = $btn.data('color') || '';
                const size = $btn.data('size') || '';
                
                // Get anti-forgery token
                const token = $('meta[name="csrf-token"]').attr('content');
                
                if (confirm('Bạn có chắc muốn xóa sản phẩm này?')) {
                    $.post('/Cart/RemoveFromCart', {
                        productId: productId,
                        color: color,
                        size: size,
                        __RequestVerificationToken: token
                    }, function(data) {
                        $content.html(data);
                        updateCartCount();
                    }).fail(function() {
                        alert('Có lỗi xảy ra, vui lòng thử lại!');
                    });
                }
            });
            
            // Close cart
            function closeCart() {
                $drawer.removeClass('open');
                $('body').css('overflow', '');
            }
            
            $('#closeCart').on('click', closeCart);
            
            // ESC key
            $(document).on('keydown', function(e) {
                if (e.key === 'Escape' && $drawer.hasClass('open')) {
                    closeCart();
                }
            });
            
            // Initial cart count
            updateCartCount();

            @if (User.Identity?.IsAuthenticated == true)
            {
                <text>
            // Load wishlist count khi page load → cập nhật badge trên navbar
            $.get('/Wishlist/GetWishlistIds', function(data) {
                if (data && data.count > 0) {
                    var badge = document.getElementById('wlNavBadge');
                    if (badge) { badge.textContent = data.count; badge.style.display = 'flex'; }
                    var mobileBadge = document.getElementById('mobileWlBadge');
                    if (mobileBadge) {
                        mobileBadge.textContent = ' (' + data.count + ')';
                        mobileBadge.style.color = '#e74c3c';
                        mobileBadge.style.fontWeight = '700';
                    }
                }
            });
                </text>
            }
        });
    </script>
    
    <!-- Chatbot Script -->
    <script>
        $(document).ready(function() {
            const $toggleBtn = $('#chatbot-toggle-btn');
            const $panel = $('#chatbot-panel');
            const $closeBtn = $('#chatbot-close-btn');
            const $messages = $('#chatbot-messages');
            const $input = $('#chatbot-input');
            const $sendBtn = $('#chatbot-send-btn');
            
            let chatHistory = [];
            
            $toggleBtn.on('click', function() {
                $panel.toggleClass('open');
                if ($panel.hasClass('open')) {
                    $input.focus();
                }
            });
            
            $closeBtn.on('click', function() {
                $panel.removeClass('open');
            });
            
            function scrollToBottom() {
                $messages.scrollTop($messages[0].scrollHeight);
            }
            
            function formatMarkdown(text) {
                if (!text) return "";
                
                // 1. Process Product Cards: Custom format detection
                // Matches roughly: ### **[Name]** \n 💰 **[Price] VNĐ** | [🛒 Xem chi tiết](url)
                const productRegex = /###\s*\*\*\[?(.*?)\]?\*\*\s*\n\s*💰\s*\*\*([\d,.]+)\s*VNĐ\*\*\s*\|\s*\[🛒.*?\]\((.*?)\)/gi;
                let match;
                while ((match = productRegex.exec(text)) !== null) {
                    const [fullMatch, name, price, url] = match;
                    // Find image if it exists before or after this block
                    let imageUrl = "";
                    const imgMatch = text.match(/!\[.*?\]\((.*?)\)/);
                    if (imgMatch) imageUrl = imgMatch[1];

                    const cardHtml = `
                        <div class="chat-product-card">
                            <div class="chat-img-wrapper">
                                <img src="${imageUrl}" class="chat-img" onerror="this.src='/images/placeholder.jpg'">
                                <div class="chat-price-badge">${price} đ</div>
                            </div>
                            <div class="chat-product-info">
                                <span class="chat-product-title">${name}</span>
                                <a href="${url}" target="_blank" class="chat-view-btn">XEM CHI TIẾT</a>
                            </div>
                        </div>
                    `;
                    text = text.replace(fullMatch, cardHtml);
                }

                // Clean up remaining markdown
                text = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                text = text.replace(/!\[(.*?)\]\((.*?)\)/g, ''); // Hide raw images as they're now in cards
                text = text.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank" class="chat-link">$1</a>');
                text = text.replace(/\n/g, '<br/>');
                
                return text;
            }
            
            function appendMessage(role, content) {
                const msgClass = role === 'user' ? 'user-msg' : 'bot-msg';
                const formattedContent = role === 'assistant' ? formatMarkdown(content) : content;
                
                const $msgDiv = $('<div>').addClass('chat-msg ' + msgClass).html(formattedContent);
                
                // Staggered fade in
                $msgDiv.css('animation-delay', (role === 'assistant' ? '0.2s' : '0s'));
                
                $messages.append($msgDiv);
                scrollToBottom();
            }
            
            function appendTypingIndicator() {
                const $typingDiv = $('<div>').addClass('typing-indicator').attr('id', 'typing-indicator')
                    .append('<span></span><span></span><span></span>');
                $messages.append($typingDiv);
                scrollToBottom();
            }
            
            function removeTypingIndicator() {
                $('#typing-indicator').remove();
            }
            
            function sendMessage() {
                const text = $input.val().trim();
                if (!text) return;
                
                appendMessage('user', text);
                $input.val('');
                $input.prop('disabled', true);
                $sendBtn.prop('disabled', true);
                
                appendTypingIndicator();
                
                const payload = {
                    message: text,
                    history: chatHistory
                };
                
                chatHistory.push({ role: 'user', content: text });
                
                // Forward message to backend proxy instead of hardcoded localhost
                $.ajax({
                    url: '/Chat/Message',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    timeout: 60000, 
                    success: function(response) {
                        removeTypingIndicator();
                        const botReply = response.response;
                        appendMessage('assistant', botReply);
                        chatHistory.push({ role: 'assistant', content: botReply });
                    },
                    error: function(xhr, status, error) {
                        removeTypingIndicator();
                        let errorMsg = 'Xin lỗi, hệ thống AI đang tạm thời gián đoạn. ';
                        
                        // Use specific error message from server if available
                        if (xhr.responseJSON && xhr.responseJSON.error) {
                            errorMsg = xhr.responseJSON.error;
                        } else if (xhr.status === 502 || xhr.status === 504) {
                            errorMsg += 'Có vẻ máy chủ đang "khởi động" lại sau thời gian nghỉ. Bạn vui lòng đợi 15-30 giây rồi thử gửi lại tin nhắn nhé! ✨';
                        } else if (xhr.status === 429) {
                            errorMsg += 'Hệ thống đang xử lý quá nhiều yêu cầu. Bạn vui lòng đợi một chút rồi thử lại nhé!';
                        } else {
                            errorMsg += 'Vui lòng kiểm tra kết nối mạng hoặc thử lại sau ít phút.';
                        }
                        appendMessage('assistant', errorMsg);
                    },
                    complete: function() {
                        $input.prop('disabled', false);
                        $sendBtn.prop('disabled', false);
                        $input.focus();
                    }
                });
            }
            
            $sendBtn.on('click', sendMessage);
            
            $input.on('keypress', function(e) {
                if (e.which === 13) {
                    sendMessage();
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
