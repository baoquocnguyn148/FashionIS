<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="BN STORE - DREAMERS ONLY" />
    <title>@ViewData["Title"] - BN STORE</title>
    @{
        var antiforgery = Context.RequestServices.GetService(typeof(Microsoft.AspNetCore.Antiforgery.IAntiforgery)) as Microsoft.AspNetCore.Antiforgery.IAntiforgery;
        var csrfToken = antiforgery?.GetAndStoreTokens(Context).RequestToken;
    }
    @if (!string.IsNullOrEmpty(csrfToken))
    {
        <meta name="csrf-token" content="@csrfToken" />
    }

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/stylevibe-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ui-polish.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Announcement Bar ─────────────────────── -->
    <div class="announcement-bar">
        <div class="marquee">
            <span>◆ TOÀN BỘ CỬA HÀNG ◆</span>
            <span>BN STORE — FOR DREAMERS ONLY</span>
            <span>◆ GIẢM GIÁ ĐẾN 50% TOÀN BỘ CỬA HÀNG ◆</span>
            <span>BN STORE — FOR DREAMERS ONLY</span>
            <span>◆ GIẢM GIÁ ĐẾN 50% ◆</span>
        </div>
    </div>

    <!-- ── Site Header ───────────────────────────── -->
    <header class="site-header">
        <div class="header-inner">
            <!-- Left -->
            <div class="header-left">
                <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menu">
                    <span></span><span></span><span></span>
                </button>
            </div>

            <!-- Center: Logo -->
            <div class="header-logo text-center">
                <a asp-controller="Home" asp-action="Index">
                    <span class="logo-stars">★★★</span>&nbsp;BN STORE
                </a>
            </div>

            <!-- Right: Icons -->
            <div class="header-right">
                <div class="d-none d-md-flex align-items-center gap-2">
                    <input id="headerSearchInput" class="form-control form-control-sm" type="search" placeholder="Tìm sản phẩm..." />
                    <button id="headerSearchBtn" type="button" class="header-icon-btn" aria-label="Tìm kiếm">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                    </button>
                </div>
                <button type="button" class="header-cart-btn" id="openCart" aria-label="Giỏ hàng" onclick="showCart()">
                    <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 01-8 0"/>
                    </svg>
                    <span class="cart-badge" id="cartBadge" style="display:none">0</span>
                </button>
                
                <style>
                    .header-cart-btn {
                        background: transparent;
                        border: none;
                        cursor: pointer;
                        padding: 10px;
                        border-radius: 50%;
                        transition: all 0.3s ease;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        position: relative;
                        color: #333;
                    }
                    .header-cart-btn:hover {
                        background: rgba(0,0,0,0.08);
                        transform: scale(1.05);
                    }
                    .header-cart-btn:active {
                        transform: scale(0.95);
                    }
                    .cart-badge {
                        position: absolute;
                        top: 2px;
                        right: 2px;
                        background: #e74c3c;
                        color: white;
                        font-size: 11px;
                        font-weight: 600;
                        min-width: 18px;
                        height: 18px;
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        padding: 0 5px;
                    }
                </style>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Index" class="header-icon-btn d-none d-md-flex" aria-label="Tài khoản">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="header-icon-btn d-none d-md-flex" aria-label="Đăng nhập">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </a>
                }
            </div>
        </div>
    </header>

    <!-- ── Mobile Menu ───────────────────────────── -->
    <div class="drawer-overlay" id="drawerOverlay"></div>
    <div class="nav-drawer" id="navDrawer">
        <div class="drawer-header">
            <span class="drawer-title">MENU</span>
            <button class="close-drawer-btn" id="closeDrawerBtn">✕</button>
        </div>
        <ul class="drawer-menu">
            <li><a href="/" class="menu-link">TRANG CHỦ</a></li>
            <li><a href="/Product/List" class="menu-link">SẢN PHẨM</a></li>
            <li><a href="/Product/List?cat=tops" class="menu-link">ÁO</a></li>
            <li><a href="/Product/List?cat=pants" class="menu-link">QUẦN</a></li>
            <li><a href="/Product/List?cat=accessories" class="menu-link">PHỤ KIỆN</a></li>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li><a href="/Account" class="menu-link">TÀI KHOẢN</a></li>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Staff"))
                {
                    <li><a href="/Admin/Dashboard" class="menu-link" style="color:var(--sv-gray-text)">QUẢN TRỊ</a></li>
                }
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" id="logoutForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="menu-link" style="background:none; border:none; width:100%; text-align:left; cursor:pointer;">ĐĂNG XUẤT</button>
                    </form>
                </li>
            }
            else
            {
                <li><a href="/Identity/Account/Login" class="menu-link">ĐĂNG NHẬP</a></li>
                <li><a href="/Identity/Account/Register" class="menu-link">ĐĂNG KÝ</a></li>
            }
        </ul>
    </div>

    <!-- ── Cart Drawer ───────────────────────────── -->
    <div id="cartDrawer" class="cart-panel">
        <div class="cart-panel-header">
            <h3 class="cart-title">Giỏ hàng của bạn</h3>
            <button id="closeCart" class="cart-close-btn" aria-label="Đóng giỏ hàng">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div id="cartContent" class="cart-panel-content"></div>
    </div>

    <!-- CART STYLES - NO BLUR -->
    <style>
        /* Cart Panel - NO backdrop overlay */
        .cart-panel {
            position: fixed;
            top: 0;
            right: -420px;
            width: 420px;
            max-width: 90vw;
            height: 100vh;
            background: #ffffff;
            z-index: 9999;
            transition: right 0.3s ease;
            display: flex;
            flex-direction: column;
            box-shadow: -5px 0 30px rgba(0,0,0,0.1);
        }
        
        .cart-panel.open {
            right: 0;
        }
        
        .cart-panel-header {
            padding: 20px 24px;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #fff;
        }
        
        .cart-title {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a1a;
            margin: 0;
        }
        
        .cart-close-btn {
            background: #f5f5f5;
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666;
        }
        
        .cart-close-btn:hover {
            background: #e8e8e8;
            color: #333;
        }
        
        .cart-panel-content {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            background: #fafafa;
        }
        
        /* Cart Items */
        .cart-item {
            background: #fff;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            gap: 14px;
        }
        
        .cart-item-image {
            width: 80px;
            height: 100px;
            border-radius: 8px;
            overflow: hidden;
            flex-shrink: 0;
        }
        
        .cart-item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .cart-item-details {
            flex: 1;
        }
        
        .cart-item-name {
            font-size: 15px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 4px;
        }
        
        .cart-item-price {
            font-size: 15px;
            font-weight: 700;
            color: #e74c3c;
            margin-bottom: 8px;
        }
        
        .cart-item-meta {
            font-size: 13px;
            color: #666;
            margin-bottom: 12px;
        }
        
        .quantity-control {
            display: flex;
            align-items: center;
            border: 1px solid #ddd;
            border-radius: 6px;
            overflow: hidden;
            width: fit-content;
        }
        
        .qty-btn {
            background: #fff;
            border: none;
            width: 32px;
            height: 32px;
            cursor: pointer;
            font-size: 16px;
            color: #333;
        }
        
        .qty-btn:hover {
            background: #f5f5f5;
        }
        
        .qty-value {
            min-width: 36px;
            text-align: center;
            font-size: 14px;
            font-weight: 600;
        }
        
        .remove-btn {
            background: none;
            border: none;
            color: #999;
            font-size: 13px;
            cursor: pointer;
            padding: 4px 8px;
            margin-top: 8px;
        }
        
        .remove-btn:hover {
            color: #e74c3c;
        }
        
        /* Empty Cart */
        .cart-empty {
            text-align: center;
            padding: 60px 20px;
            color: #666;
        }
        
        .cart-empty-icon {
            width: 80px;
            height: 80px;
            background: #f0f0f0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        
        .cart-empty-icon svg {
            width: 40px;
            height: 40px;
            stroke: #aaa;
        }
        
        .cart-empty-text {
            font-size: 16px;
            margin-bottom: 20px;
        }
        
        .continue-shopping {
            display: inline-block;
            padding: 12px 24px;
            background: #333;
            color: #fff;
            text-decoration: none;
            border-radius: 6px;
        }
        
        .continue-shopping:hover {
            background: #555;
            color: #fff;
        }
        
        /* Cart Footer */
        .cart-footer {
            padding: 20px 24px;
            border-top: 1px solid #eee;
            background: #fff;
        }
        
        .cart-total {
            display: flex;
            justify-content: space-between;
            margin-bottom: 16px;
            font-size: 16px;
        }
        
        .cart-total-value {
            font-size: 20px;
            font-weight: 700;
            color: #e74c3c;
        }
        
        .checkout-btn {
            width: 100%;
            padding: 16px;
            background: #333;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
        }
        
        .checkout-btn:hover {
            background: #555;
        }
    </style>

    <!-- ── Main Content ──────────────────────────── -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- ── Site Footer ───────────────────────────── -->
    <footer class="site-footer">
        <div class="page-container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a class="logo">★★★ BN STORE</a>
                    <p>Chuỗi thời trang premium dành cho giới trẻ Việt Nam. Chất lượng – Phong cách – Tự tin.</p>
                </div>
                <div class="footer-col">
                    <h4>Khám phá</h4>
                    <ul>
                        <li><a href="/Product/List">Tất cả sản phẩm</a></li>
                        <li><a href="/Product/List?cat=tops">Áo</a></li>
                        <li><a href="/Product/List?cat=pants">Quần</a></li>
                        <li><a href="/Product/List?cat=accessories">Phụ kiện</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Hỗ trợ</h4>
                    <ul>
                        <li><a href="#">Hướng dẫn mua hàng</a></li>
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Bảng size</a></li>
                        <li><a href="#">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Cửa hàng</h4>
                    <ul>
                        <li><a href="#">BN STORE Quận 1</a></li>
                        <li><a href="#">BN STORE Quận 3</a></li>
                        <li><a href="/Admin/Dashboard">Khu vực quản trị</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>&copy; 2026 BN STORE. All rights reserved.</span>
                <span>Dreamers Only.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- CART SCRIPT - NO blur -->
    <script>
        $(document).ready(function() {
            const $drawer = $('#cartDrawer');
            const $content = $('#cartContent');
            
            // Open cart
            $('#openCart').on('click', function() {
                $drawer.addClass('open');
                $('body').css('overflow', 'hidden');
                loadCartContent();
            });
            
            // Load cart content function
            function loadCartContent() {
                $.get('/Cart/GetCartDrawer', function(data) {
                    $content.html(data);
                    updateCartCount();
                }).fail(function() {
                    $content.html('<div class="cart-empty"><div class="cart-empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></div><div class="cart-empty-text">Giỏ hàng trống</div><a href="/Product/List" class="continue-shopping">Tiếp tục mua sắm</a></div>');
                });
            }
            
            // Update cart count badge
            function updateCartCount() {
                $.get('/Cart/GetCartCount', function(data) {
                    const count = data.count || 0;
                    $('#cartBadge').text(count).toggle(count > 0);
                });
            }
            
            // Update quantity (+/-)
            $(document).on('click', '.qty-btn', function() {
                const $btn = $(this);
                const productId = $btn.data('product-id');
                const color = $btn.data('color') || '';
                const size = $btn.data('size') || '';
                const delta = parseInt($btn.data('delta'));
                
                // Get anti-forgery token
                const token = $('meta[name="csrf-token"]').attr('content');
                
                $.post('/Cart/UpdateQuantity', {
                    productId: productId,
                    color: color,
                    size: size,
                    delta: delta,
                    __RequestVerificationToken: token
                }, function(data) {
                    $content.html(data);
                    updateCartCount();
                }).fail(function() {
                    alert('Có lỗi xảy ra, vui lòng thử lại!');
                });
            });
            
            // Remove item
            $(document).on('click', '.remove-btn', function() {
                const $btn = $(this);
                const productId = $btn.data('product-id');
                const color = $btn.data('color') || '';
                const size = $btn.data('size') || '';
                
                // Get anti-forgery token
                const token = $('meta[name="csrf-token"]').attr('content');
                
                if (confirm('Bạn có chắc muốn xóa sản phẩm này?')) {
                    $.post('/Cart/RemoveFromCart', {
                        productId: productId,
                        color: color,
                        size: size,
                        __RequestVerificationToken: token
                    }, function(data) {
                        $content.html(data);
                        updateCartCount();
                    }).fail(function() {
                        alert('Có lỗi xảy ra, vui lòng thử lại!');
                    });
                }
            });
            
            // Close cart
            function closeCart() {
                $drawer.removeClass('open');
                $('body').css('overflow', '');
            }
            
            $('#closeCart').on('click', closeCart);
            
            // ESC key
            $(document).on('keydown', function(e) {
                if (e.key === 'Escape' && $drawer.hasClass('open')) {
                    closeCart();
                }
            });
            
            // Initial cart count
            updateCartCount();
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
