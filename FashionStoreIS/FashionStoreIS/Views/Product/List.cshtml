@model List<FashionStoreIS.Models.Product>
@{
    ViewData["Title"] = ViewBag.CategoryTitle;
}

<div class="page-container" style="margin-top: 40px;">
    <!-- Breadcrumb -->
    <div class="pdp-breadcrumb" style="margin-bottom: 30px;">
        <a href="/">Home</a> / 
        @if (ViewBag.CurrentCat != null && ViewBag.CurrentCat != "all-products")
        {
            <a href="/Product/List">Collection</a> <span> / </span>
        }
        <span>@ViewBag.CategoryTitle</span>
    </div>

    <div class="collection-layout">
        <!-- Sidebar -->
        <aside class="filter-sidebar">
            <div class="filter-group collapsed">
                <div class="filter-title">
                    COLOR
                    <span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </span>
                </div>
                <div class="filter-content">
                    @{
                        var currentColor = ViewBag.CurrentColor as string;
                        var colors = ViewBag.AvailableColors as List<string> ?? new List<string>();
                        string ColorSwatch(string c)
                        {
                            var key = (c ?? "").Trim().ToLowerInvariant();
                            return key switch
                            {
                                "black" => "#111111",
                                "white" => "#ffffff",
                                "navy" => "#0b1f3a",
                                "blue" => "#1f6feb",
                                "red" => "#e11d48",
                                "green" => "#15803d",
                                "brown" => "#7c4a2d",
                                "beige" => "#e7d7c1",
                                "gray" => "#9ca3af",
                                "grey" => "#9ca3af",
                                _ => "#dddddd"
                            };
                        }
                    }
                    @if (colors.Count == 0)
                    {
                        <p class="filter-placeholder-text">Đang cập nhật...</p>
                    }
                    else
                    {
                        <div class="filter-color-grid">
                            @foreach (var c in colors)
                            {
                                <button type="button" class="color-btn @(string.Equals(currentColor, c, StringComparison.OrdinalIgnoreCase) ? "active" : "")" data-color="@c">
                                    <span class="color-swatch" style="background:@ColorSwatch(c)"></span>
                                    <span class="color-name">@c</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="filter-group collapsed">
                <div class="filter-title">
                    SIZE
                    <span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </span>
                </div>
                <div class="filter-content">
                    <div class="filter-size-grid">
                        @{
                            var currentSize = ViewBag.CurrentSize as string;
                            var sizes = new[] { "S", "M", "L", "XL" };
                        }
                        @foreach (var s in sizes)
                        {
                            <button type="button" class="size-btn @(string.Equals(currentSize, s, StringComparison.OrdinalIgnoreCase) ? "active" : "")" data-size="@s">@s</button>
                        }
                    </div>
                </div>
            </div>

            <div class="filter-group collapsed">
                <div class="filter-title">
                    PRICE
                    <span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </span>
                </div>
                <div class="filter-content">
                    <div class="price-input-container">
                        <div class="price-input-item">
                            <label>TỐI THIỂU</label>
                            <input type="number" id="minPriceInput" placeholder="VND" value="@ViewBag.MinPrice" />
                        </div>
                        <div class="price-input-separator">-</div>
                        <div class="price-input-item">
                            <label>TỐI ĐA</label>
                            <input type="number" id="maxPriceInput" placeholder="VND" value="@ViewBag.MaxPrice" />
                        </div>
                    </div>
                    <div class="price-quick-btns">
                        <button type="button" class="btn-quick-price" onclick="setQuickPrice(0, 500000)">0 - 500K</button>
                        <button type="button" class="btn-quick-price" onclick="setQuickPrice(500000, 1000000)">500K - 1M</button>
                    </div>
                    <button class="btn-pdp btn-primary btn-sm w-100 mt-3" id="applyPriceFilter">ÁP DỤNG</button>
                </div>
            </div>
        </aside>

        <!-- Product Grid -->
        <main class="product-main">
            <div class="product-grid-header">
                <div class="product-count">@Model.Count sản phẩm</div>
                <div class="sort-area" style="display: flex; align-items: center; gap: 10px;">
                    <span style="font-size: 12px; color: #888;">Sắp xếp:</span>
                        <select class="sort-select">
                        <option value="newest" selected="@(ViewBag.CurrentSort == "newest")">Mới nhất</option>
                        <option value="price-asc" selected="@(ViewBag.CurrentSort == "price-asc")">Giá tăng dần</option>
                        <option value="price-desc" selected="@(ViewBag.CurrentSort == "price-desc")">Giá giảm dần</option>
                    </select>
                </div>
            </div>

            @if (Model.Any())
            {
                <div class="product-grid">
                    @foreach (var p in Model)
                    {
                        <div class="product-card-bn" onclick="window.location.href='/Product/Detail/@p.Id'">
                            <div class="product-image-bn">
                                @if (p.Stock <= 0)
                                {
                                    <div class="sold-out-badge">SOLD OUT</div>
                                }
                                <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "https://placehold.co/600x720/333/fff?text=NO+IMAGE" : p.ImageUrl)" alt="@p.Name" loading="lazy" />
                            </div>
                            <div class="product-info-bn">
                                <div class="product-title-bn">@p.Name</div>
                                <div class="product-price-bn">@p.Price.ToString("N0") VND</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <p style="color: #888;">Không tìm thấy sản phẩm nào.</p>
                </div>
            }
        </main>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        $('#applyPriceFilter').click(function() {
            updateFilters();
        });

        $('.sort-select').on('change', function() {
            updateFilters();
        });

        $('.size-btn').on('click', function() {
            const size = $(this).data('size');
            const urlParams = new URLSearchParams(window.location.search);
            const current = urlParams.get('size');
            if (size && current && current.toLowerCase() === String(size).toLowerCase()) urlParams.delete('size');
            else if (size) urlParams.set('size', size);
            else urlParams.delete('size');
            window.location.href = window.location.pathname + '?' + urlParams.toString();
        });
        
        $('.color-btn').on('click', function() {
            const color = $(this).data('color');
            const urlParams = new URLSearchParams(window.location.search);
            const current = urlParams.get('color');
            if (color && current && current.toLowerCase() === String(color).toLowerCase()) urlParams.delete('color');
            else if (color) urlParams.set('color', color);
            else urlParams.delete('color');
            window.location.href = window.location.pathname + '?' + urlParams.toString();
        });

        window.setQuickPrice = function(min, max) {
            $('#minPriceInput').val(min);
            $('#maxPriceInput').val(max);
            updateFilters();
        }

        function updateFilters() {
            const urlParams = new URLSearchParams(window.location.search);
            const minPrice = $('#minPriceInput').val();
            const maxPrice = $('#maxPriceInput').val();
            const sort = $('.sort-select').val();

            if (minPrice) urlParams.set('minPrice', minPrice); else urlParams.delete('minPrice');
            if (maxPrice) urlParams.set('maxPrice', maxPrice); else urlParams.delete('maxPrice');
            if (sort) urlParams.set('sort', sort); else urlParams.delete('sort');

            // Keep category and query
            window.location.href = window.location.pathname + '?' + urlParams.toString();
        }
    });
</script>
}

