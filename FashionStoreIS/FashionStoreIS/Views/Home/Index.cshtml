@{
    ViewData["Title"] = "BN STORE - DREAMERS ONLY";
    var banner = ViewBag.HeroBanner as FashionStoreIS.Models.Banner;
}

<!-- ── Hero Section ──────────────────────────────────── -->
<section class="hero-section" style="background-image: url('/images/banners/hero-main.png'); background-size: cover; background-position: center;">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <p class="hero-subtitle">NEW COLLECTION 2026</p>
        <a href="/Product/List" class="hero-btn">XEM SẢN PHẨM</a>
    </div>
</section>

<!-- ── Category Banners ─────────────────────────────── -->
<div class="page-container section-spacer">
    <div class="row g-4">
        <!-- Category 1 -->
        <div class="col-md-4">
            <div class="category-card" style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.4)), url('/images/banners/cat-tops.png') center/cover;">
                <div class="category-content">
                    <h3>ÁO</h3>
                    <a href="/Product/List?cat=tops" class="btn-minimal">XEM NGAY</a>
                </div>
            </div>
        </div>
        <!-- Category 2 -->
        <div class="col-md-4">
            <div class="category-card" style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.4)), url('/images/banners/cat-bottoms.png') center/cover;">
                <div class="category-content">
                    <h3>QUẦN</h3>
                    <a href="/Product/List?cat=pants" class="btn-minimal">XEM NGAY</a>
                </div>
            </div>
        </div>
        <!-- Category 3 -->
        <div class="col-md-4">
            <div class="category-card" style="background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.4)), url('/images/banners/cat-acc.png') center/cover;">
                <div class="category-content">
                    <h3>PHỤ KIỆN</h3>
                    <a href="/Product/List?cat=accessories" class="btn-minimal">XEM NGAY</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .category-card {
        height: 600px;
        position: relative;
        display: flex;
        align-items: flex-end;
        padding: 40px;
        overflow: hidden;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 4px;
    }
    .category-card:hover { transform: scale(0.99); }
    .category-content h3 {
        color: white;
        font-size: 28px;
        font-weight: 800;
        letter-spacing: 0.1em;
        margin-bottom: 15px;
        text-transform: uppercase;
    }
    .btn-minimal {
        display: inline-block;
        color: white;
        border-bottom: 2px solid white;
        padding-bottom: 4px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.15em;
        transition: all 0.3s;
        text-decoration: none;
    }
    .btn-minimal:hover { 
        color: white;
        padding-left: 10px;
        border-bottom-color: rgba(255,255,255,0.5);
    }
</style>
