## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
bin/
obj/

# Visual Studio cache
.vs/

# .NET & EF
*.log
*.txt.bak
build_*.log
build_*.txt
msbuild.log
startup.log
tmp_*.cs

# Database & Secrets
App_Data/*.db
App_Data/*.db-journal
appsettings.Development.json

# OS
.DS_Store
Thumbs.db

# Secrets
.env
chatbot/.env
**/bin/
**/obj/
**/publish/
