@{
    ViewData["Title"] = "Hoàn thiện hồ sơ";
}

<div class="page-container" style="padding:80px 0">
    <div class="card border-0 shadow mx-auto" style="max-width: 480px; border-radius: 0;">
        <div class="card-body p-5">
            <h2 class="fw-900 text-center mb-4" style="letter-spacing: 0.05em;">CHÀO MỪNG BẠN!</h2>
            <p class="text-muted text-center mb-4">Vui lòng hoàn thiện thông tin để bắt đầu mua sắm và tích điểm loyalty tại StyleVibe.</p>

            <form method="post">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label class="form-label small fw-bold text-uppercase">Họ và tên</label>
                    <input type="text" name="fullName" class="form-control" required placeholder="Nhập họ tên đầy đủ" />
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-uppercase">Số điện thoại</label>
                    <input type="tel" name="phone" class="form-control" required placeholder="Ví dụ: 0901234567" />
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState["phone"]?.Errors.Any() == true)
                    {
                        <span class="text-danger small">@ViewData.ModelState["phone"]?.Errors[0].ErrorMessage</span>
                    }
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase">Địa chỉ giao hàng mặc định</label>
                    <textarea name="address" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường/xã, quận/huyện..."></textarea>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold" style="letter-spacing: 0.1em;">
                    HOÀN TẤT & TIẾP TỤC
                </button>
            </form>
        </div>
    </div>
</div>
