@model List<StyleVibe.Domain.Entities.Order>
@using StyleVibe.Domain.Enums
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="page-container" style="padding:48px 0 80px">
    <div class="row g-4">
        <div class="col-lg-3">
            <div class="card p-4 border-0 shadow-sm rounded-0">
                <div class="list-group list-group-flush">
                    <a href="/Account/Index" class="list-group-item list-group-item-action border-0">Tổng quan</a>
                    <a href="/Account/Orders" class="list-group-item list-group-item-action active border-0">Đơn hàng của tôi</a>
                    <a href="/Account/Loyalty" class="list-group-item list-group-item-action border-0">Điểm thưởng</a>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <h4 class="fw-bold mb-4">Đơn hàng của tôi</h4>
            
            <div class="card border-0 shadow-sm rounded-0">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Cửa hàng</th>
                                <th class="text-end">Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@o.OrderCode</td>
                                    <td>@o.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>@o.Store?.Name</td>
                                    <td class="text-end fw-bold">@o.TotalAmount.ToString("N0")₫</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@o.Status</span>
                                    </td>
                                    <td class="text-end">
                                        <a href="/Account/OrderDetail/@o.Id" class="btn btn-sm btn-outline-dark">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr><td colspan="6" class="text-center py-4 text-muted">Bạn chưa có đơn hàng nào.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination pagination-sm justify-content-center">
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" href="/Account/Orders?page=@i">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
