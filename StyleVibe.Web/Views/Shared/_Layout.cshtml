<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="StyleVibe Fashion – Chuỗi thời trang premium tại Việt Nam" />
    <title>@ViewData["Title"] - StyleVibe</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/stylevibe-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Announcement Bar ─────────────────────── -->
    <div class="announcement-bar">
        <div class="marquee">
            <span>✦ MIỄN PHÍ VẬN CHUYỂN ĐƠN HÀNG TRÊN 500.000đ</span>
            <span>✦ STYLEVIBE FASHION — PREMIUM STREETWEAR</span>
            <span>✦ ĐỔI TRẢ MIỄN PHÍ TRONG 30 NGÀY</span>
            <span>✦ MIỄN PHÍ VẬN CHUYỂN ĐƠN HÀNG TRÊN 500.000đ</span>
            <span>✦ STYLEVIBE FASHION — PREMIUM STREETWEAR</span>
            <span>✦ ĐỔI TRẢ MIỄN PHÍ TRONG 30 NGÀY</span>
        </div>
    </div>

    <!-- ── Site Header ───────────────────────────── -->
    <header class="site-header">
        <div class="header-inner">
            <!-- Left -->
            <div class="header-left">
                <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menu">
                    <span></span><span></span><span></span>
                </button>
                <nav>
                    <ul class="header-nav-links d-none d-lg-flex">
                        <li><a asp-controller="Products" asp-action="Index">Sản phẩm</a></li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                        {
                            <li><a asp-controller="Pos" asp-action="Index" style="color:var(--sv-danger); font-weight:700">POS</a></li>
                        }
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="1">Áo</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="2">Quần</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="5">Phụ kiện</a></li>
                    </ul>
                </nav>
            </div>

            <!-- Center: Logo -->
            <div class="header-logo text-center">
                <a asp-controller="Home" asp-action="Index">
                    <span class="logo-stars">★★</span>&nbsp;STYLEVIBE
                </a>
            </div>

            <!-- Right: Icons -->
            <div class="header-right">
                <a href="#" class="header-icon-btn d-none d-md-flex" aria-label="Tìm kiếm" id="searchToggle">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </a>
                <a asp-controller="Cart" asp-action="Index" class="header-icon-btn" aria-label="Giỏ hàng">
                    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 01-8 0"/>
                    </svg>
                    <span class="cart-badge" id="cartBadge" style="display:none">0</span>
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Index" class="header-icon-btn d-none d-md-flex" aria-label="Tài khoản">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="header-icon-btn d-none d-md-flex" aria-label="Đăng nhập">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </a>
                }
            </div>
        </div>
    </header>

    <div id="searchBar" style="display:none;position:fixed;top:0;left:0;right:0; 
         background:white;z-index:9999;padding:16px 24px; 
         box-shadow:0 2px 16px rgba(0,0,0,0.1);">
        <form asp-controller="Products" asp-action="Index" method="get"
              class="d-flex align-items-center gap-3" style="max-width:640px;margin:0 auto">
            <input type="text" name="search" autofocus
                   placeholder="Tìm kiếm sản phẩm..."
                   class="form-control" style="font-size:16px;border:none; 
                   border-bottom:2px solid #222;border-radius:0;padding:8px 0;" />
            <button type="submit" class="btn" style="background:none;border:none;padding:0">
                <svg width="22" height="22" fill="none" stroke="currentColor"
                     stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </button>
            <button type="button" onclick="toggleSearch()"
                    style="background:none;border:none;font-size:20px;cursor:pointer">✕</button>
        </form>
    </div>

    <!-- ── Mobile Menu ───────────────────────────── -->
    <div class="mobile-menu-overlay" id="mobileOverlay"></div>
    <div class="mobile-menu" id="mobileMenu">
        <button class="mobile-menu-close" id="mobileMenuClose">✕</button>
        <ul>
            <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li><a asp-controller="Products" asp-action="Index">Tất cả sản phẩm</a></li>
            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
            {
                <li><a asp-controller="Pos" asp-action="Index" style="color:var(--sv-danger); font-weight:700">🏧 Bán tại quầy (POS)</a></li>
            }
            <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="1">Áo</a></li>
            <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="2">Quần</a></li>
            <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="3">Váy</a></li>
            <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="4">Áo khoác</a></li>
            <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="5">Phụ kiện</a></li>
            <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li><a asp-area="Identity" asp-page="/Account/Manage/Index">Tài khoản</a></li>
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="margin:0">
                        <button type="submit" style="background:none;border:none;padding:14px 0;font-weight:700;font-size:14px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;width:100%;text-align:left;border-bottom:1px solid #e0e0e0;">Đăng xuất</button>
                    </form>
                </li>
            }
            else
            {
                <li><a asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a></li>
                <li><a asp-area="Identity" asp-page="/Account/Register">Đăng ký</a></li>
            }
        </ul>
    </div>

    <!-- ── Main Content ──────────────────────────── -->
    <main role="main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="page-container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="page-container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <!-- ── Site Footer ───────────────────────────── -->
    <footer class="site-footer">
        <div class="page-container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a class="logo">★★ STYLEVIBE</a>
                    <p>Chuỗi thời trang premium dành cho giới trẻ Việt Nam. Chất lượng – Phong cách – Tự tin.</p>
                </div>
                <div class="footer-col">
                    <h4>Khám phá</h4>
                    <ul>
                        <li><a asp-controller="Products" asp-action="Index">Tất cả sản phẩm</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="1">Áo</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="2">Quần</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-categoryId="4">Áo khoác</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Hỗ trợ</h4>
                    <ul>
                        <li><a href="#">Hướng dẫn mua hàng</a></li>
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Bảng size</a></li>
                        <li><a href="#">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Cửa hàng</h4>
                    <ul>
                        <li><a href="#">StyleVibe Quận 1</a></li>
                        <li><a href="#">StyleVibe Bình Thạnh</a></li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                        {
                            <li><a asp-controller="Pos" asp-action="Index">Bán tại quầy (POS)</a></li>
                        }
                        <li><a asp-controller="Admin" asp-action="Dashboard">Quản trị</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>&copy; 2026 StyleVibe Fashion. All rights reserved.</span>
                <span>ITE1129E — UEF B01E</span>
            </div>
        </div>
    </footer>

    <!-- Scroll to top -->
    <button class="scroll-top-btn" id="scrollTopBtn" aria-label="Lên đầu trang">↑</button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Mobile menu
        const hamburger = document.getElementById('hamburgerBtn');
        const overlay   = document.getElementById('mobileOverlay');
        const mobileMenu= document.getElementById('mobileMenu');
        const closeBtn  = document.getElementById('mobileMenuClose');

        function openMenu()  { mobileMenu.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow='hidden'; }
        function closeMenu() { mobileMenu.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow=''; }

        hamburger?.addEventListener('click', openMenu);
        overlay?.addEventListener('click', closeMenu);
        closeBtn?.addEventListener('click', closeMenu);

        // Scroll to top
        const scrollBtn = document.getElementById('scrollTopBtn');
        window.addEventListener('scroll', () => {
            scrollBtn?.classList.toggle('visible', window.scrollY > 400);
        });
        scrollBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // Init cart badge from localStorage
        function updateCartBadge() {
            const cart = JSON.parse(localStorage.getItem('cart') || '[]');
            const total = cart.reduce((a, b) => a + b.quantity, 0);
            const badge = document.getElementById('cartBadge');
            if (badge) {
                if (total > 0) {
                    badge.textContent = total;
                    badge.style.display = 'flex';
                }
                else {
                    badge.style.display = 'none';
                }
            }
        }

        function toggleSearch() {
            const bar = document.getElementById('searchBar');
            const isVisible = bar.style.display !== 'none';
            bar.style.display = isVisible ? 'none' : 'flex';
            if (!isVisible) bar.querySelector('input').focus();
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateCartBadge();
            
            document.getElementById('searchToggle')?.addEventListener('click', (e) => {
                e.preventDefault();
                toggleSearch();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
