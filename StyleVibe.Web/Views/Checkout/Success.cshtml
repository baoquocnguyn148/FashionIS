@model StyleVibe.Domain.Entities.Order
@{
    ViewData["Title"] = "Đặt hàng thành công – StyleVibe";
}
<div class="page-container" style="padding:80px 0;text-align:center">
    <div style="font-size:3rem;margin-bottom:16px">✓</div>
    <h1 style="font-size:1.5rem;font-weight:900;letter-spacing:0.06em;margin-bottom:8px">
        ĐẶT HÀNG THÀNH CÔNG!
    </h1>
    <p style="color:var(--sv-gray-text);margin-bottom:32px">
        Mã đơn hàng: <strong>@Model.OrderCode</strong>
    </p>
    <div class="card p-4 mx-auto" style="max-width:520px;text-align:left">
        <h5 class="mb-3">Chi tiết đơn hàng</h5>
        <p><strong>Cửa hàng:</strong> @Model.Store?.Name</p>
        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
        <hr/>
        @foreach (var item in Model.OrderDetails)
        {
            <div class="d-flex justify-content-between mb-1">
                <span>@item.ProductSku?.Product?.Name (@item.ProductSku?.Size / @item.ProductSku?.Color) × @item.Quantity</span>
                <span>@item.Subtotal.ToString("N0")₫</span>
            </div>
        }
        <hr/>
        <div class="d-flex justify-content-between fw-bold">
            <span>Tổng cộng</span>
            <span>@Model.TotalAmount.ToString("N0")₫</span>
        </div>
        @if (Model.PointsEarned > 0)
        {
            <p class="text-success mt-2 mb-0" style="font-size:13px">
                ✦ Bạn đã tích được @Model.PointsEarned điểm loyalty!
            </p>
        }
    </div>
    <div class="d-flex gap-3 justify-content-center mt-4">
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary px-4">
            Tiếp tục mua sắm
        </a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Account" asp-action="Orders" class="btn btn-outline-primary px-4">
                Xem đơn hàng của tôi
            </a>
        }
    </div>
</div>
