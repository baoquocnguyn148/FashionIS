@{
    ViewData["Title"] = "Thanh toán – StyleVibe";
    var stores = ViewBag.Stores as IEnumerable<StyleVibe.Domain.Entities.Store> ?? [];
    var customer = ViewBag.Customer as StyleVibe.Domain.Entities.Customer;
}

<div class="page-container" style="padding:48px 0 80px">
    <h1 style="font-size:1.5rem;font-weight:900;letter-spacing:0.06em;margin-bottom:32px">
        XÁC NHẬN ĐƠN HÀNG
    </h1>

    <form method="post" asp-action="ProcessOrder" id="checkoutForm">
        @Html.AntiForgeryToken()
        
        <!-- Hidden fields for cart data -->
        <input type="hidden" name="itemsJson" id="hiddenItemsJson" />

        <div class="row g-4">
            <!-- Thông tin giao hàng -->
            <div class="col-lg-7">
                <div class="card p-4 mb-4">
                    <h5 class="mb-3">Thông tin nhận hàng</h5>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:12px;letter-spacing:0.06em;text-transform:uppercase">
                            Họ và tên *
                        </label>
                        <input type="text" class="form-control" name="customerName" 
                               value="@(customer?.FullName ?? "")" required 
                               placeholder="Nguyễn Văn A" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label" style="font-size:12px;letter-spacing:0.06em;text-transform:uppercase">
                                Số điện thoại *
                            </label>
                            <input type="tel" class="form-control" name="phone" 
                                   value="@(customer?.Phone ?? "")" required 
                                   placeholder="0901234567" />
                        </div>
                        <div class="col-6">
                            <label class="form-label" style="font-size:12px;letter-spacing:0.06em;text-transform:uppercase">
                                Email (không bắt buộc)
                            </label>
                            <input type="email" class="form-control" 
                                   value="@(customer?.Email ?? "")" 
                                   placeholder="email@example.com" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:12px;letter-spacing:0.06em;text-transform:uppercase">
                            Địa chỉ nhận hàng *
                        </label>
                        <input type="text" class="form-control" name="address" 
                               value="@(customer?.Address ?? "")" required 
                               placeholder="Số nhà, tên đường, phường/xã..." />
                    </div>
                    <div>
                        <label class="form-label" style="font-size:12px;letter-spacing:0.06em;text-transform:uppercase">
                            Ghi chú đơn hàng (tùy chọn)
                        </label>
                        <textarea class="form-control" name="note" rows="2" 
                                  placeholder="Ghi chú cho người giao hàng..."></textarea>
                    </div>
                </div>

                <div class="card p-4 mb-4">
                    <h5 class="mb-3">Chọn cửa hàng nhận hàng</h5>
                    <select name="storeId" id="storeSelect" class="form-select">
                        @foreach (var store in stores)
                        {
                            <option value="@store.Id">@store.Name — @store.Address</option>
                        }
                    </select>
                </div>

                <div class="card p-4">
                    <h5 class="mb-3">Phương thức thanh toán</h5>
                    <div class="d-flex flex-column gap-2">
                        <label class="d-flex align-items-center gap-2 p-3 border rounded" style="cursor:pointer">
                            <input type="radio" name="paymentMethod" value="1" checked /> Thanh toán khi nhận hàng (COD)
                        </label>
                        <label class="d-flex align-items-center gap-2 p-3 border rounded" style="cursor:pointer">
                            <input type="radio" name="paymentMethod" value="2" /> Chuyển khoản ngân hàng
                        </label>
                        <label class="d-flex align-items-center gap-2 p-3 border rounded" style="cursor:pointer">
                            <input type="radio" name="paymentMethod" value="3" /> Ví điện tử (MoMo / ZaloPay)
                        </label>
                    </div>
                </div>
            </div>

            <!-- Tóm tắt đơn hàng -->
            <div class="col-lg-5">
                <div class="card p-4">
                    <h5 class="mb-3">Đơn hàng của bạn</h5>
                    <div id="checkoutItems"></div>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính</span><span id="co-subtotal">0₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Vận chuyển</span><span id="co-shipping">30.000₫</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold fs-5 mt-2">
                        <span>Tổng cộng</span><span id="co-total">0₫</span>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 mt-4 py-3" onclick="prepareSubmit(event)"
                            style="font-size:13px;letter-spacing:0.1em;font-weight:700">
                        HOÀN TẤT ĐẶT HÀNG
                    </button>
                    
                    <p class="text-center mt-3 text-muted" style="font-size:11px;letter-spacing:0.04em;text-transform:uppercase">
                        Bằng cách đặt hàng, bạn đồng ý với điều khoản dịch vụ của StyleVibe.
                    </p>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
function fmtVND(n) { return n.toLocaleString('vi-VN') + '₫'; }

function renderCheckoutItems() {
    const cart = JSON.parse(localStorage.getItem('cart') || '[]');
    if (!cart.length) { window.location.href = '/Cart'; return; }

    let html = '';
    let subtotal = 0;
    cart.forEach(item => {
        const line = item.price * item.quantity;
        subtotal += line;
        html += `<div class="d-flex justify-content-between mb-2 align-items-start">
            <div style="max-width:70%">
                <p class="mb-0 fw-bold" style="font-size:13px;">${item.name}</p>
                <p class="mb-0 text-muted" style="font-size:11px;">${item.size} / ${item.color} × ${item.quantity}</p>
            </div>
            <span class="fw-bold" style="font-size:13px;">${fmtVND(line)}</span>
        </div>`;
    });
    document.getElementById('checkoutItems').innerHTML = html;

    const shipping = subtotal >= 500000 ? 0 : 30000;
    document.getElementById('co-subtotal').textContent = fmtVND(subtotal);
    document.getElementById('co-shipping').textContent = shipping === 0 ? 'Miễn phí' : fmtVND(shipping);
    document.getElementById('co-total').textContent = fmtVND(subtotal + shipping);
}

function prepareSubmit(event) {
    const cart = JSON.parse(localStorage.getItem('cart') || '[]');
    if (!cart.length) {
        alert('Giỏ hàng trống!');
        event.preventDefault();
        return;
    }

    // Đưa dữ liệu cart vào hidden field
    document.getElementById('hiddenItemsJson').value = JSON.stringify(cart);
    
    // Disable nút để tránh click nhiều lần
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = 'ĐANG XỬ LÝ...';
    
    // Xóa giỏ hàng trong localStorage sau khi submit (vì submit sẽ reload trang/đi tiếp)
    // Lưu ý: Nếu server trả về lỗi, user sẽ mất giỏ hàng. 
    // Nhưng vì đây là form POST thành công sẽ Redirect, nên ta xóa luôn.
    localStorage.removeItem('cart');
    
    document.getElementById('checkoutForm').submit();
}

document.addEventListener('DOMContentLoaded', renderCheckoutItems);
</script>
}