@model StyleVibe.Web.ViewModels.Admin.CustomerViewModel
@{
    ViewData["Title"] = "Chỉnh sửa thông tin khách hàng";
}

<div class="mb-3">
    <a href="/AdminCustomers/Details/@Model.Id" class="btn btn-outline-dark btn-sm">← Quay lại hồ sơ</a>
</div>

<div class="card border-0 shadow-sm rounded-0 mx-auto" style="max-width: 600px;">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="mb-0 fw-bold">Chỉnh sửa: @Model.FullName</h5>
    </div>
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-bold">Họ và tên</label>
                <input asp-for="FullName" class="form-control" required />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                <input asp-for="Phone" class="form-control" required />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold">Email (tùy chọn)</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DateOfBirth" class="form-label fw-bold">Ngày sinh</label>
                <input asp-for="DateOfBirth" type="date" class="form-control" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" />
                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tier" class="form-label fw-bold">Hạng thành viên</label>
                <select asp-for="Tier" class="form-select" asp-items="Html.GetEnumSelectList<StyleVibe.Domain.Enums.CustomerTier>()">
                </select>
                <span asp-validation-for="Tier" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LoyaltyPoints" class="form-label fw-bold">Điểm Loyalty</label>
                <input asp-for="LoyaltyPoints" class="form-control" type="number" min="0" />
                <span asp-validation-for="LoyaltyPoints" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold">CẬP NHẬT THÔNG TIN</button>
        </form>
    </div>
</div>
