@model StyleVibe.Web.ViewModels.Admin.CustomerViewModel
@{
    ViewData["Title"] = "Thêm khách hàng mới";
}

<div class="mb-3">
    <a href="/AdminCustomers/Index" class="btn btn-outline-dark btn-sm">← Quay lại danh sách</a>
</div>

<div class="card border-0 shadow-sm rounded-0 mx-auto" style="max-width: 600px;">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="mb-0 fw-bold">Thông tin khách hàng</h5>
    </div>
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-bold">Họ và tên</label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên đầy đủ" required />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                <input asp-for="Phone" class="form-control" placeholder="Ví dụ: 0901234567" required />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold">Email (tùy chọn)</label>
                <input asp-for="Email" class="form-control" placeholder="customer@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DateOfBirth" class="form-label fw-bold">Ngày sinh</label>
                <input asp-for="DateOfBirth" type="date" class="form-control" />
                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tier" class="form-label fw-bold">Hạng thành viên</label>
                <select asp-for="Tier" class="form-select" asp-items="Html.GetEnumSelectList<StyleVibe.Domain.Enums.CustomerTier>()">
                </select>
                <span asp-validation-for="Tier" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                <textarea asp-for="Address" class="form-control" rows="3" placeholder="Địa chỉ giao hàng mặc định..."></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold">XÁC NHẬN THÊM MỚI</button>
        </form>
    </div>
</div>
