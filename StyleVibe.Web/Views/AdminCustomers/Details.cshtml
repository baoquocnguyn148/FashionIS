@model StyleVibe.Domain.Entities.Customer
@using StyleVibe.Domain.Enums
@{
    ViewData["Title"] = "Hồ sơ khách hàng: " + Model.FullName;
    
    string TierBadge(CustomerTier t) => t switch
    {
        CustomerTier.Bronze => "badge bg-secondary",
        CustomerTier.Silver => "badge",
        CustomerTier.Gold => "badge",
        CustomerTier.Vip => "badge bg-danger",
        _ => "badge bg-dark"
    };

    string TierStyle(CustomerTier t) => t switch
    {
        CustomerTier.Silver => "background:#C0C0C0;color:#333",
        CustomerTier.Gold => "background:#FFD700;color:#333",
        _ => ""
    };
}

<div class="mb-3">
    <a href="/AdminCustomers/Index" class="btn btn-outline-dark btn-sm">← Quay lại danh sách</a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-0 mb-4">
            <div class="card-body text-center py-4">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                    👤
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <div class="mb-3">
                    <span class="@TierBadge(Model.Tier)" style="@TierStyle(Model.Tier) font-size: 0.9rem;">@Model.Tier</span>
                </div>
                <div class="d-flex justify-content-around border-top pt-3">
                    <div>
                        <div class="text-muted small text-uppercase fw-bold">Điểm tích lũy</div>
                        <div class="h4 mb-0 text-danger fw-bold">@Model.LoyaltyPoints.ToString("N0")</div>
                    </div>
                    <div>
                        <div class="text-muted small text-uppercase fw-bold">Tổng đơn hàng</div>
                        <div class="h4 mb-0 fw-bold">@Model.Orders.Count</div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white border-0 py-3">
                <a href="/AdminCustomers/Edit/@Model.Id" class="btn btn-dark btn-sm w-100 mb-2">Chỉnh sửa thông tin</a>
                <button type="button" class="btn btn-outline-danger btn-sm w-100" data-bs-toggle="modal" data-bs-target="#adjustPointsModal">
                    Điều chỉnh điểm
                </button>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-0">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold">Thông tin liên hệ</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold d-block">Số điện thoại</label>
                    <div>@Model.Phone</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold d-block">Email</label>
                    <div>@(Model.Email ?? "N/A")</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold d-block">Địa chỉ</label>
                    <div>@(Model.Address ?? "N/A")</div>
                </div>
                <div class="mb-0">
                    <label class="text-muted small text-uppercase fw-bold d-block">Ngày sinh</label>
                    <div>@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <ul class="nav nav-tabs border-0 mb-4" id="customerTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active border-0 fw-bold px-4" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button">Đơn hàng gần đây</button>
            </li>
            <li class="nav-item">
                <button class="nav-link border-0 fw-bold px-4" id="points-tab" data-bs-toggle="tab" data-bs-target="#points" type="button">Lịch sử điểm</button>
            </li>
        </ul>
        <div class="tab-content bg-white shadow-sm" id="customerTabContent">
            <div class="tab-pane fade show active" id="orders" role="tabpanel">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày</th>
                                <th class="text-end">Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.Orders)
                            {
                                <tr>
                                    <td class="fw-semibold">@o.OrderCode</td>
                                    <td>@o.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end fw-bold">@o.TotalAmount.ToString("N0")</td>
                                    <td><span class="badge bg-light text-dark border">@o.Status</span></td>
                                    <td class="text-end">
                                        <a href="/AdminOrders/Details/@o.Id" class="btn btn-outline-dark btn-sm">Xem</a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Orders.Any())
                            {
                                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có đơn hàng nào</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="tab-pane fade" id="points" role="tabpanel">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Ngày</th>
                                <th>Số điểm</th>
                                <th>Nội dung</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.LoyaltyTransactions)
                            {
                                <tr>
                                    <td>@t.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold @(t.Points >= 0 ? "text-success" : "text-danger")">
                                        @(t.Points >= 0 ? "+" : "")@t.Points
                                    </td>
                                    <td>@t.Description</td>
                                </tr>
                            }
                            @if (!Model.LoyaltyTransactions.Any())
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">Chưa có lịch sử giao dịch điểm</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Điều chỉnh điểm -->
<div class="modal fade" id="adjustPointsModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" action="/AdminCustomers/AdjustPoints" class="modal-content border-0 rounded-0">
            @Html.AntiForgeryToken()
            <input type="hidden" name="customerId" value="@Model.Id" />
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Điều chỉnh điểm Loyalty</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Số điểm</label>
                    <input type="number" name="points" class="form-control" required placeholder="Ví dụ: 100 hoặc -50" />
                    <div class="form-text">Dùng số âm để trừ điểm.</div>
                </div>
                <div class="mb-0">
                    <label class="form-label fw-bold">Lý do</label>
                    <textarea name="reason" class="form-control" required rows="2" placeholder="Nhập lý do điều chỉnh..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-danger">Xác nhận</button>
            </div>
        </form>
    </div>
</div>
