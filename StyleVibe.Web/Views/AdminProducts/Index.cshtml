@model List<StyleVibe.Domain.Entities.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<StyleVibe.Domain.Entities.Category> ?? new();
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    string search = ViewBag.Search as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2 align-items-center">
        <select name="categoryId" class="form-select" style="width: 220px;">
            <option value="">Tất cả danh mục</option>
            @foreach (var c in categories)
            {
                <option value="@c.Id" selected="@(selectedCategoryId == c.Id ? "selected" : null)">@c.Name</option>
            }
        </select>
        <input name="search" value="@search" class="form-control" placeholder="Tìm theo tên sản phẩm..." style="width: 280px;" />
        <button class="btn btn-dark" type="submit">Lọc</button>
    </form>
    <a class="btn btn-danger" href="/AdminProducts/Create">+ Tạo sản phẩm</a>
</div>

<div class="card border-0 shadow-sm rounded-0">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Nhà cung cấp</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="text-muted">#@p.Id</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" style="width:48px;height:48px;object-fit:cover;border-radius:8px;" />
                                }
                                <div>
                                    <div class="fw-semibold">@p.Name</div>
                                    <div class="small text-muted">@p.CreatedAt.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                        </td>
                        <td>@p.Category?.Name</td>
                        <td>@p.Supplier?.Name</td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <a class="btn btn-outline-dark btn-sm" href="/AdminProducts/Details/@p.Id">Details</a>
                                <a class="btn btn-outline-dark btn-sm" href="/AdminProducts/Edit/@p.Id">Edit</a>
                                <form method="post" action="/AdminProducts/Delete/@p.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<nav class="mt-3">
    <ul class="pagination mb-0">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == page ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index", new { categoryId = selectedCategoryId, search, page = i })">@i</a>
            </li>
        }
    </ul>
</nav>

