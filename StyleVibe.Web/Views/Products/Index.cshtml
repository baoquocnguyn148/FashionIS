@model IEnumerable<StyleVibe.Domain.Entities.Product>
@{
    ViewData["Title"] = "Sản phẩm – StyleVibe Fashion";
    var categories = ViewBag.Categories as IEnumerable<StyleVibe.Domain.Entities.Category> ?? [];
    var activeCatId = ViewBag.CurrentCategoryId?.ToString();
}

<div class="page-container">
    <div style="padding:48px 0 0;">
        <!-- Page Heading -->
        <div class="section-title">
            <h1 style="font-size:1.75rem;letter-spacing:0.08em;text-transform:uppercase;">Sản phẩm</h1>
        </div>

        <!-- Category Tabs -->
        <div class="category-tabs">
            <a asp-action="Index"
               class="category-tab @(string.IsNullOrEmpty(activeCatId) ? "active" : "")">
                Tất cả
            </a>
            @foreach (var cat in categories)
            {
                <a asp-action="Index" asp-route-categoryId="@cat.Id"
                   class="category-tab @(activeCatId == cat.Id.ToString() ? "active" : "")">
                    @cat.Name
                </a>
            }
        </div>

        <!-- Filter & Sort Bar -->
        <form method="get" asp-action="Index" class="mb-4">
            @if (ViewBag.CurrentCategoryId != null)
            {
                <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategoryId" />
            }
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <!-- Search -->
                <input type="text" name="search" value="@ViewBag.CurrentSearch"
                       placeholder="Tìm sản phẩm..." class="form-control"
                       style="max-width:220px;font-size:13px" />
                <!-- Sort -->
                <select name="sortBy" class="form-select" style="max-width:170px;font-size:13px"
                        onchange="this.form.submit()">
                    <option value="newest" @(ViewBag.CurrentSortBy == "newest" ? "selected" : "")>Mới nhất</option>
                    <option value="price_asc" @(ViewBag.CurrentSortBy == "price_asc" ? "selected" : "")>Giá tăng dần</option>
                    <option value="price_desc" @(ViewBag.CurrentSortBy == "price_desc" ? "selected" : "")>Giá giảm dần</option>
                    <option value="name" @(ViewBag.CurrentSortBy == "name" ? "selected" : "")>Tên A→Z</option>
                </select>
                <!-- Price range -->
                <input type="number" name="minPrice" value="@ViewBag.MinPrice"
                       placeholder="Giá từ" class="form-control"
                       style="max-width:110px;font-size:13px" />
                <input type="number" name="maxPrice" value="@ViewBag.MaxPrice"
                       placeholder="Đến" class="form-control"
                       style="max-width:110px;font-size:13px" />
                <button type="submit" class="btn btn-primary btn-sm" style="font-size:12px">Lọc</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm" style="font-size:12px">Xoá lọc</a>
            </div>
        </form>

        <!-- Kết quả -->
        <p style="font-size:12px;color:var(--sv-gray-text);margin-bottom:16px">
            @ViewBag.TotalCount sản phẩm
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string))
            {
                <span> · Từ khoá: "@ViewBag.CurrentSearch"</span>
            }
        </p>

        <!-- Products Grid -->
        @if (!Model.Any())
        {
            <div style="text-align:center;padding:80px 0;color:var(--sv-gray-text)">
                <svg width="64" height="64" fill="none" stroke="#bdbdbd" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 20px;display:block">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" />
                </svg>
                <p style="font-size:13px;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:24px">
                    Không có sản phẩm nào phù hợp
                </p>
                <a asp-action="Index" class="btn btn-primary" style="padding:14px 36px;font-size:12px;letter-spacing:0.1em;">
                    Xem tất cả
                </a>
            </div>
        }
        else
        {
            <div class="products-grid">
                @foreach (var product in Model)
                {
                    <div class="product-card">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id"
                           style="text-decoration:none;color:inherit;">
                            <div class="product-card-img-wrap">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="product-no-image">
                                        <svg width="48" height="48" fill="none" stroke="#bdbdbd" stroke-width="1.5" viewBox="0 0 24 24">
                                            <rect x="3" y="3" width="18" height="18" rx="2" />
                                            <circle cx="8.5" cy="8.5" r="1.5" />
                                            <polyline points="21 15 16 10 5 21" />
                                        </svg>
                                    </div>
                                }
                                <div class="product-card-overlay">
                                    <span class="quick-view-btn">Xem chi tiết</span>
                                </div>
                            </div>
                            <div class="product-info">
                                <p class="product-category-label">@product.Category?.Name</p>
                                <h3 class="product-name">@product.Name</h3>
                                @if (product.Skus?.Any() == true)
                                {
                                    var prices = product.Skus.Where(s => s.IsActive).Select(s => s.SellingPrice);
                                    if (prices.Any())
                                    {
                                        <p class="product-price">@prices.Min().ToString("N0")₫</p>
                                    }
                                }
                                else
                                {
                                    <p class="product-price" style="color:var(--sv-gray-text);font-size:12px">Liên hệ</p>
                                }
                            </div>
                        </a>
                    </div>
                }
            </div>

            @if ((int)ViewBag.TotalPages > 1)
            {
                <nav class="d-flex justify-content-center mt-4 mb-5">
                    <ul class="pagination pagination-sm">
                        @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                        {
                            <li class="page-item @(p == (int)ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@p"
                                   asp-route-categoryId="@ViewBag.CurrentCategoryId"
                                   asp-route-search="@ViewBag.CurrentSearch"
                                   asp-route-minPrice="@ViewBag.MinPrice"
                                   asp-route-maxPrice="@ViewBag.MaxPrice"
                                   asp-route-sortBy="@ViewBag.CurrentSortBy">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>
