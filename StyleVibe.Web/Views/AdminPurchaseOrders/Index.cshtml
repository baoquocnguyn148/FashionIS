@model IEnumerable<StyleVibe.Domain.Entities.PurchaseOrder>
@{
    ViewData["Title"] = "Quản lý Đơn nhập hàng";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    <a href="/AdminPurchaseOrders/Create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Tạo đơn nhập mới</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card bg-dark text-light border-secondary">
    <div class="card-body">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Mã Đơn Nhập</th>
                    <th>Ngày Nhập</th>
                    <th>Nhà Cung Cấp</th>
                    <th>Tổng Tiền</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var po in Model)
                {
                    <tr>
                        <td><strong>@po.PoCode</strong></td>
                        <td>@po.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(po.Supplier?.Name ?? "N/A")</td>
                        <td class="text-warning fw-bold">@po.TotalCost.ToString("N0") ₫</td>
                        <td class="text-center">
                            <a href="/AdminPurchaseOrders/Details/@po.Id" class="btn btn-sm btn-outline-light">Xem chi tiết</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có đơn nhập hàng nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
