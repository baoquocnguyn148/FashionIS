@{
    ViewData["Title"] = "Tạo Đơn Nhập Hàng Mới";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-plus-circle"></i> @ViewData["Title"]</h2>
    <a href="/AdminPurchaseOrders" class="btn btn-outline-light">Hủy bỏ</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form method="post" action="/AdminPurchaseOrders/Create" id="poForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="itemsJson" id="itemsJson" value="[]" />

    <div class="row">
        <!-- Thông tin chung -->
        <div class="col-md-4">
            <div class="card bg-dark text-light border-secondary mb-4">
                <div class="card-header bg-secondary border-secondary">Thông tin nhập hàng</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label text-info">Nhà Cung Cấp</label>
                        <select name="supplierId" class="form-select bg-dark text-light border-secondary" required>
                            <option value="">-- Chọn Nhà Cung Cấp --</option>
                            @foreach (var s in ViewBag.Suppliers as Microsoft.AspNetCore.Mvc.Rendering.SelectList)
                            {
                                <option value="@s.Value">@s.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-info">Ghi Chú</label>
                        <textarea name="note" class="form-control bg-dark text-light border-secondary" rows="3"></textarea>
                    </div>
                    
                    <hr class="border-secondary mt-4 mb-3" />
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fs-5 text-muted">Tổng thành tiền:</span>
                        <span class="fs-4 text-warning fw-bold" id="totalCostDisplay">0 ₫</span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" onclick="return prepareSubmit()">Lưu Phiếu Nhập & Phân Bổ Kho</button>
                </div>
            </div>
        </div>

        <!-- Chọn sản phẩm -->
        <div class="col-md-8">
            <div class="card bg-dark text-light border-secondary">
                <div class="card-header bg-secondary border-secondary d-flex justify-content-between align-items-center">
                    <span>Danh sách sản phẩm nhập</span>
                    <button type="button" class="btn btn-sm btn-success" onclick="addRow()">+ Thêm dòng</button>
                </div>
                <div class="card-body p-0">
                    <table class="table table-dark table-striped m-0 align-middle" id="itemsTable">
                        <thead>
                            <tr>
                                <th style="width: 40%">Sản phẩm - SKU</th>
                                <th class="text-center" style="width: 15%">Số Lượng</th>
                                <th class="text-end" style="width: 25%">Đơn Giá Nhập (₫)</th>
                                <th class="text-end" style="width: 15%">Thành Tiền</th>
                                <th style="width: 5%"></th>
                            </tr>
                        </thead>
                        <tbody id="itemsBody">
                            <!-- JS rows here -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</form>

<template id="rowTemplate">
    <tr class="po-row">
        <td>
            <select class="form-select form-select-sm bg-dark text-light border-secondary sku-select" onchange="updateRow(this)">
                <option value="">Chọn SKU...</option>
            </select>
        </td>
        <td>
            <input type="number" class="form-control form-control-sm bg-dark text-light border-secondary text-center qty-input" min="1" value="1" onchange="updateRow(this)" onkeyup="updateRow(this)" />
        </td>
        <td>
            <input type="number" class="form-control form-control-sm bg-dark text-light border-secondary text-end cost-input" min="0" value="0" step="1000" onchange="updateRow(this)" onkeyup="updateRow(this)" />
        </td>
        <td class="text-end fw-bold text-info row-total">0 ₫</td>
        <td class="text-center">
            <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="removeRow(this)"><i class="fa-solid fa-trash"></i></button>
        </td>
    </tr>
</template>

@section Scripts {
    <script>
        const productsData = @Html.Raw(ViewBag.ProductsJson);
        const tBody = document.getElementById('itemsBody');
        const template = document.getElementById('rowTemplate');

        function generateSkuOptions() {
            let options = '<option value="">Chọn SKU...</option>';
            productsData.forEach(p => {
                const group = document.createElement('optgroup');
                group.label = p.Name;
                p.Skus.forEach(s => {
                    options += `<option value="${s.Id}" data-cost="${s.CostPrice}">${p.Name} - ${s.Color}/${s.Size} (${s.SkuCode})</option>`;
                });
            });
            return options;
        }

        const skuOptionsHtml = generateSkuOptions();

        function addRow() {
            const clone = template.content.cloneNode(true);
            const select = clone.querySelector('.sku-select');
            select.innerHTML = skuOptionsHtml;
            tBody.appendChild(clone);
            updateTotal();
        }

        function removeRow(btn) {
            btn.closest('tr').remove();
            updateTotal();
        }

        function updateRow(element) {
            const row = element.closest('tr');
            const select = row.querySelector('.sku-select');
            const qtyInput = row.querySelector('.qty-input');
            const costInput = row.querySelector('.cost-input');
            const totalCell = row.querySelector('.row-total');

            // Nếu người dùng vừa chọn SKU mới, tự điền giá vốn hiện tại
            if (element.classList.contains('sku-select') && select.value) {
                const selectedOpt = select.options[select.selectedIndex];
                const defaultCost = Number(selectedOpt.dataset.cost) || 0;
                costInput.value = defaultCost;
            }

            const qty = parseInt(qtyInput.value) || 0;
            const cost = parseFloat(costInput.value) || 0;
            const subtotal = qty * cost;

            totalCell.textContent = subtotal.toLocaleString('vi-VN') + ' ₫';
            updateTotal();
        }

        function updateTotal() {
            let total = 0;
            document.querySelectorAll('.po-row').forEach(row => {
                const qty = parseInt(row.querySelector('.qty-input').value) || 0;
                const cost = parseFloat(row.querySelector('.cost-input').value) || 0;
                if (row.querySelector('.sku-select').value) {
                    total += (qty * cost);
                }
            });
            document.getElementById('totalCostDisplay').textContent = total.toLocaleString('vi-VN') + ' ₫';
        }

        function prepareSubmit() {
            const items = [];
            let hasError = false;

            document.querySelectorAll('.po-row').forEach(row => {
                const skuId = row.querySelector('.sku-select').value;
                const qty = parseInt(row.querySelector('.qty-input').value) || 0;
                const cost = parseFloat(row.querySelector('.cost-input').value) || 0;

                if (skuId && qty > 0) {
                    items.push({ SkuId: parseInt(skuId), Quantity: qty, UnitCost: cost });
                } else if (skuId) {
                    hasError = true;
                }
            });

            if (items.length === 0) {
                alert("Vui lòng thêm ít nhất 1 sản phẩm vào phiếu nhập.");
                return false;
            }
            if (hasError) {
                alert("Số lượng nhập phải lớn hơn 0.");
                return false;
            }

            document.getElementById('itemsJson').value = JSON.stringify(items);
            return true;
        }

        // Initialize with one empty row
        addRow();
    </script>
}
