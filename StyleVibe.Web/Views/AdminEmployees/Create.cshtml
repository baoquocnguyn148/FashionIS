@model StyleVibe.Domain.Entities.Employee
@{
    ViewData["Title"] = "Thêm nhân viên mới";
    var stores = ViewBag.Stores as List<StyleVibe.Domain.Entities.Store> ?? new();
}

<div class="mb-3">
    <a href="/AdminEmployees/Index" class="btn btn-outline-dark btn-sm">← Quay lại danh sách</a>
</div>

<div class="card border-0 shadow-sm rounded-0 mx-auto" style="max-width: 600px;">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="mb-0 fw-bold">Thông tin nhân viên</h5>
    </div>
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-bold">Họ và tên</label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên đầy đủ" required />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" required />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-bold">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Position" class="form-label fw-bold">Chức vụ</label>
                <input asp-for="Position" class="form-control" placeholder="Ví dụ: Nhân viên bán hàng, Quản lý..." required />
                <span asp-validation-for="Position" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="StoreId" class="form-label fw-bold">Cửa hàng làm việc</label>
                <select asp-for="StoreId" class="form-select" required>
                    <option value="">-- Chọn cửa hàng --</option>
                    @foreach (var s in stores)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
                <span asp-validation-for="StoreId" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold">XÁC NHẬN THÊM MỚI</button>
        </form>
    </div>
</div>
