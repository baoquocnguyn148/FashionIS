@model StyleVibe.Domain.Entities.Order
@using StyleVibe.Domain.Enums
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderCode;
    string StatusBadge(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "badge bg-warning text-dark",
        OrderStatus.Confirmed => "badge bg-info",
        OrderStatus.Processing => "badge bg-primary",
        OrderStatus.Completed => "badge bg-success",
        OrderStatus.Cancelled => "badge bg-danger",
        _ => "badge bg-secondary"
    };
}

<div class="mb-3">
    <a href="/AdminOrders/Index" class="btn btn-outline-dark btn-sm">← Quay lại danh sách</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-0 mb-4">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold">Sản phẩm</h6>
            </div>
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.OrderDetails)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@d.ProductSku?.Product?.Name</div>
                                    <div class="small text-muted">SKU: @d.ProductSku?.SkuCode | @d.ProductSku?.Size / @d.ProductSku?.Color</div>
                                </td>
                                <td class="text-center">@d.Quantity</td>
                                <td class="text-end">@d.UnitPrice.ToString("N0")</td>
                                <td class="text-end fw-bold">@d.Subtotal.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-light">
                            <td colspan="3" class="text-end fw-bold">Tổng tiền:</td>
                            <td class="text-end fw-bold text-danger h5">@Model.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="mb-0 fw-bold">Ghi chú</h6>
                </div>
                <div class="card-body">
                    @Model.Note
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-0 mb-4">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold">Trạng thái đơn hàng</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <span class="@StatusBadge(Model.Status) fs-6">@Model.Status</span>
                </div>
                
                <form method="post" action="/AdminOrders/UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase">Cập nhật trạng thái</label>
                        <select name="status" class="form-select">
                            @foreach (var s in Enum.GetValues<OrderStatus>())
                            {
                                <option value="@s" selected="@(Model.Status == s ? "selected" : null)">@s</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-danger w-100">Cập nhật</button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-0 mb-4">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold">Khách hàng</h6>
            </div>
            <div class="card-body">
                @if (Model.Customer != null)
                {
                    <div class="fw-bold">@Model.Customer.FullName</div>
                    <div class="text-muted small">📞 @Model.Customer.Phone</div>
                    <div class="text-muted small">📧 @Model.Customer.Email</div>
                    <div class="text-muted small mt-2">📍 @Model.Customer.Address</div>
                    <a href="/AdminCustomers/Details/@Model.Customer.Id" class="btn btn-link btn-sm p-0 mt-2">Xem hồ sơ khách hàng</a>
                }
                else
                {
                    <div class="text-muted">Khách vãng lai</div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-0">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold">Cửa hàng</h6>
            </div>
            <div class="card-body">
                <div class="fw-bold">@Model.Store?.Name</div>
                <div class="text-muted small">📍 @Model.Store?.Address</div>
                <div class="text-muted small">📞 @Model.Store?.Phone</div>
            </div>
        </div>
    </div>
</div>
