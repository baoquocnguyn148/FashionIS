@{
    ViewData["Title"] = "POS - Bán hàng tại quầy";
    var stores = ViewBag.Stores as IEnumerable<StyleVibe.Domain.Entities.Store> ?? [];
}

<div class="container mt-4">
    <h2 class="mb-3">POS - Bán hàng tại quầy</h2>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <form asp-action="Checkout" method="post" id="posForm">
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Cửa hàng</label>
                <select class="form-select" name="storeId" required>
                    @foreach (var store in stores)
                    {
                        <option value="@store.Id">@store.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Mã khách hàng (tuỳ chọn)</label>
                <input type="number" class="form-control" name="customerId" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Phương thức thanh toán</label>
                <select class="form-select" name="paymentMethod">
                    <option value="1">Tiền mặt</option>
                    <option value="2">Chuyển khoản</option>
                    <option value="3">Ví điện tử</option>
                    <option value="4">Thẻ</option>
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Ghi chú</label>
            <textarea class="form-control" name="note" rows="2"></textarea>
        </div>

        <h5>Giỏ hàng</h5>
        <table class="table table-bordered align-middle" id="cartTable">
            <thead>
            <tr>
                <th>SKU Id</th>
                <th>Số lượng</th>
                <th>Giảm (%)</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td>
                    <input type="number" class="form-control" name="skuIds" required />
                </td>
                <td>
                    <input type="number" class="form-control" name="quantities" value="1" min="1" required />
                </td>
                <td>
                    <input type="number" class="form-control" name="discounts" value="0" min="0" max="100" step="0.5" />
                </td>
                <td>
                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">X</button>
                </td>
            </tr>
            </tbody>
        </table>

        <button type="button" class="btn btn-secondary mb-3" onclick="addRow()">+ Thêm dòng</button>
        <br />
        <button type="submit" class="btn btn-primary">Thanh toán</button>
    </form>
</div>

<script>
    function addRow() {
        const table = document.getElementById('cartTable').getElementsByTagName('tbody')[0];
        const newRow = table.rows[0].cloneNode(true);
        newRow.querySelectorAll('input').forEach(input => {
            if (input.name === 'skuIds') {
                input.value = '';
            } else if (input.name === 'quantities') {
                input.value = '1';
            } else if (input.name === 'discounts') {
                input.value = '0';
            }
        });
        table.appendChild(newRow);
    }

    function removeRow(button) {
        const table = document.getElementById('cartTable').getElementsByTagName('tbody')[0];
        if (table.rows.length === 1) return;
        const row = button.closest('tr');
        row.remove();
    }
</script>

