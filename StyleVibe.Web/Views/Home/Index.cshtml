@using StyleVibe.Domain.Entities
@{
    ViewData["Title"] = "Trang chủ – StyleVibe Fashion";
    var categories   = ViewBag.Categories  as IEnumerable<Category> ?? [];
    var newArrivals  = ViewBag.NewArrivals as IEnumerable<Product>  ?? [];
}

<!-- ── Hero Section ──────────────────────────────────── -->
<section class="hero-section">
    <div class="hero-gradient"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <p class="hero-subtitle">NEW COLLECTION 2026</p>
        <h1 class="hero-title">FOR DREAMERS ONLY</h1>
        <a asp-controller="Products" asp-action="Index" class="hero-btn">Xem sản phẩm</a>
    </div>
</section>

<!-- ── Category Banners ──────────────────────────────── -->
<div class="page-container">
    <div class="section-spacer" style="padding-bottom: 0">
        <div class="section-title">
            <h2>Khám phá danh mục</h2>
            <p>Phong cách cho mọi khoảnh khắc</p>
        </div>
        <div class="category-banners">
            @{
                var bannerData = new[]
                {
                    new { Label = "ÁO", Bg = "linear-gradient(135deg,#1a1a2e,#16213e)", CatId = 1 },
                    new { Label = "QUẦN", Bg = "linear-gradient(135deg,#2d1b69,#11998e)", CatId = 2 },
                    new { Label = "PHỤ KIỆN", Bg = "linear-gradient(135deg,#373b44,#4286f4)", CatId = 5 },
                };
            }
            @foreach (var b in bannerData)
            {
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@b.CatId" class="category-banner" style="text-decoration:none">
                    <div class="category-banner-placeholder" style="background:@b.Bg">
                        <svg width="56" height="56" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" viewBox="0 0 24 24">
                            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                            <polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                    </div>
                    <div class="category-banner-overlay">
                        <span class="category-banner-label">@b.Label</span>
                    </div>
                </a>
            }
        </div>
    </div>

    <!-- ── New Arrivals ───────────────────────────────── -->
    <div class="section-spacer">
        <div class="section-title">
            <h2>Mới nhất</h2>
            <p>Cập nhật liên tục – Đừng bỏ lỡ</p>
        </div>

        <!-- Category Tab Filter -->
        <div class="category-tabs">
            <a asp-controller="Products" asp-action="Index" class="category-tab active">Tất cả</a>
            @foreach (var cat in categories.Take(6))
            {
                <a asp-controller="Products" asp-action="Index"
                   asp-route-categoryId="@cat.Id"
                   class="category-tab">@cat.Name</a>
            }
        </div>

        @if (!newArrivals.Any())
        {
            <div style="text-align:center;padding:60px 0;color:var(--sv-gray-text)">
                <p style="font-size:13px;letter-spacing:0.08em;text-transform:uppercase">
                    Chưa có sản phẩm nào. Hãy thêm sản phẩm ở phần Quản trị.
                </p>
                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary mt-3" style="padding:14px 36px;">
                    Vào trang Admin
                </a>
            </div>
        }
        else
        {
            <div class="products-grid">
                @foreach (var product in newArrivals.Take(8))
                {
                    <div class="product-card">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id"
                           style="text-decoration:none;color:inherit;">
                            <div class="product-card-img-wrap">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="product-no-image">
                                        <svg width="48" height="48" fill="none" stroke="#bdbdbd" stroke-width="1.5" viewBox="0 0 24 24">
                                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                                            <circle cx="8.5" cy="8.5" r="1.5"/>
                                            <polyline points="21 15 16 10 5 21"/>
                                        </svg>
                                    </div>
                                }
                                <div class="product-card-overlay">
                                    <span class="quick-view-btn">Xem chi tiết</span>
                                </div>
                            </div>
                            <div class="product-info">
                                <p class="product-category-label">@product.Category?.Name</p>
                                <h3 class="product-name">@product.Name</h3>
                                @if (product.Skus?.Any() == true)
                                {
                                    var prices = product.Skus.Where(s => s.IsActive).Select(s => s.SellingPrice);
                                    if (prices.Any())
                                    {
                                        var minPrice = prices.Min();
                                        <p class="product-price">@minPrice.ToString("N0")₫</p>
                                    }
                                }
                                else
                                {
                                    <p class="product-price" style="color:var(--sv-gray-text);font-size:12px">Liên hệ</p>
                                }
                            </div>
                        </a>
                    </div>
                }
            </div>

            @if (newArrivals.Count() > 8)
            {
                <div style="text-align:center;margin-top:48px">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary" style="padding:14px 48px;font-size:12px;letter-spacing:0.12em;">
                        XEM TẤT CẢ SẢN PHẨM
                    </a>
                </div>
            }
        }
    </div>

    <!-- ── Brand Statement ───────────────────────────── -->
    <div style="border-top:1px solid var(--sv-gray-mid);padding:80px 0;text-align:center">
        <p style="font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--sv-gray-text);margin-bottom:20px">
            Our Philosophy
        </p>
        <h2 style="font-size:clamp(1.5rem,4vw,2.5rem);font-weight:900;letter-spacing:0.04em;max-width:640px;margin:0 auto 28px;line-height:1.15;">
            THỜI TRANG KHÔNG CHỈ LÀ QUẦN ÁO — ĐÓ LÀ NGÔN NGỮ
        </h2>
        <a asp-controller="Products" asp-action="Index" class="hero-btn" style="display:inline-block;background:var(--sv-black);color:var(--sv-white);padding:16px 48px;">
            KHÁM PHÁ NGAY
        </a>
    </div>
</div>
