@model StyleVibe.Web.ViewModels.Admin.StockAdjustViewModel
@{
    ViewData["Title"] = "Điều chỉnh tồn kho";
}

<div class="mb-3">
    <a href="/AdminInventory/Index" class="btn btn-outline-dark btn-sm">← Quay lại</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-0">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold">Thông tin sản phẩm</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold d-block">Sản phẩm</label>
                    <div class="fw-bold fs-5">@Model.ProductName</div>
                </div>
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="text-muted small text-uppercase fw-bold d-block">SKU Code</label>
                        <div class="fw-semibold">@Model.SkuCode</div>
                    </div>
                    <div class="col-6">
                        <label class="text-muted small text-uppercase fw-bold d-block">Cửa hàng</label>
                        <div class="fw-semibold">@Model.StoreName</div>
                    </div>
                </div>
                <div class="mb-0">
                    <label class="text-muted small text-uppercase fw-bold d-block">Tồn kho hiện tại</label>
                    <div class="h3 mb-0">@Model.QuantityOnHand</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-0">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="mb-0 fw-bold">Form điều chỉnh</h6>
            </div>
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="InventoryId" />
                    <input type="hidden" asp-for="ProductSkuId" />
                    <input type="hidden" asp-for="StoreId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Số lượng thay đổi (+/-)</label>
                        <input asp-for="QuantityChange" class="form-control form-control-lg" placeholder="Ví dụ: 10 hoặc -5" />
                        <span asp-validation-for="QuantityChange" class="text-danger small"></span>
                        <div class="form-text">Dùng số dương để tăng, số âm để giảm tồn kho.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Lý do</label>
                        <select asp-for="Reason" class="form-select" asp-items="Html.GetEnumSelectList<StyleVibe.Domain.Enums.StockAdjustmentReason>()">
                        </select>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Ghi chú</label>
                        <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập lý do chi tiết..."></textarea>
                        <span asp-validation-for="Note" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-danger btn-lg w-100">Xác nhận điều chỉnh</button>
                </form>
            </div>
        </div>
    </div>
</div>
