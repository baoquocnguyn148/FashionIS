@model List<StyleVibe.Domain.Entities.Inventory>
@{
    ViewData["Title"] = "Quản lý tồn kho";
    var stores = ViewBag.Stores as List<StyleVibe.Domain.Entities.Store> ?? new();
    var filter = ViewBag.Filter as StyleVibe.Web.ViewModels.Admin.InventoryFilterViewModel ?? new();
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2 align-items-end">
        <div>
            <label class="form-label small fw-bold">Cửa hàng</label>
            <select name="StoreId" class="form-select" style="width: 200px;">
                <option value="">Tất cả cửa hàng</option>
                @foreach (var s in stores)
                {
                    <option value="@s.Id" selected="@(filter.StoreId == s.Id ? "selected" : null)">@s.Name</option>
                }
            </select>
        </div>
        <div class="mb-2">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="LowStock" value="true" id="lowStockCheck" checked="@(filter.LowStock ? "checked" : null)">
                <label class="form-check-label small fw-bold" for="lowStockCheck">Chỉ hiện tồn kho thấp</label>
            </div>
        </div>
        <button class="btn btn-dark" type="submit">Lọc</button>
    </form>
    <a href="/AdminInventory/PurchaseOrders" class="btn btn-danger">📋 Quản lý đơn nhập (PO)</a>
</div>

<div class="card border-0 shadow-sm rounded-0">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>SKU Code</th>
                    <th>Sản phẩm</th>
                    <th>Cửa hàng</th>
                    <th class="text-center">Tồn kho</th>
                    <th class="text-center">Mức tối thiểu</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model)
                {
                    bool isLow = i.QuantityOnHand <= i.ReorderPoint;
                    <tr class="@(isLow ? "table-danger" : "")">
                        <td class="fw-bold">@i.ProductSku?.SkuCode</td>
                        <td>
                            <div class="fw-semibold">@i.ProductSku?.Product?.Name</div>
                            <div class="small text-muted">Size: @i.ProductSku?.Size | Color: @i.ProductSku?.Color</div>
                        </td>
                        <td>@i.Store?.Name</td>
                        <td class="text-center fw-bold @(isLow ? "text-danger" : "")">@i.QuantityOnHand</td>
                        <td class="text-center text-muted">@i.ReorderPoint</td>
                        <td>
                            @if (isLow)
                            {
                                <span class="badge bg-danger">Low Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">In Stock</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <a href="/AdminInventory/Adjust/@i.Id" class="btn btn-outline-dark btn-sm">Adjust</a>
                                <a href="/AdminInventory/History?inventoryId=@i.Id" class="btn btn-outline-dark btn-sm">History</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<nav class="mt-3">
    <ul class="pagination">
        @for (int p = 1; p <= totalPages; p++)
        {
            <li class="page-item @(p == filter.Page ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index", new { StoreId = filter.StoreId, LowStock = filter.LowStock, Page = p })">@p</a>
            </li>
        }
    </ul>
</nav>
