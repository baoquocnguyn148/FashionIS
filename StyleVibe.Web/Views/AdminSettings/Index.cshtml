@{
    ViewData["Title"] = "Cài đặt hệ thống";
    var activeTab = ViewBag.ActiveTab as string ?? "stores";
    var stores = ViewBag.Stores as List<StyleVibe.Domain.Entities.Store> ?? new();
    var suppliers = ViewBag.Suppliers as List<StyleVibe.Domain.Entities.Supplier> ?? new();
    var categories = ViewBag.Categories as List<StyleVibe.Domain.Entities.Category> ?? new();
}

<ul class="nav nav-pills mb-4 gap-2" id="settingsTab" role="tablist">
    <li class="nav-item">
        <button class="btn @(activeTab == "stores" ? "btn-danger" : "btn-outline-dark") px-4" id="stores-tab" data-bs-toggle="pill" data-bs-target="#stores" type="button">Cửa hàng</button>
    </li>
    <li class="nav-item">
        <button class="btn @(activeTab == "suppliers" ? "btn-danger" : "btn-outline-dark") px-4" id="suppliers-tab" data-bs-toggle="pill" data-bs-target="#suppliers" type="button">Nhà cung cấp</button>
    </li>
    <li class="nav-item">
        <button class="btn @(activeTab == "categories" ? "btn-danger" : "btn-outline-dark") px-4" id="categories-tab" data-bs-toggle="pill" data-bs-target="#categories" type="button">Danh mục</button>
    </li>
</ul>

<div class="tab-content" id="settingsTabContent">
    <!-- STORES TAB -->
    <div class="tab-pane fade @(activeTab == "stores" ? "show active" : "")" id="stores" role="tabpanel">
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addStoreModal">+ Thêm cửa hàng</button>
        </div>
        <div class="card border-0 shadow-sm rounded-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tên cửa hàng</th>
                            <th>Địa chỉ</th>
                            <th>Liên hệ</th>
                            <th>Quản lý</th>
                            <th>Trạng thái</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in stores)
                        {
                            <tr>
                                <td class="fw-bold">@s.Name</td>
                                <td>@s.Address</td>
                                <td>@s.Phone</td>
                                <td>@s.ManagerName</td>
                                <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                                <td class="text-end">
                                    <button class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#editStoreModal-@s.Id">Edit</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- SUPPLIERS TAB -->
    <div class="tab-pane fade @(activeTab == "suppliers" ? "show active" : "")" id="suppliers" role="tabpanel">
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addSupplierModal">+ Thêm nhà cung cấp</button>
        </div>
        <div class="card border-0 shadow-sm rounded-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tên NCC</th>
                            <th>Người liên hệ</th>
                            <th>Số điện thoại</th>
                            <th>Email</th>
                            <th>Thời gian giao (ngày)</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in suppliers)
                        {
                            <tr>
                                <td class="fw-bold">@s.Name</td>
                                <td>@s.ContactPerson</td>
                                <td>@s.Phone</td>
                                <td>@s.Email</td>
                                <td>@s.LeadTimeDays</td>
                                <td class="text-end">
                                    <button class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#editSupplierModal-@s.Id">Edit</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- CATEGORIES TAB -->
    <div class="tab-pane fade @(activeTab == "categories" ? "show active" : "")" id="categories" role="tabpanel">
        <div class="d-flex justify-content-end mb-3">
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addCategoryModal">+ Thêm danh mục</button>
        </div>
        <div class="card border-0 shadow-sm rounded-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Thứ tự</th>
                            <th>Hình ảnh</th>
                            <th>Tên danh mục</th>
                            <th>Mô tả</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in categories)
                        {
                            <tr>
                                <td>@c.DisplayOrder</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.ImageUrl))
                                    {
                                        <img src="@c.ImageUrl" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" />
                                    }
                                </td>
                                <td class="fw-bold">@c.Name</td>
                                <td class="small text-muted">@c.Description</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <button class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#editCategoryModal-@c.Id">Edit</button>
                                        <form method="post" action="/AdminSettings/DeleteCategory/@c.Id" onsubmit="return confirm('Xóa danh mục này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modals for adding/editing -->
<div class="modal fade" id="addStoreModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" action="/AdminSettings/CreateStore" class="modal-content border-0 rounded-0">
            @Html.AntiForgeryToken()
            <div class="modal-header"><h5 class="modal-title fw-bold">Thêm cửa hàng</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3"><label class="form-label fw-bold">Tên cửa hàng</label><input name="Name" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-bold">Địa chỉ</label><input name="Address" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-bold">Điện thoại</label><input name="Phone" class="form-control" required /></div>
                <div class="mb-0"><label class="form-label fw-bold">Quản lý</label><input name="ManagerName" class="form-control" required /></div>
            </div>
            <div class="modal-footer"><button type="submit" class="btn btn-danger">Lưu</button></div>
        </form>
    </div>
</div>

@foreach (var s in stores)
{
    <div class="modal fade" id="editStoreModal-@s.Id" tabindex="-1">
        <div class="modal-dialog">
            <form method="post" action="/AdminSettings/EditStore" class="modal-content border-0 rounded-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@s.Id" />
                <div class="modal-header"><h5 class="modal-title fw-bold">Sửa cửa hàng</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-bold">Tên cửa hàng</label><input name="Name" value="@s.Name" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Địa chỉ</label><input name="Address" value="@s.Address" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Điện thoại</label><input name="Phone" value="@s.Phone" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Quản lý</label><input name="ManagerName" value="@s.ManagerName" class="form-control" required /></div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@(s.IsActive ? "checked" : null)" id="activeStore-@s.Id">
                        <label class="form-check-label" for="activeStore-@s.Id">Hoạt động</label>
                    </div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-danger">Lưu thay đổi</button></div>
            </form>
        </div>
    </div>
}

<div class="modal fade" id="addSupplierModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" action="/AdminSettings/CreateSupplier" class="modal-content border-0 rounded-0">
            @Html.AntiForgeryToken()
            <div class="modal-header"><h5 class="modal-title fw-bold">Thêm nhà cung cấp</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3"><label class="form-label fw-bold">Tên nhà cung cấp</label><input name="Name" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-bold">Người liên hệ</label><input name="ContactPerson" class="form-control" /></div>
                <div class="mb-3"><label class="form-label fw-bold">Điện thoại</label><input name="Phone" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-bold">Email</label><input name="Email" type="email" class="form-control" /></div>
                <div class="mb-3"><label class="form-label fw-bold">Địa chỉ</label><input name="Address" class="form-control" /></div>
                <div class="mb-0"><label class="form-label fw-bold">Lead Time (ngày)</label><input name="LeadTimeDays" type="number" class="form-control" value="0" /></div>
            </div>
            <div class="modal-footer"><button type="submit" class="btn btn-danger">Lưu</button></div>
        </form>
    </div>
</div>

@foreach (var s in suppliers)
{
    <div class="modal fade" id="editSupplierModal-@s.Id" tabindex="-1">
        <div class="modal-dialog">
            <form method="post" action="/AdminSettings/EditSupplier" class="modal-content border-0 rounded-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@s.Id" />
                <div class="modal-header"><h5 class="modal-title fw-bold">Sửa nhà cung cấp</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-bold">Tên nhà cung cấp</label><input name="Name" value="@s.Name" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Người liên hệ</label><input name="ContactPerson" value="@s.ContactPerson" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Điện thoại</label><input name="Phone" value="@s.Phone" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Email</label><input name="Email" value="@s.Email" type="email" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Địa chỉ</label><input name="Address" value="@s.Address" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Lead Time (ngày)</label><input name="LeadTimeDays" value="@s.LeadTimeDays" type="number" class="form-control" /></div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@(s.IsActive ? "checked" : null)" id="activeSup-@s.Id">
                        <label class="form-check-label" for="activeSup-@s.Id">Hoạt động</label>
                    </div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-danger">Lưu thay đổi</button></div>
            </form>
        </div>
    </div>
}

<div class="modal fade" id="addCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" action="/AdminSettings/CreateCategory" class="modal-content border-0 rounded-0">
            @Html.AntiForgeryToken()
            <div class="modal-header"><h5 class="modal-title fw-bold">Thêm danh mục</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3"><label class="form-label fw-bold">Tên danh mục</label><input name="Name" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-bold">Hình ảnh URL</label><input name="ImageUrl" class="form-control" /></div>
                <div class="mb-3"><label class="form-label fw-bold">Thứ tự hiển thị</label><input name="DisplayOrder" type="number" class="form-control" value="0" /></div>
                <div class="mb-0"><label class="form-label fw-bold">Mô tả</label><textarea name="Description" class="form-control"></textarea></div>
            </div>
            <div class="modal-footer"><button type="submit" class="btn btn-danger">Lưu</button></div>
        </form>
    </div>
</div>

@foreach (var c in categories)
{
    <div class="modal fade" id="editCategoryModal-@c.Id" tabindex="-1">
        <div class="modal-dialog">
            <form method="post" action="/AdminSettings/EditCategory" class="modal-content border-0 rounded-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@c.Id" />
                <div class="modal-header"><h5 class="modal-title fw-bold">Sửa danh mục</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-bold">Tên danh mục</label><input name="Name" value="@c.Name" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Hình ảnh URL</label><input name="ImageUrl" value="@c.ImageUrl" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Thứ tự hiển thị</label><input name="DisplayOrder" value="@c.DisplayOrder" type="number" class="form-control" /></div>
                    <div class="mb-0"><label class="form-label fw-bold">Mô tả</label><textarea name="Description" class="form-control">@c.Description</textarea></div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-danger">Lưu thay đổi</button></div>
            </form>
        </div>
    </div>
}
