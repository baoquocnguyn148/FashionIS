@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
    <h1 class="mb-4">Dashboard</h1>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="dashboard-label mb-1">Tổng sản phẩm</p>
                            <h2 class="dashboard-stat mb-0">@ViewBag.TotalProducts</h2>
                        </div>
                        <div class="text-primary" style="font-size: 2.5rem;">📦</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="dashboard-label mb-1">Tổng đơn hàng</p>
                            <h2 class="dashboard-stat mb-0">@ViewBag.TotalOrders</h2>
                        </div>
                        <div class="text-success" style="font-size: 2.5rem;">🛒</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="dashboard-label mb-1">Tổng khách hàng</p>
                            <h2 class="dashboard-stat mb-0">@ViewBag.TotalCustomers</h2>
                        </div>
                        <div class="text-info" style="font-size: 2.5rem;">👥</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="dashboard-label mb-1">Doanh thu hôm nay</p>
                            <h2 class="dashboard-stat mb-0">@(((decimal)ViewBag.TodayRevenue).ToString("N0")) đ</h2>
                        </div>
                        <div class="text-danger" style="font-size: 2.5rem;">💰</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Doanh thu tháng này</h5>
                </div>
                <div class="card-body">
                    <h3 class="text-primary">@(((decimal)ViewBag.ThisMonthRevenue).ToString("N0")) đ</h3>
                    @if ((decimal)ViewBag.RevenueGrowth > 0)
                    {
                        <p class="text-success mb-0">
                            <span class="badge bg-success">+@(((decimal)ViewBag.RevenueGrowth).ToString("F1"))%</span>
                            so với tháng trước
                        </p>
                    }
                    else if ((decimal)ViewBag.RevenueGrowth < 0)
                    {
                        <p class="text-danger mb-0">
                            <span class="badge bg-danger">@(((decimal)ViewBag.RevenueGrowth).ToString("F1"))%</span>
                            so với tháng trước
                        </p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Sản phẩm bán chạy</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.TopProducts != null && ((IEnumerable<dynamic>)ViewBag.TopProducts).Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Số lượng bán</th>
                                        <th>Doanh thu</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in ViewBag.TopProducts)
                                    {
                                        <tr>
                                            <td>@product.ProductName</td>
                                            <td>@product.TotalSold</td>
                                            <td>@(((decimal)product.Revenue).ToString("N0")) đ</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có dữ liệu</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Products" class="btn btn-primary">Quản lý sản phẩm</a>
                        <a asp-action="Orders" class="btn btn-primary">Quản lý đơn hàng</a>
                        <a asp-action="Inventory" class="btn btn-primary">Quản lý tồn kho</a>
                        <a asp-action="Customers" class="btn btn-primary">Quản lý khách hàng</a>
                        <a asp-action="Reports" class="btn btn-outline-primary">Báo cáo</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
